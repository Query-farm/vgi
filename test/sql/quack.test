# name: test/sql/vgi.test
# description: test vgi extension
# group: [sql]

# Before we load the extension, this will fail
statement error
SELECT vgi('Sam');
----
Catalog Error: Scalar Function with name vgi does not exist!

# Require statement will ensure this test is run with this extension loaded
require vgi

# Confirm the extension works
query I
SELECT vgi('Sam');
----
vgi Sam 🐥

query I
SELECT vgi_openssl_version('Michael') ILIKE 'vgi Michael, my linked OpenSSL version is OpenSSL%';
----
true
