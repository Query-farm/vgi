# name: test/sql/vgi.test
# description: test vgi extension
# group: [vgi]

# Require statement will ensure this test is run with this extension loaded
require vgi

# Test vgi_catalogs with non-existent worker path. The exact error differs by
# platform (POSIX exec-fail "not found or not executable"; MSVC cmd.exe "failed
# during unary RPC (exit code 1)"; MinGW "RPC response stream EOF (no schema)"),
# so just assert that it errors.
statement error
SELECT * FROM vgi_catalogs('/nonexistent/path/to/worker');
----

# Test vgi_catalogs with a path that is not a valid VGI worker. The specific
# error differs by platform (POSIX: "RPC response stream EOF (no schema)" when
# /bin/echo runs but speaks no protocol; Windows: a cmd.exe not-found failure),
# so assert only that it errors.
statement error
SELECT * FROM vgi_catalogs('/bin/echo');
----

# Test vgi_catalogs with empty string path
statement error
SELECT * FROM vgi_catalogs('');
----

# A worker that prints to stderr then exits non-zero should surface its stderr
# in the error message (so users see *why* it failed, not just an exit code).
# POSIX-only: the worker command is a /bin/sh snippet and stderr capture relies
# on the subprocess (fork/exec) transport.
require notwindows

statement error
SELECT * FROM vgi_catalogs('echo VGI_TEST_STDERR_MARKER 1>&2; exit 2');
----
worker stderr:
