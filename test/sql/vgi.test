# name: test/sql/vgi.test
# description: test vgi extension
# group: [vgi]

# Require statement will ensure this test is run with this extension loaded
require vgi

# Test vgi_catalogs with non-existent worker path. The exact error differs by
# platform — POSIX exec-fail ("not found or not executable") vs Windows cmd.exe
# exit 1 ("failed during unary RPC") — so assert only the common "VGI worker"
# prefix that both produce.
statement error
SELECT * FROM vgi_catalogs('/nonexistent/path/to/worker');
----
VGI worker

# Test vgi_catalogs with a path that is not a valid VGI worker. The specific
# error differs by platform (POSIX: "RPC response stream EOF (no schema)" when
# /bin/echo runs but speaks no protocol; Windows: a cmd.exe not-found failure),
# so assert only that it errors.
statement error
SELECT * FROM vgi_catalogs('/bin/echo');
----

# Test vgi_catalogs with empty string path
statement error
SELECT * FROM vgi_catalogs('');
----
