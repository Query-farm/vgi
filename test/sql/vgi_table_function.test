# name: test/sql/vgi_table_function.test
# description: test vgi_table_function with VGI worker
# group: [vgi]

# This test requires a VGI worker to be available
require-env VGI_TEST_WORKER

require vgi

# =============================================================================
# Error Handling
# =============================================================================

# Test invalid function name
statement error
SELECT * FROM vgi_table_function('${VGI_TEST_WORKER}', 'nonexistent_function', [5]);
----
Unknown function

# Test invalid worker path
statement error
SELECT * FROM vgi_table_function('/nonexistent/worker/path', 'sequence', [5]);
----
IO Error

# Test generator_exception - worker raises an exception after generating some rows
statement error
SELECT * FROM vgi_table_function('${VGI_TEST_WORKER}', 'generator_exception', [2]);
----
Intentional failure after 2 batches

# =============================================================================
# Positive Tests - sequence function
# =============================================================================

# Basic sequence: 5 values (0-4)
query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [5]);
----
5

query IIII
SELECT COUNT(*), SUM(n), MIN(n), MAX(n) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [5]);
----
5	10	0	4

# Aggregation on 100 rows
query IIII
SELECT COUNT(*), SUM(n), MIN(n), MAX(n) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [100]);
----
100	4950	0	99

# Larger dataset - 10000 rows
query II
SELECT COUNT(*), SUM(n) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [10000]);
----
10000	49995000

# =============================================================================
# Positive Tests - ten_thousand function (no args)
# =============================================================================

query II
SELECT COUNT(*), SUM(n) FROM vgi_table_function('${VGI_TEST_WORKER}', 'ten_thousand', []);
----
10000	49995000

