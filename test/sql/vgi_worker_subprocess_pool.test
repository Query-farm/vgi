# name: test/sql/vgi_worker_subprocess_pool.test
# description: test vgi worker pool functionality
# group: [vgi]

# This test requires a VGI worker to be available
require-env VGI_TEST_WORKER

require vgi

# ============================================================================
# Test vgi_worker_subprocess_pool() table function structure
# ============================================================================

# Verify vgi_worker_subprocess_pool() returns a table with the correct schema
query III
SELECT typeof(worker_path), typeof(pid), typeof(age_seconds) FROM vgi_worker_subprocess_pool() LIMIT 0;
----

# ============================================================================
# Test vgi_worker_pool_flush() table function
# ============================================================================

# First flush any workers left over from previous tests
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Flush should return an integer count (0 when pool is empty)
query I
SELECT typeof(flushed) FROM vgi_worker_pool_flush();
----
BIGINT

# Flush on empty pool returns 0
query I
SELECT flushed FROM vgi_worker_pool_flush();
----
0

# ============================================================================
# Test worker pool settings exist
# ============================================================================

query I
SELECT COUNT(*) FROM duckdb_settings() WHERE name = 'vgi_worker_pool_idle_limit_seconds';
----
1

query I
SELECT COUNT(*) FROM duckdb_settings() WHERE name = 'vgi_worker_pool_max';
----
1

# ============================================================================
# Test worker pooling - workers should be reused across queries
# ============================================================================

# First, flush the pool to start clean
query I
SELECT flushed FROM vgi_worker_pool_flush();
----
0

# Run a query to populate the pool
query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [10]);
----
10

# Pool should now have workers (scan worker + cardinality RPC worker)
query I
SELECT COUNT(*) >= 1 FROM vgi_worker_subprocess_pool();
----
true

# Snapshot the pool state (save all PIDs)
statement ok
CREATE TEMP TABLE pool_snapshot AS SELECT * FROM vgi_worker_subprocess_pool();

# Run another query - should acquire from pool, then return to pool
query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [5]);
----
5

# Pool should still have workers
query I
SELECT COUNT(*) >= 1 FROM vgi_worker_subprocess_pool();
----
true

# THE KEY TEST: Verify at least one PID was reused from the pool
query I
SELECT COUNT(*) > 0 FROM vgi_worker_subprocess_pool() p JOIN pool_snapshot s ON p.pid = s.pid;
----
true

# Clean up snapshot
statement ok
DROP TABLE pool_snapshot;

# Flush and verify pool is empty
query I
SELECT flushed >= 1 FROM vgi_worker_pool_flush();
----
true

query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

# ============================================================================
# Test vgi_worker_pool_stats() table function
# ============================================================================

# Verify schema
query III
SELECT typeof(worker_path), typeof(hits), typeof(misses) FROM vgi_worker_pool_stats() LIMIT 0;
----

# Flush pool, then run a query (first run = miss)
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [10]);
----
10

# Stats should show at least 1 miss (fresh worker was spawned)
query I
SELECT SUM(misses) >= 1 FROM vgi_worker_pool_stats();
----
true

# Run another query - should hit the pool (worker was returned after first query)
query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [5]);
----
5

# Stats should now show at least 1 hit
query I
SELECT SUM(hits) >= 1 FROM vgi_worker_pool_stats();
----
true

# Flush pool and verify stats still reflect historical counts
query I
SELECT flushed >= 1 FROM vgi_worker_pool_flush();
----
true

query I
SELECT SUM(hits) >= 1 FROM vgi_worker_pool_stats();
----
true

# ============================================================================
# Test pool=false ATTACH option disables pooling
# ============================================================================

# Flush pool to start clean
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Attach with pooling disabled
statement ok
ATTACH 'example' AS vgi_nopool (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool false);

# Run a table scan - this should NOT pool the worker
query I
SELECT COUNT(*) FROM vgi_nopool.main.sequence(5, batch_size := 1000);
----
5

# Pool should still be empty because pool=false
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

# Run a scalar function - this should also NOT pool the worker
query I
SELECT vgi_nopool.main.double(21);
----
42

# Pool should still be empty
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

statement ok
DETACH vgi_nopool;

# ============================================================================
# Test pool=true ATTACH option pools workers
# ============================================================================

# Flush pool first
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Attach with pooling explicitly enabled
statement ok
ATTACH 'example' AS vgi_pool (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool true);

# Run a table scan - this SHOULD pool the worker
query I
SELECT COUNT(*) FROM vgi_pool.main.sequence(5, batch_size := 1000);
----
5

# Pool should have at least one worker now
query I
SELECT COUNT(*) >= 1 FROM vgi_worker_subprocess_pool();
----
true

statement ok
DETACH vgi_pool;

# Clean up
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# ============================================================================
# Test pool_max=0 ATTACH option disables pooling
# ============================================================================

# Flush pool first
query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Attach with pool_max=0 (pool disabled for this catalog)
statement ok
ATTACH 'example' AS vgi_pm0 (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool_max 0);

# Run a table scan - should NOT pool the worker
query I
SELECT COUNT(*) FROM vgi_pm0.main.sequence(5, batch_size := 1000);
----
5

# Pool should be empty (pool_max=0 disables pooling)
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

# Run a scalar function - also should NOT pool
query I
SELECT vgi_pm0.main.double(21);
----
42

query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

statement ok
DETACH vgi_pm0;

# ============================================================================
# Test pool_max=1 limits pool size for this path
# ============================================================================

query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Attach with pool_max=1
statement ok
ATTACH 'example' AS vgi_pm1 (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool_max 1);

# Run a query to populate the pool
query I
SELECT COUNT(*) FROM vgi_pm1.main.sequence(5, batch_size := 1000);
----
5

# Pool should have exactly 1 worker
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
1

# Run another query - pool should still be limited to 1
query I
SELECT COUNT(*) FROM vgi_pm1.main.sequence(3, batch_size := 1000);
----
3

query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
1

statement ok
DETACH vgi_pm1;

query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# ============================================================================
# Test pool_timeout controls idle cleanup
# ============================================================================

query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# Attach with pool_timeout=1 (workers expire after 1 second)
statement ok
ATTACH 'example' AS vgi_pt1 (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool_timeout 1);

# Run a query to pool a worker
query I
SELECT COUNT(*) FROM vgi_pt1.main.sequence(5, batch_size := 1000);
----
5

# Pool should have a worker now
query I
SELECT COUNT(*) >= 1 FROM vgi_worker_subprocess_pool();
----
true

# Wait for the pool_timeout to expire (cleanup runs every 1s, timeout is 1s)
query I
SELECT sleep_ms(3000);
----
NULL

# Pool should be empty now (worker expired after 1 second idle)
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

statement ok
DETACH vgi_pt1;

# ============================================================================
# Test pool=false with pool_max still disables pooling
# ============================================================================

query I
SELECT flushed >= 0 FROM vgi_worker_pool_flush();
----
true

# pool=false should disable even if pool_max is set
statement ok
ATTACH 'example' AS vgi_pf_pm (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', pool false, pool_max 5);

query I
SELECT COUNT(*) FROM vgi_pf_pm.main.sequence(5, batch_size := 1000);
----
5

# Pool should be empty because pool=false overrides pool_max
query I
SELECT COUNT(*) FROM vgi_worker_subprocess_pool();
----
0

statement ok
DETACH vgi_pf_pm;
