# name: test/sql/integration/attach/versioned_tables_spec.test
# description: npm-style data_version_spec matching (^, ~, bare) + 1.1.0 schema evolution (animals gets a `color` column)
# group: [vgi_integration_attach]

require-env VGI_VERSIONED_TABLES_WORKER

require vgi

require httpfs

# ============================================================================
# Exact 1.0.0: pre-evolution animals schema (3 columns, no color).
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_exact (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '1.0.0'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_exact';
----
1.0.0

query T
SELECT column_name FROM information_schema.columns
WHERE table_catalog='v_exact' AND table_schema='main' AND table_name='animals'
ORDER BY ordinal_position;
----
name
legs
sound

statement ok
DETACH v_exact;

# ============================================================================
# Caret ^1.0.0: latest 1.x.x → resolves to 1.1.0 (animals gains `color`).
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_caret (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '^1.0.0'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_caret';
----
1.1.0

query T
SELECT column_name FROM information_schema.columns
WHERE table_catalog='v_caret' AND table_schema='main' AND table_name='animals'
ORDER BY ordinal_position;
----
name
legs
sound
color

query T
SELECT color FROM v_caret.main.animals WHERE name='cow';
----
brown

statement ok
DETACH v_caret;

# ============================================================================
# Tilde ~1.0.0: pin to 1.0.x → only 1.0.0 exists → resolves to 1.0.0.
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_tilde (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '~1.0.0'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_tilde';
----
1.0.0

statement ok
DETACH v_tilde;

# ============================================================================
# Bare major `1`: latest version in major 1 → 1.1.0.
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_major (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '1'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_major';
----
1.1.0

statement ok
DETACH v_major;

# ============================================================================
# Bare major.minor `1.0`: pin to exact 1.0.0.
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_mm (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '1.0'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_mm';
----
1.0.0

statement ok
DETACH v_mm;

# ============================================================================
# ^2.0.0 resolves cleanly to 2.0.0 (only 2.x in the supported set).
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_caret2 (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '^2.0.0'
);

query T
SELECT tags['vgi_resolved_data_version'] FROM duckdb_databases() WHERE database_name='v_caret2';
----
2.0.0

statement ok
DETACH v_caret2;

# ============================================================================
# Unsatisfiable spec: no 2.5.x exists.
# ============================================================================

statement error
ATTACH 'versioned_tables' AS v_bad (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '~2.5.0'
);
----
Unsupported data_version_spec

# ============================================================================
# Pool isolation: two attaches at different resolved versions keep distinct
# vgi_resolved_data_version tags (a shared pooled worker would contaminate).
# ============================================================================

statement ok
ATTACH 'versioned_tables' AS v_pool_a (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '1.0.0'
);

statement ok
ATTACH 'versioned_tables' AS v_pool_b (
    TYPE vgi,
    LOCATION '${VGI_VERSIONED_TABLES_WORKER}',
    data_version_spec '^1.0.0'
);

query TT
SELECT database_name, tags['vgi_resolved_data_version']
FROM duckdb_databases()
WHERE database_name IN ('v_pool_a', 'v_pool_b')
ORDER BY database_name;
----
v_pool_a	1.0.0
v_pool_b	1.1.0

statement ok
DETACH v_pool_a;

statement ok
DETACH v_pool_b;
