# name: test/sql/integration/secret/secret_function_backed_table.test
# description: A function-backed table whose backing function resolves a secret in on_bind
# group: [vgi_integration_secret]

# Regression: the backing function (secret_demo) calls params.secrets.get() in
# on_bind, which returns a two-phase secret-scope request. Table schema derivation
# must retry the bind with resolved secrets rather than adopt the empty scope-request
# schema (which produced a 0-column table: "column not found" / "vector of size 0").
# Covers the intersection of secrets x function-backed tables that the separate
# secret_table_function.test (function call) and inlined_scan_function.test (no
# secret) never exercised together.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'test_str', api_key 'ak-456', port 8080, use_ssl true, timeout 45.0);

# ============================================================================
# The table's schema must derive correctly (not the empty scope-request schema).
# A 0-column table would fail these binds ("column not found" / empty *).
# ============================================================================

query I
SELECT COUNT(*) FROM (DESCRIBE example.data.secret_demo_table) WHERE column_name IN ('key', 'value', 'arrow_type');
----
3

# Scanning the table (no parentheses — it's a table) returns the secret rows.
query I
SELECT COUNT(*) > 0 FROM example.data.secret_demo_table;
----
true

# The scan resolves the secret and surfaces its values, same as the function form.
query T
SELECT value FROM example.data.secret_demo_table WHERE key = 'secret_string';
----
test_str

query T
SELECT value FROM example.data.secret_demo_table WHERE key = 'api_key';
----
ak-456
