# name: test/sql/integration/secret/secret_scalar.test
# description: Validates scalar function receiving secrets with diverse value types
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Create a secret with diverse value types
# ============================================================================

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'hello_world', api_key 'key-abc-123', port 5432, use_ssl true, timeout 30.5);

# ============================================================================
# Call return_secret_value() which requires vgi_example secret
# The function returns a JSON string of the secret's key-value pairs
# ============================================================================

query I
SELECT example.return_secret_value() IS NOT NULL;
----
true

# ============================================================================
# Verify the function returns valid JSON containing our secret values
# The JSON should contain the key-value pairs we set
# ============================================================================

query I
SELECT example.return_secret_value() LIKE '%hello_world%';
----
true

query I
SELECT example.return_secret_value() LIKE '%key-abc-123%';
----
true

# ============================================================================
# DROP and re-create with different values
# ============================================================================

statement ok
DROP SECRET test_secret;

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'new_value', api_key 'new_key', port 9999, use_ssl false, timeout 60.0);

query I
SELECT example.return_secret_value() LIKE '%new_value%';
----
true

query I
SELECT example.return_secret_value() LIKE '%new_key%';
----
true

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP SECRET test_secret;

statement ok
DETACH example;
