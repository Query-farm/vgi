# name: test/sql/integration/secret/secret_table_in_out.test
# description: A table-in-out function that resolves a secret in on_bind (two-phase) and appends it per row
# group: [vgi_integration_secret]

# Regression / coverage: secret_in_out calls params.secrets.get() in on_bind, which
# returns a two-phase secret-scope request. Unlike the table-function case
# (secret_table_function.test) and the function-backed-table case
# (secret_function_backed_table.test), this exercises the intersection of the
# two-phase secret bind with a table-in-out function's INPUT stream — the bind
# must retry with resolved secrets AND preserve the input schema, then the
# resolved secret must be available at process() time to populate an output column.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'test_str', api_key 'ak-456', port 8080, use_ssl true, timeout 45.0);

# ============================================================================
# The bind must derive the two-column output schema (input `n` + `secret_string`),
# not the empty scope-request schema. A 0-column bind would fail these queries.
# ============================================================================

query I
SELECT COUNT(*) FROM (DESCRIBE SELECT * FROM example.main.secret_in_out((SELECT 1 AS n))) WHERE column_name IN ('n', 'secret_string');
----
2

# Every input row is emitted with the resolved secret's secret_string appended.
query II
SELECT n, secret_string FROM example.main.secret_in_out((SELECT 1 AS n UNION ALL SELECT 2 AS n)) ORDER BY n;
----
1	test_str
2	test_str

# Row count is preserved (table-in-out is 1:1 here), and the secret value is
# constant across rows because it comes from the single resolved secret.
query I
SELECT COUNT(*) FROM example.main.secret_in_out((SELECT * FROM range(5) t(n)));
----
5

query I
SELECT COUNT(DISTINCT secret_string) FROM example.main.secret_in_out((SELECT * FROM range(5) t(n)));
----
1

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP SECRET test_secret;

statement ok
DETACH example;
