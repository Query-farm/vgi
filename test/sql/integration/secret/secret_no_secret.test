# name: test/sql/integration/secret/secret_no_secret.test
# description: Validates function behavior when no matching secret exists
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Call functions without any secret created
# Functions with optional secrets should handle gracefully (receive None)
# ============================================================================

# secret_demo with no secret should return empty result
query I
SELECT COUNT(*) FROM example.secret_demo();
----
0

# ============================================================================
# Cleanup
