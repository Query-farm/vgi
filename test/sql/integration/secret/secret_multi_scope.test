# name: test/sql/integration/secret/secret_multi_scope.test
# description: Two secrets of the SAME type with different scopes resolved in a
#              single bind — exercises name-keyed resolved secrets and per-path
#              scope selection (Secrets.for_scope_of_type).
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Two vgi_example secrets, one per bucket scope. Before the name-keying fix the
# connector kept only one secret per type, so this could not work.

statement ok
CREATE SECRET scoped_a (TYPE vgi_example, secret_string 'a', api_key 'ka', port 1, use_ssl true, timeout 1.0, SCOPE 's3://bucket-a/');

statement ok
CREATE SECRET scoped_b (TYPE vgi_example, secret_string 'b', api_key 'kb', port 2, use_ssl true, timeout 2.0, SCOPE 's3://bucket-b/');

# multi_secret_demo requests BOTH scopes in one bind; for_scope_of_type then
# selects the secret matching the path argument. Each path gets its own secret.

query T
SELECT api_key FROM example.multi_secret_demo('s3://bucket-a/data.parquet');
----
ka

query T
SELECT api_key FROM example.multi_secret_demo('s3://bucket-b/other/file.csv');
----
kb

# A path matching neither scope selects no credentials (empty api_key).

query I
SELECT COUNT(*) FROM example.multi_secret_demo('s3://no-such-bucket/x') WHERE api_key <> '';
----
0

statement ok
DROP SECRET scoped_a;

statement ok
DROP SECRET scoped_b;

statement ok
DETACH example;
