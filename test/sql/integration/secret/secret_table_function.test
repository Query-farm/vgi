# name: test/sql/integration/secret/secret_table_function.test
# description: Validates table function receiving secrets and outputting key-value pairs
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Create a secret with diverse value types
# ============================================================================

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'test_str', api_key 'ak-456', port 8080, use_ssl true, timeout 45.0);

# ============================================================================
# Call secret_demo() which outputs secret key-value pairs as rows
# Output schema: key (string), value (string), arrow_type (string)
# ============================================================================

# Should return rows for each secret field
query I
SELECT COUNT(*) > 0 FROM example.secret_demo();
----
true

# Verify specific keys are present
query I
SELECT COUNT(*) FROM example.secret_demo() WHERE key = 'secret_string';
----
1

query I
SELECT COUNT(*) FROM example.secret_demo() WHERE key = 'api_key';
----
1

query I
SELECT COUNT(*) FROM example.secret_demo() WHERE key = 'port';
----
1

# Verify values
query T
SELECT value FROM example.secret_demo() WHERE key = 'secret_string';
----
test_str

query T
SELECT value FROM example.secret_demo() WHERE key = 'api_key';
----
ak-456

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP SECRET test_secret;

statement ok
DETACH example;
