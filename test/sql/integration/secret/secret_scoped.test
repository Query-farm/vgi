# name: test/sql/integration/secret/secret_scoped.test
# description: Validates two-phase bind with scoped secrets (longest-prefix matching)
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Create scoped secrets
# ============================================================================

statement ok
CREATE SECRET scoped_a (TYPE vgi_example, secret_string 'for-bucket-a', api_key 'ka', port 5432, use_ssl true, timeout 30.5, SCOPE 's3://bucket-a/');

statement ok
CREATE SECRET scoped_b (TYPE vgi_example, secret_string 'for-bucket-b', api_key 'kb', port 5433, use_ssl false, timeout 60.0, SCOPE 's3://bucket-b/');

# ============================================================================
# scoped_secret_demo resolves secrets via two-phase bind
# It takes a path argument and does a scoped lookup
# Output: scope (string), found (bool), secret_keys (string)
# ============================================================================

# Should resolve scoped_a via longest-prefix match
query TT
SELECT scope, found FROM example.scoped_secret_demo('s3://bucket-a/data.parquet');
----
s3://bucket-a/data.parquet	true

# Should resolve scoped_b
query TT
SELECT scope, found FROM example.scoped_secret_demo('s3://bucket-b/other/file.csv');
----
s3://bucket-b/other/file.csv	true

# ============================================================================
# No matching scope — should return found=false
# ============================================================================

query TT
SELECT scope, found FROM example.scoped_secret_demo('s3://no-such-bucket/file.txt');
----
s3://no-such-bucket/file.txt	false

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP SECRET scoped_a;

statement ok
DROP SECRET scoped_b;

statement ok
DETACH example;
