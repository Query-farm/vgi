# name: test/sql/integration/secret/secret_aggregate.test
# description: An aggregate whose result type is chosen from a statically-resolved secret
# group: [vgi_integration_secret]

# Coverage: closes the aggregate x secret intersection. secret_typed_sum declares
# a Secret("vgi_example") on its aggregate on_bind, so the extension pre-resolves
# the secret and delivers it on AggregateBindRequest.secrets. on_bind reads the
# secret's `use_ssl` value and returns DOUBLE (true) or BIGINT (false); the sum
# itself is computed normally in update/finalize. This is the supported aggregate
# secret path — the secret is read at bind time only. Secret *values* do not reach
# update/finalize (they receive an empty ResolvedSecrets), and a two-phase
# params.secrets.get() inside an aggregate on_bind raises NotImplementedError;
# secret_typed_sum uses the static `to_dict().of_type()` accessor to avoid that.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# use_ssl = true  ->  the secret makes the aggregate return DOUBLE
# ============================================================================

statement ok
CREATE SECRET ssl_on (TYPE vgi_example, secret_string 'test_str', api_key 'ak-456', port 8080, use_ssl true, timeout 45.0);

query T
SELECT typeof(example.main.secret_typed_sum(n)) FROM (SELECT 1 AS n UNION ALL SELECT 2 UNION ALL SELECT 3);
----
DOUBLE

query R
SELECT example.main.secret_typed_sum(n) FROM (SELECT 1 AS n UNION ALL SELECT 2 UNION ALL SELECT 3);
----
6.0

# The secret only shapes the type; the aggregation is a normal per-group sum.
query IR
SELECT g, example.main.secret_typed_sum(n) AS s
FROM (VALUES (0, 1), (0, 2), (1, 10), (1, 20)) t(g, n)
GROUP BY g ORDER BY g;
----
0	3.0
1	30.0

statement ok
DROP SECRET ssl_on;

# ============================================================================
# use_ssl = false  ->  the same aggregate returns BIGINT
# Proves on_bind reads the secret VALUE (not merely its presence).
# ============================================================================

statement ok
CREATE SECRET ssl_off (TYPE vgi_example, secret_string 'test_str', api_key 'ak-456', port 8080, use_ssl false, timeout 45.0);

query T
SELECT typeof(example.main.secret_typed_sum(n)) FROM (SELECT 10 AS n UNION ALL SELECT 20 UNION ALL SELECT 30);
----
BIGINT

query I
SELECT example.main.secret_typed_sum(n) FROM (SELECT 10 AS n UNION ALL SELECT 20 UNION ALL SELECT 30);
----
60

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP SECRET ssl_off;

statement ok
DETACH example;
