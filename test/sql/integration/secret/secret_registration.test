# name: test/sql/integration/secret/secret_registration.test
# description: Validates secret type registration and basic CREATE/DROP SECRET
# group: [vgi_integration_secret]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Secret Type Registration
# The vgi_example secret type must be registered after ATTACH
# ============================================================================

query I
SELECT COUNT(*)
FROM duckdb_secret_types()
WHERE type = 'vgi_example';
----
1

# ============================================================================
# CREATE SECRET with the registered type
# ============================================================================

statement ok
CREATE SECRET test_secret (TYPE vgi_example, secret_string 'hello', api_key 'k123', port 5432, use_ssl true, timeout 30.5);

# Verify the secret exists
query I
SELECT COUNT(*) FROM duckdb_secrets() WHERE type = 'vgi_example';
----
1

# ============================================================================
# DROP SECRET
# ============================================================================

statement ok
DROP SECRET test_secret;

# Verify the secret is gone
query I
SELECT COUNT(*) FROM duckdb_secrets() WHERE type = 'vgi_example';
----
0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
