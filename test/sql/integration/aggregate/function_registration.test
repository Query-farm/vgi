# name: test/sql/integration/aggregate/function_registration.test
# description: Validates aggregate function registration metadata
# group: [vgi_integration_aggregate]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Function Inventory
# All aggregate functions must be registered
# ============================================================================

# Exclude dynamic-code aggregates (vgi_dynamic_agg, vgi_dynamic_ml_agg) —
# those are only registered by workers that support dynamic language
# interpretation (Python / JavaScript). See function_registration_dynamic.test.
#
# 2 of the 17 are one schema-disambiguation probe: test_same_name_agg is
# declared TWICE — once in `main`, once in `data` — so the pair collides on name
# and is separated only by the owning schema. It backs
# aggregate/same_name_schemas.test, the aggregate member of the family whose
# other two members are scalar/same_name_schemas.test and
# table_in_out/same_name_schemas.test. Every aggregate RPC has to name the
# schema or the worker re-resolves by bare name and runs the other one.

query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'aggregate'
  AND function_name NOT IN ('vgi_dynamic_agg', 'vgi_dynamic_ml_agg');
----
17

query TT
SELECT function_name, return_type
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'aggregate'
  AND function_name NOT IN ('vgi_dynamic_agg', 'vgi_dynamic_ml_agg')
ORDER BY function_name;
----
nest_tensor	ANY
secret_typed_sum	ANY
test_same_name_agg	VARCHAR
test_same_name_agg	VARCHAR
vgi_avg	DOUBLE
vgi_count	BIGINT
vgi_generic_sum	ANY
vgi_listagg	VARCHAR
vgi_percentile	DOUBLE
vgi_streaming_sum	BIGINT
vgi_sum	BIGINT
vgi_sum_all	DOUBLE
vgi_weighted_sum	DOUBLE
vgi_window_listagg	VARCHAR
vgi_window_median	DOUBLE
vgi_window_sum	BIGINT
vgi_window_sum_batch	BIGINT

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
