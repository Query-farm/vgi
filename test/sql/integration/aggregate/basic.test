# name: test/sql/integration/aggregate/basic.test
# description: Basic aggregate function tests (ungrouped)
# group: [vgi_integration_aggregate]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
USE example;

# ============================================================================
# vgi_sum — single int64 input
# ============================================================================

query I
SELECT vgi_sum(i::BIGINT) FROM range(10) t(i);
----
45

query I
SELECT vgi_sum(i::BIGINT) FROM range(100) t(i);
----
4950

# ============================================================================
# vgi_count — nullary aggregate (no input columns)
# ============================================================================

query I
SELECT vgi_count() FROM range(100) t(i);
----
100

query I
SELECT vgi_count() FROM range(1) t(i);
----
1

# ============================================================================
# vgi_avg — two-field state (sum + count)
# ============================================================================

query R
SELECT vgi_avg(i::BIGINT) FROM range(10) t(i);
----
4.5

query R
SELECT vgi_avg(i::BIGINT) FROM range(4) t(i);
----
1.5

# ============================================================================
# NULL handling — NullHandling.DEFAULT skips NULLs
# ============================================================================

query I
SELECT vgi_sum(x) FROM (VALUES (1::BIGINT), (NULL), (3::BIGINT)) t(x);
----
4

# All-NULL SUM returns NULL (SQL standard). With NullHandling.DEFAULT, DuckDB
# skips all NULL rows, so update() is never called. The framework passes None
# for the state in finalize(), and the function returns NULL.
query I
SELECT vgi_sum(x) FROM (VALUES (NULL::BIGINT), (NULL), (NULL)) t(x);
----
NULL

# ============================================================================
# Empty table — no rows at all
# ============================================================================

query I
SELECT vgi_sum(i::BIGINT) FROM range(0) t(i);
----
NULL

query I
SELECT vgi_count() FROM range(0) t(i);
----
0

# ============================================================================
# Regression: vgi_sum where the per-group post-update state happens to be
# byte-equal to the initial state. Earlier the framework optimised away the
# storage write for such groups, conflating "no rows" with "rows whose
# update was a no-op (all NULL inputs)" — so SUM of zeros returned NULL
# instead of 0. ``vgi_sum(0)`` must now return 0 just like the built-in.
# ============================================================================

query I
SELECT vgi_sum(0::BIGINT) FROM range(5) t(i);
----
0

query I
SELECT vgi_sum(x) FROM (VALUES (0::BIGINT), (0::BIGINT), (0::BIGINT)) t(x);
----
0

# Same regression manifests as a window aggregate, where every frame
# produces a state byte-equal to initial: built-in ``sum`` returns 0
# for the single-row frame at row 0, and ``vgi_sum`` must too.
query II
SELECT i, vgi_sum(i::BIGINT) OVER (ORDER BY i ROWS BETWEEN 1 PRECEDING AND CURRENT ROW)
FROM range(5) t(i);
----
0	0
1	1
2	3
3	5
4	7

# ============================================================================
# Cleanup
# ============================================================================

statement ok
USE memory;

statement ok
DETACH example;
