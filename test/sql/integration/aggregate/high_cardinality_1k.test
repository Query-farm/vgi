# name: test/sql/integration/aggregate/high_cardinality_1k.test
# description: GROUP BY with 1000 groups, single- and multi-threaded
# group: [vgi_integration_aggregate]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
USE example;

# ============================================================================
# 1000 groups, single-threaded
# ============================================================================

statement ok
SET threads=1;

query I
SELECT count(*) FROM (
    SELECT i % 1000 AS grp, vgi_sum(i::BIGINT) AS s
    FROM range(100000) t(i)
    GROUP BY grp
) sub WHERE s > 0;
----
1000

# Verify a specific group's sum is correct
# Group 0: 0+1000+2000+...+99000 = 1000 * (0+1+2+...+99) = 1000*4950 = 4950000
query I
SELECT s FROM (
    SELECT i % 1000 AS grp, vgi_sum(i::BIGINT) AS s
    FROM range(100000) t(i)
    GROUP BY grp
) sub WHERE grp = 0;
----
4950000

# ============================================================================
# 1000 groups, multi-threaded
#
# vgi_sum is RPC-bound to the Python worker — the GIL serialises updates
# regardless of DuckDB's thread count, so the multi-threaded count is
# byte-identical to (and the same speed as) the single-threaded one.  We
# keep just the group-0 sanity check under threads=4 to verify the
# aggregate produces correct results when the planner runs the parallel
# path; the redundant count(*) variant was dropped after profiling showed
# it added ~4 s with zero incremental coverage (see git history).
# ============================================================================

statement ok
SET threads=4;

# Group 0 check with parallelism — confirms the parallel aggregate path
# matches the serial result.
query I
SELECT s FROM (
    SELECT i % 1000 AS grp, vgi_sum(i::BIGINT) AS s
    FROM range(100000) t(i)
    GROUP BY grp
) sub WHERE grp = 0;
----
4950000

# ============================================================================
# Cleanup
# ============================================================================

statement ok
USE memory;

statement ok
DETACH example;
