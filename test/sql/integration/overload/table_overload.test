# name: test/sql/integration/overload/table_overload.test
# description: Validates table function overloading by positional arg count and type
# group: [vgi_integration_overload]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Overload dispatch — 1 arg: example.make_series(count)
# ============================================================================

query I
SELECT * FROM example.make_series(5) ORDER BY value;
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.make_series(10);
----
10

# ============================================================================
# Overload dispatch — 2 args: example.make_series(start, stop)
# ============================================================================

query I
SELECT * FROM example.make_series(3, 7) ORDER BY value;
----
3
4
5
6

query I
SELECT COUNT(*) FROM example.make_series(0, 100);
----
100

# ============================================================================
# Overload dispatch — 3 args: example.make_series(start, stop, step)
# ============================================================================

query I
SELECT * FROM example.make_series(0, 10, 3) ORDER BY value;
----
0
3
6
9

query I
SELECT * FROM example.make_series(5, 20, 5) ORDER BY value;
----
5
10
15

# ============================================================================
# Aggregation
# ============================================================================

query IIII
SELECT SUM(value), COUNT(*), MIN(value), MAX(value) FROM example.make_series(10);
----
45	10	0	9

query I
SELECT SUM(value) FROM example.make_series(0, 100, 10);
----
450

# ============================================================================
# Edge cases
# ============================================================================

# count=0 → empty result
query I
SELECT COUNT(*) FROM example.make_series(0);
----
0

# start=stop → empty result
query I
SELECT COUNT(*) FROM example.make_series(5, 5);
----
0

# start>stop → empty result
query I
SELECT COUNT(*) FROM example.make_series(10, 5);
----
0

# step > range → single element
query I
SELECT * FROM example.make_series(0, 5, 100);
----
0

# ============================================================================
# Large series (>1024 rows, spanning multiple batches)
# ============================================================================

query II
SELECT COUNT(*), SUM(value) FROM example.make_series(2000);
----
2000	1999000

# ============================================================================
# make_series — type dispatch: int(5) vs string('10,20,30')
# Same 1-arg count, different arg type
# ============================================================================

# int arg → count overload
query I
SELECT * FROM example.make_series(3) ORDER BY value;
----
0
1
2

# string arg → CSV overload
query I
SELECT * FROM example.make_series('10,20,30') ORDER BY value;
----
10
20
30

query I
SELECT * FROM example.make_series('100') ORDER BY value;
----
100

query I
SELECT COUNT(*) FROM example.make_series('1,2,3,4,5');
----
5

# ============================================================================
# make_pairs — type dispatch: int(start,stop) vs str(prefix,suffix)
# Same 2-arg count, different arg types
# ============================================================================

# int args → integer pairs (i, i*2)
query II
SELECT * FROM example.make_pairs(1, 4) ORDER BY a;
----
1	2
2	4
3	6

# string args → string pairs (prefix+i, suffix+i)
query TT
SELECT * FROM example.make_pairs('row_', '_end') ORDER BY a;
----
row_0	_end0
row_1	_end1
row_2	_end2
row_3	_end3
row_4	_end4

# make_pairs int — edge case: empty range
query I
SELECT COUNT(*) FROM example.make_pairs(5, 5);
----
0

# make_pairs int — aggregation
query II
SELECT SUM(a), SUM(b) FROM example.make_pairs(0, 5);
----
10	20

# ============================================================================
# make_pairs — mixed-type dispatch: int + str (mirrors scalar pair_type int+str)
# ============================================================================

# int+str args → mixed pairs (a: int, b: labeled string)
query IT
SELECT * FROM example.make_pairs(10, 'item_') ORDER BY a;
----
10	item_0
11	item_1
12	item_2
13	item_3
14	item_4

# Verify all three overloads still work (regression)
query II
SELECT * FROM example.make_pairs(1, 3) ORDER BY a;
----
1	2
2	4

query TT
SELECT * FROM example.make_pairs('x_', '_y') ORDER BY a;
----
x_0	_y0
x_1	_y1
x_2	_y2
x_3	_y3
x_4	_y4

# aggregation
query I
SELECT COUNT(*) FROM example.make_pairs(0, 'test_');
----
5

# ============================================================================
# make_series — 3-way type dispatch at 1-arg count: int, string, float
# ============================================================================

# float arg → step overload (10 values)
query R
SELECT * FROM example.make_series(0.5::DOUBLE) ORDER BY value;
----
0.0
0.5
1.0
1.5
2.0
2.5
3.0
3.5
4.0
4.5

query I
SELECT COUNT(*) FROM example.make_series(2.5::DOUBLE);
----
10

# Verify all three 1-arg overloads coexist
query I
SELECT * FROM example.make_series(3) ORDER BY value;
----
0
1
2

query I
SELECT * FROM example.make_series('10,20,30') ORDER BY value;
----
10
20
30

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
