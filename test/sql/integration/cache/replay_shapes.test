# name: test/sql/integration/cache/replay_shapes.test
# description: VGI result cache — query shapes over a REPLAYED cached result: (#25) projection that reorders + duplicates columns on a HIT returns the right values; (#27) GROUP BY … HAVING over a replayed multi-batch result groups correctly across replay batch boundaries; (#28) LIMIT … OFFSET past a substream boundary on the single-thread serve returns the correct window.
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

statement ok
CALL enable_logging(level := 'debug');

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SELECT * FROM vgi_result_cache_flush();

# Warm the entries.
statement ok
SELECT COUNT(*) FROM ex.data.cache_multicol;

statement ok
SELECT COUNT(*) FROM ex.data.cache_big;

statement ok
CALL truncate_duckdb_logs();

# ---- #25 projection REORDER + DUPLICATE columns on a HIT --------------------
# cache_multicol: a=i, b=10i, c=100i. Select c,a,a (reordered + duplicated).
query III
SELECT c, a, a FROM ex.data.cache_multicol WHERE a = 3;
----
300	3	3

# Full reordered+dup projection sums correctly (a=0..3: SUM(a)=6, SUM(c)=600).
query III
SELECT SUM(c), SUM(a), SUM(a) FROM (SELECT c, a, a AS a2 FROM ex.data.cache_multicol) t(c, a, a2);
----
600	6	6

# That scan was a HIT (served from cache, not recomputed).
query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.hit%';
----
true

# ---- #27 GROUP BY … HAVING over a replayed multi-batch result --------------
# cache_big = 0..4999 (5000 rows, multi-batch). n%7 → 7 groups, all > 700.
query II
SELECT COUNT(*), SUM(c) FROM (
    SELECT n % 7 AS g, COUNT(*) c FROM ex.data.cache_big GROUP BY g HAVING COUNT(*) > 700);
----
7	5000

# A HAVING that filters out the smaller groups (5000 = 2×715 + 5×714).
query I
SELECT COUNT(*) FROM (
    SELECT n % 7 AS g, COUNT(*) c FROM ex.data.cache_big GROUP BY g HAVING COUNT(*) > 714);
----
2

# ---- #28 LIMIT … OFFSET past a batch boundary on the single-thread serve ----
# cache_big replays 0..4999 in order; OFFSET 2500 crosses several 1000-row batches.
query I
SELECT LIST(n) FROM (SELECT n FROM ex.data.cache_big ORDER BY n LIMIT 3 OFFSET 2500);
----
[2500, 2501, 2502]

# OFFSET past the end yields no rows (bounds handled on replay).
query I
SELECT COUNT(*) FROM (SELECT n FROM ex.data.cache_big ORDER BY n LIMIT 3 OFFSET 5000);
----
0

statement ok
DETACH ex;

statement ok
SELECT * FROM vgi_result_cache_flush();
