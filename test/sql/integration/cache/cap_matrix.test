# name: test/sql/integration/cache/cap_matrix.test
# description: VGI result cache — the interacting caps' precedence, documented by outcome. The SAME oversized result under toggled config: (a) disk OFF + tiny max_entry_bytes → abort reason=entry_too_large (uncached, streams correct); (b) disk ON + generous disk_max → spills to disk; (c) disk ON + tiny disk_max → abort reason=disk_entry_too_large. Turning the disk tier on flips an entry_too_large abort into a spill.
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET threads = 8;

statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SET vgi_result_cache_max_bytes = 268435456;

# ---- (a) disk OFF → abort entry_too_large (currently untested elsewhere) ----
statement ok
RESET vgi_result_cache_dir;

statement ok
SET vgi_result_cache_disk_max_bytes = 0;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

# Query still returns the complete correct result (a cache cap never breaks it).
query II
SELECT COUNT(*), SUM(v) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000	19999900000

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.abort%' AND message LIKE '%reason=entry_too_large%';
----
true

query I
SELECT COUNT(*) FROM vgi_result_cache() WHERE function = 'cache_parallel';
----
0

# ---- (b) disk ON + generous → the SAME result now SPILLS (no abort) ----------
statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_capmatrix';

statement ok
SET vgi_result_cache_disk_max_bytes = 1073741824;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

query II
SELECT COUNT(*), SUM(v) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000	19999900000

query I
SELECT COUNT(*) FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.abort%';
----
0

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.store%' AND message LIKE '%tier=disk%';
----
true

# ---- (c) disk ON + tiny disk_max → abort disk_entry_too_large ---------------
statement ok
SET vgi_result_cache_disk_max_bytes = 262144;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

query I
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.abort%' AND message LIKE '%reason=disk_entry_too_large%';
----
true

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/vgi_capmatrix/*/objects/*.vrc');
----
0

statement ok
RESET vgi_result_cache_max_entry_bytes;

statement ok
SET vgi_result_cache_disk_max_bytes = 0;

statement ok
SELECT * FROM vgi_result_cache_flush();
