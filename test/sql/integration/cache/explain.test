# name: test/sql/integration/cache/explain.test
# description: VGI result cache — EXPLAIN ANALYZE indicates a cache HIT (and its tier) on the served scan, since a hit skips the worker entirely; plain EXPLAIN neither serves nor populates the cache.
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
CALL enable_logging(level := 'debug');

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SELECT * FROM vgi_result_cache_flush();

# Warm a memory entry.
statement ok
SELECT COUNT(*) FROM ex.data.cacheable_numbers;

# EXPLAIN ANALYZE on the HIT surfaces the cache tier in the analyzed plan.
query II
EXPLAIN ANALYZE SELECT n FROM ex.data.cacheable_numbers;
----
analyzed_plan	<REGEX>:.*Cache: hit \(memory\).*

# Plain EXPLAIN does NOT execute → no Cache indicator in the physical plan.
query II
EXPLAIN SELECT n FROM ex.data.cacheable_numbers;
----
physical_plan	<!REGEX>:.*Cache: hit.*

# Plain EXPLAIN emitted no serve/store/miss events (it didn't run the scan).
statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

statement ok
EXPLAIN SELECT n FROM ex.data.cacheable_numbers;

query I
SELECT COUNT(*) FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.%';
----
0

# ---- Disk-streaming tier is labelled distinctly --------------------------
statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_explain';

statement ok
SET vgi_result_cache_disk_max_bytes = 1073741824;

statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SELECT COUNT(*) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);

query II
EXPLAIN ANALYZE SELECT v FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
analyzed_plan	<REGEX>:.*disk_streaming.*

statement ok
SET vgi_result_cache_max_entry_bytes = 67108864;

statement ok
DETACH ex;

statement ok
SELECT * FROM vgi_result_cache_flush();
