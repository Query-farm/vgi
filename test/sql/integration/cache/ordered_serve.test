# name: test/sql/integration/cache/ordered_serve.test
# description: VGI result cache — ORDER-SENSITIVE capture + serve. cache_ordered is a FIXED_ORDER / supports_batch_index function whose correct output is strictly 0,1,…,N-1. A cached MISS captures every batch with its batch_index; the single-thread serve flattens + stable-sorts by batch_index, so a HIT replays in identical SOURCE ORDER (not merely the same row set).
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

statement ok
CALL enable_logging(level := 'debug');

# Parallel scheduling available; on subprocess a FIXED_ORDER source still collapses
# to one worker/substream (see the order_preservation_modes note in CLAUDE.md), so
# capture is serialized — the assertion here is on ORDER, which must hold regardless.
statement ok
SET threads = 8;

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

# First scan → MISS + capture. The correct output is the monotonic sequence, so
# n MUST equal its 0-based row position. This is the live (worker) ordering.
statement ok
CREATE TEMP TABLE live AS
SELECT n, row_number() OVER () - 1 AS rn FROM ex.data.cache_ordered;

query II
SELECT bool_and(n = rn), COUNT(*) FROM live;
----
true	200000

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.miss%';
----
true

# The captured entry is genuinely multi-batch (many batch_index-tagged batches),
# so the serve exercises the flatten + stable-sort-by-batch_index replay path.
query I
SELECT num_batches >= 2 FROM vgi_result_cache() WHERE function = 'cache_ordered';
----
true

statement ok
CALL truncate_duckdb_logs();

# Second scan → HIT, served single-threaded from the cache. The replay must be in
# batch_index order: n still equals its row position, byte-identical to live.
statement ok
CREATE TEMP TABLE served AS
SELECT n, row_number() OVER () - 1 AS rn FROM ex.data.cache_ordered;

query II
SELECT bool_and(n = rn), COUNT(*) FROM served;
----
true	200000

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.hit%';
----
true

# Cross-check: the served stream equals the live stream position-for-position
# (both the row set AND the order match).
query I
SELECT COUNT(*) FROM live JOIN served USING (rn) WHERE live.n <> served.n;
----
0

statement ok
DETACH ex;
