# name: test/sql/integration/cache/opt_out.test
# description: VGI result cache — per-catalog `cache false` and global master switch disable caching
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
CALL enable_logging(level := 'debug');

# --- Per-catalog opt-out: ATTACH ... (cache false) ---
statement ok
ATTACH 'example' AS exoff (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', cache false);

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

# Two scans on the cache-disabled catalog: never stored, never a hit.
query I
SELECT COUNT(*) FROM exoff.data.cacheable_numbers;
----
10

query I
SELECT COUNT(*) FROM exoff.data.cacheable_numbers;
----
10

# Ineligible for the per-catalog reason; no hit ever fired.
query I
SELECT COUNT(*) >= 1 FROM duckdb_logs()
  WHERE type = 'VGI' AND message LIKE '%result_cache.ineligible%'
    AND message LIKE '%reason=disabled_attach%';
----
true

query I
SELECT COUNT(*) FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.hit%';
----
0

query I
SELECT COUNT(*) FROM vgi_result_cache();
----
0

statement ok
DETACH exoff;

# --- Global master switch off ---
statement ok
ATTACH 'example' AS exg (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET vgi_result_cache = false;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

query I
SELECT COUNT(*) FROM exg.data.cacheable_numbers;
----
10

query I
SELECT COUNT(*) FROM exg.data.cacheable_numbers;
----
10

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs()
  WHERE type = 'VGI' AND message LIKE '%result_cache.ineligible%'
    AND message LIKE '%reason=disabled_global%';
----
true

query I
SELECT COUNT(*) FROM vgi_result_cache();
----
0

statement ok
SET vgi_result_cache = true;

statement ok
DETACH exg;
