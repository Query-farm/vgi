# name: test/sql/integration/cache/spill_types.test
# description: VGI result cache (spill-to-disk) — nested / wide / NULL columns round-trip BYTE-IDENTICAL through the disk blob + streaming serve. cache_types emits STRUCT / LIST<int64> / DECIMAL / TIMESTAMP / string with interleaved NULLs across many batches; forced to spill (tiny max_entry_bytes) it must reassemble validity bitmaps + variable/nested buffers exactly on serve — not merely a matching COUNT (every prior cacheable fixture is flat int64).
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET threads = 8;

statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_spill_types';

statement ok
SET vgi_result_cache_disk_max_bytes = 1073741824;

# Tiny cap → the ~MB nested result spills to the disk blob, then serves via streaming.
statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SET vgi_result_cache_max_bytes = 268435456;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

# Live (miss) → spills to disk (disk-only, no memory row).
statement ok
CREATE TEMP TABLE live AS SELECT * FROM ex.main.cache_types(10000);

query I
SELECT COUNT(*) FROM vgi_result_cache() WHERE function = 'cache_types';
----
0

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/vgi_spill_types/*/objects/*.vrc');
----
1

statement ok
CALL truncate_duckdb_logs();

# Served from the disk blob via streaming.
statement ok
CREATE TEMP TABLE served AS SELECT * FROM ex.main.cache_types(10000);

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.hit%' AND message LIKE '%tier=disk_streaming%';
----
true

# Same cardinality and same NULL distribution (validity bitmaps survived).
query III
SELECT (SELECT COUNT(*) FROM served),
       (SELECT COUNT(*) FROM live WHERE tags IS NULL) = (SELECT COUNT(*) FROM served WHERE tags IS NULL),
       (SELECT COUNT(*) FROM served WHERE label IS NULL);
----
10000	true	2000

# BYTE-IDENTICAL on every nested/wide column, row for row (IS DISTINCT FROM is
# NULL-safe deep equality for STRUCT / LIST / DECIMAL / TIMESTAMP / string).
query I
SELECT COUNT(*) FROM live l JOIN served s USING (id)
WHERE l.tags  IS DISTINCT FROM s.tags
   OR l.attrs IS DISTINCT FROM s.attrs
   OR l.amt   IS DISTINCT FROM s.amt
   OR l.ts    IS DISTINCT FROM s.ts
   OR l.label IS DISTINCT FROM s.label;
----
0

# And the id sets are identical (no lost/duplicated rows through the spill).
query I
SELECT (SELECT COUNT(*) FROM (SELECT id FROM live EXCEPT SELECT id FROM served))
     + (SELECT COUNT(*) FROM (SELECT id FROM served EXCEPT SELECT id FROM live));
----
0

statement ok
SET vgi_result_cache_max_entry_bytes = 67108864;

statement ok
SELECT * FROM vgi_result_cache_flush();
