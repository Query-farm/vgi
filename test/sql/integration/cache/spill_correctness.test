# name: test/sql/integration/cache/spill_correctness.test
# description: VGI result cache (spill-to-disk) — a SPILLED result serves BYTE-IDENTICAL to the live result, not merely a matching aggregate. Covers the RAM→disk spill boundary reassembly: full row-set equality (cache_parallel) and full row-ORDER equality via round-tripped batch_index (cache_ordered). Ordered path is subprocess-only (FIXED_ORDER work-queue HTTP limitation), so this file is subprocess-focused.
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET threads = 8;

statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_spill_ok';

statement ok
SET vgi_result_cache_disk_max_bytes = 1073741824;

# Tiny per-entry cap → every result below spills after the first few KB.
statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SET vgi_result_cache_max_bytes = 268435456;

statement ok
SELECT * FROM vgi_result_cache_flush();

# ===========================================================================
# 1. Set-preserving spill (cache_parallel, 8 producers): the union of all
#    spilled substreams must equal the live union exactly (no lost / duplicated
#    / reordered-into-wrong-value rows).
# ===========================================================================
statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CREATE TEMP TABLE live_par AS
SELECT v FROM ex.main.cache_parallel(200000);

statement ok
CREATE TEMP TABLE served_par AS
SELECT v FROM ex.main.cache_parallel(200000);

# Same cardinality, same sum, and the two multisets are identical (symmetric EXCEPT empty).
query III
SELECT (SELECT COUNT(*) FROM served_par),
       (SELECT SUM(v) FROM served_par),
       (SELECT COUNT(*) FROM (SELECT v FROM live_par EXCEPT SELECT v FROM served_par))
     + (SELECT COUNT(*) FROM (SELECT v FROM served_par EXCEPT SELECT v FROM live_par));
----
200000	19999900000	0

# No duplicates introduced by the spill (v is distinct 0..N-1).
query I
SELECT COUNT(*) = COUNT(DISTINCT v) FROM served_par;
----
true

statement ok
SET vgi_result_cache_max_entry_bytes = 67108864;

statement ok
SELECT * FROM vgi_result_cache_flush();
