# name: test/sql/integration/cache/spill.test
# description: VGI result cache (spill-to-disk) — a capture that exceeds max_entry_bytes with the disk tier on SPILLS to a streaming disk blob instead of aborting, keeping RAM flat at ~max_entry_bytes. Covers single-producer (cache_big) and parallel (cache_parallel, one substream per worker) spill at a small, fast scale; the >2 GB flat-RAM proof is parallel_2gb.test_slow.
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_spill';

statement ok
SET vgi_result_cache_disk_max_bytes = 1073741824;

# Tiny per-entry cap so even a small result crosses the spill threshold.
statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SET vgi_result_cache_max_bytes = 268435456;

statement ok
SET threads = 8;

statement ok
SELECT * FROM vgi_result_cache_flush();

# ---------------------------------------------------------------------------
# 1. Parallel spill: cache_parallel(200000) is ~1.6 MB across 8 producers — far
#    over the 4 KB cap, so each producer spills its substream to the shared disk
#    blob. The union must still be exact.
# ---------------------------------------------------------------------------
statement ok
CALL truncate_duckdb_logs();

query II
SELECT COUNT(*), SUM(v) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000	19999900000

# Spilled → cached to disk (NOT aborted as too-large), and disk-only (not in memory).
query I
SELECT COUNT(*) FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.abort%';
----
0

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/vgi_spill/*/objects/*.vrc');
----
1

query I
SELECT COUNT(*) FROM vgi_result_cache() WHERE function = 'cache_parallel';
----
0

# Serve: memory miss → disk streaming hit (entry size > max_entry_bytes). Byte-exact.
statement ok
CALL truncate_duckdb_logs();

query II
SELECT COUNT(*), SUM(v) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000	19999900000

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.hit%' AND message LIKE '%tier=disk_streaming%';
----
true

# ---------------------------------------------------------------------------
# 2. Single-producer spill: cache_big (catalog data Table, one worker) still
#    spills correctly and serves complete.
# ---------------------------------------------------------------------------
statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

query II
SELECT COUNT(*), SUM(n) FROM ex.data.cache_big;
----
5000	12497500

query I
SELECT COUNT(*) FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%result_cache.abort%';
----
0

query II
SELECT COUNT(*), SUM(n) FROM ex.data.cache_big;
----
5000	12497500

query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.hit%' AND message LIKE '%tier=disk_streaming%';
----
true

statement ok
DETACH ex;

statement ok
SET vgi_result_cache_max_entry_bytes = 67108864;

statement ok
SELECT * FROM vgi_result_cache_flush();
