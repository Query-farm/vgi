# name: test/sql/integration/cache/spill_disk_cap.test
# description: VGI result cache (spill-to-disk) — a spill that exceeds the per-entry disk budget mid-stream aborts cleanly (result_cache.abort reason=disk_entry_too_large), the query still completes CORRECTLY (uncached), and the partial temp blob is removed (no orphan .vrc/.ref).
# group: [vgi_integration_cache]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET threads = 8;

statement ok
SET vgi_result_cache_dir = '__TEST_DIR__/vgi_spill_cap';

# Small per-entry disk budget: the ~1.6 MB result spills, then blows the 256 KB
# budget partway → the writer refuses further batches and the capture aborts.
statement ok
SET vgi_result_cache_disk_max_bytes = 262144;

statement ok
SET vgi_result_cache_max_entry_bytes = 4096;

statement ok
SET vgi_result_cache_max_bytes = 268435456;

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
CALL truncate_duckdb_logs();

# The query STILL returns the complete, correct result (a cache-size limit never
# breaks the query — it just streams uncached).
query II
SELECT COUNT(*), SUM(v) FROM vgi_table_function('${VGI_TEST_WORKER}', 'cache_parallel', [200000]);
----
200000	19999900000

# The over-budget spill aborted with the disk reason (at least one producer hit it).
query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
    AND message LIKE '%result_cache.abort%' AND message LIKE '%reason=disk_entry_too_large%';
----
true

# Nothing was committed and the partial temp was cleaned — no object, no ref.
query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/vgi_spill_cap/*/objects/*');
----
0

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/vgi_spill_cap/*/refs/*.ref');
----
0

query I
SELECT COUNT(*) FROM vgi_result_cache() WHERE function = 'cache_parallel';
----
0

statement ok
SET vgi_result_cache_max_entry_bytes = 67108864;

statement ok
SET vgi_result_cache_disk_max_bytes = 0;
