# name: test/sql/integration/table/double_sequence/operations.test
# description: SQL operations tests for VGI double_sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Aggregations - Basic
# ----------------------------------------------------------------------------

# SUM: 0.0+1.0+2.0+...+99.0 = 4950.0
query R
SELECT SUM(n) FROM example.double_sequence(100, batch_size := 10);
----
4950.0

# SUM with different batch sizes (verify consistency)
query R
SELECT SUM(n) FROM example.double_sequence(100, batch_size := 1);
----
4950.0

query R
SELECT SUM(n) FROM example.double_sequence(100, batch_size := 100);
----
4950.0

query R
SELECT SUM(n) FROM example.double_sequence(100, batch_size := 1000);
----
4950.0

# AVG: average of 0.0..99.0 = 49.5
query R
SELECT AVG(n) FROM example.double_sequence(100, batch_size := 10);
----
49.5

# MIN/MAX
query RR
SELECT MIN(n), MAX(n) FROM example.double_sequence(100, batch_size := 10);
----
0.0	99.0

# COUNT
query I
SELECT COUNT(*) FROM example.double_sequence(100, batch_size := 10);
----
100

# Multiple aggregations in one query
query RIRIRI
SELECT SUM(n), COUNT(*), AVG(n), MIN(n), MAX(n), COUNT(DISTINCT n)
FROM example.double_sequence(1000, batch_size := 50);
----
499500.0	1000	499.5	0.0	999.0	1000

# ----------------------------------------------------------------------------
# Aggregations on empty sequences
# ----------------------------------------------------------------------------

query R
SELECT SUM(n) FROM example.double_sequence(0, batch_size := 10);
----
NULL

query I
SELECT COUNT(*) FROM example.double_sequence(0, batch_size := 10);
----
0

query R
SELECT AVG(n) FROM example.double_sequence(0, batch_size := 10);
----
NULL

query RR
SELECT MIN(n), MAX(n) FROM example.double_sequence(0, batch_size := 10);
----
NULL	NULL

# ----------------------------------------------------------------------------
# Aggregations on single row
# ----------------------------------------------------------------------------

query R
SELECT SUM(n) FROM example.double_sequence(1, batch_size := 10);
----
0.0

query R
SELECT AVG(n) FROM example.double_sequence(1, batch_size := 10);
----
0.0

query RR
SELECT MIN(n), MAX(n) FROM example.double_sequence(1, batch_size := 10);
----
0.0	0.0

# ----------------------------------------------------------------------------
# Aggregations with fractional increment
# ----------------------------------------------------------------------------

# SUM with increment=0.5: 0.0+0.5+1.0+1.5+2.0 = 5.0
query R
SELECT SUM(n) FROM example.double_sequence(5, batch_size := 10, increment=0.5);
----
5.0

# AVG with increment=0.5: avg(0.0, 0.5, 1.0, 1.5, 2.0) = 1.0
query R
SELECT AVG(n) FROM example.double_sequence(5, batch_size := 10, increment=0.5);
----
1.0

# MIN/MAX with increment=0.5
query RR
SELECT MIN(n), MAX(n) FROM example.double_sequence(5, batch_size := 10, increment=0.5);
----
0.0	2.0

# SUM with increment=0.1: 0.0+0.1+0.2+...+0.9 = 4.5
query R
SELECT SUM(n) FROM example.double_sequence(10, batch_size := 5, increment=0.1);
----
4.5

# SUM with increment=0.25: 0.0+0.25+0.5+0.75 = 1.5
query R
SELECT SUM(n) FROM example.double_sequence(4, batch_size := 10, increment=0.25);
----
1.5

# ----------------------------------------------------------------------------
# Aggregations with GROUP BY
# ----------------------------------------------------------------------------

# Group by floor value
query IR
SELECT CAST(FLOOR(n) AS INTEGER) as bucket, COUNT(*) as cnt
FROM example.double_sequence(20, batch_size := 5, increment=0.5)
GROUP BY bucket
ORDER BY bucket;
----
0	2
1	2
2	2
3	2
4	2
5	2
6	2
7	2
8	2
9	2

# Sum within groups
# Values: 0.0, 0.5, 1.0, 1.5, 2.0, 2.5, 3.0, 3.5, 4.0, 4.5
# bucket 0: 0.0+0.5=0.5, bucket 1: 1.0+1.5=2.5, bucket 2: 2.0+2.5=4.5
# bucket 3: 3.0+3.5=6.5, bucket 4: 4.0+4.5=8.5
query IR
SELECT CAST(FLOOR(n) AS INTEGER) as bucket, SUM(n) as total
FROM example.double_sequence(10, batch_size := 3, increment=0.5)
GROUP BY bucket
ORDER BY bucket;
----
0	0.5
1	2.5
2	4.5
3	6.5
4	8.5

# ----------------------------------------------------------------------------
# Filtering on doubles
# ----------------------------------------------------------------------------

# Filter by value
query I
SELECT COUNT(*) FROM example.double_sequence(100, batch_size := 7) WHERE n >= 50.0;
----
50

# Filter by range
query I
SELECT COUNT(*) FROM example.double_sequence(1000, batch_size := 50) WHERE n BETWEEN 100.0 AND 199.0;
----
100

# Filter with fractional increment
query I
SELECT COUNT(*) FROM example.double_sequence(20, batch_size := 5, increment=0.5) WHERE n >= 5.0;
----
10

# Aggregation on filtered data
query R
SELECT SUM(n) FROM example.double_sequence(100, batch_size := 10) WHERE n < 10.0;
----
45.0

query R
SELECT AVG(n) FROM example.double_sequence(100, batch_size := 10) WHERE n >= 90.0;
----
94.5

# ----------------------------------------------------------------------------
# Sorting
# ----------------------------------------------------------------------------

# ORDER BY DESC
query R
SELECT * FROM example.double_sequence(5, batch_size := 2) ORDER BY n DESC;
----
4.0
3.0
2.0
1.0
0.0

# ORDER BY with LIMIT
query R
SELECT * FROM example.double_sequence(100, batch_size := 10) ORDER BY n DESC LIMIT 5;
----
99.0
98.0
97.0
96.0
95.0

# ORDER BY with fractional increment
query R
SELECT * FROM example.double_sequence(5, batch_size := 2, increment=0.5) ORDER BY n DESC;
----
2.0
1.5
1.0
0.5
0.0

# ----------------------------------------------------------------------------
# DISTINCT
# ----------------------------------------------------------------------------

# All values should be unique
query I
SELECT COUNT(DISTINCT n) FROM example.double_sequence(1000, batch_size := 50);
----
1000

# DISTINCT on small set with fractional increment
query R
SELECT DISTINCT n FROM example.double_sequence(5, batch_size := 2, increment=0.5) ORDER BY n;
----
0.0
0.5
1.0
1.5
2.0

# ----------------------------------------------------------------------------
# Window functions
# ----------------------------------------------------------------------------

# Running sum
query RR
SELECT n, SUM(n) OVER (ORDER BY n) as running_sum
FROM example.double_sequence(5, batch_size := 2)
ORDER BY n;
----
0.0	0.0
1.0	1.0
2.0	3.0
3.0	6.0
4.0	10.0

# Row number
query RI
SELECT n, ROW_NUMBER() OVER (ORDER BY n) as rn
FROM example.double_sequence(5, batch_size := 2)
ORDER BY n;
----
0.0	1
1.0	2
2.0	3
3.0	4
4.0	5

# Running sum with fractional increment
query RR
SELECT n, SUM(n) OVER (ORDER BY n) as running_sum
FROM example.double_sequence(5, batch_size := 2, increment=0.5)
ORDER BY n;
----
0.0	0.0
0.5	0.5
1.0	1.5
1.5	3.0
2.0	5.0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
