# name: test/sql/integration/table/double_sequence/parameters.test
# description: Parameter variation tests for VGI double_sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Increment parameter variations (float increments!)
# Tests value generation with different increments
# ----------------------------------------------------------------------------

# Default increment = 1.0
query R
SELECT * FROM example.double_sequence(5, 1000, increment=1.0);
----
0.0
1.0
2.0
3.0
4.0

# increment = 0.5 (fractional step)
query R
SELECT * FROM example.double_sequence(5, 1000, increment=0.5);
----
0.0
0.5
1.0
1.5
2.0

# increment = 0.1 (smaller fractional step)
query R
SELECT * FROM example.double_sequence(5, 1000, increment=0.1);
----
0.0
0.1
0.2
0.3
0.4

# increment = 2.5 (mixed increment)
query R
SELECT * FROM example.double_sequence(4, 1000, increment=2.5);
----
0.0
2.5
5.0
7.5

# increment = 10.0 (larger step)
query R
SELECT * FROM example.double_sequence(5, 1000, increment=10.0);
----
0.0
10.0
20.0
30.0
40.0

# Small batch with fractional increment
query R
SELECT * FROM example.double_sequence(5, 2, increment=0.25);
----
0.0
0.25
0.5
0.75
1.0

# Batch size = 1 with fractional increment
query R
SELECT * FROM example.double_sequence(4, 1, increment=0.5);
----
0.0
0.5
1.0
1.5

# Large increment
query R
SELECT SUM(n) FROM example.double_sequence(100, 10, increment=7.0);
----
34650.0

# Fractional increment sum: 0.0 + 0.1 + 0.2 + ... + 0.9 = 4.5
query R
SELECT SUM(n) FROM example.double_sequence(10, 5, increment=0.1);
----
4.5

# ----------------------------------------------------------------------------
# Combined edge cases
# Tests interactions between parameters
# ----------------------------------------------------------------------------

# Single row with large increment (should just return 0.0)
query R
SELECT * FROM example.double_sequence(1, 1, increment=1000000.0);
----
0.0

# Two rows with increment, batch_size=1
query R
SELECT * FROM example.double_sequence(2, 1, increment=50.5);
----
0.0
50.5

# Zero rows with increment (still empty)
query I
SELECT COUNT(*) FROM example.double_sequence(0, 1, increment=100.0);
----
0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
