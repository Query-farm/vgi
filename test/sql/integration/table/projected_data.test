# name: test/sql/integration/table/projected_data.test
# description: Integration tests for VGI projected_data table function
# group: [vgi_integration_table]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# projected_data function (projection pushdown)
# Generates data with 4 columns: id, name, value, extra
# - id: sequential integer (0, 1, 2, ...)
# - name: string "item_N"
# - value: float (id * 1.5)
# - extra: integer (id * id)
# ============================================================================

# ============================================================================
# No projection (SELECT *) - all columns requested
# ============================================================================

# All columns with small dataset
query IRTI
SELECT * FROM example.projected_data(3);
----
0	item_0	0.0	0
1	item_1	1.5	1
2	item_2	3.0	4

# All columns with medium dataset - verify correctness
query IIII
SELECT COUNT(*), COUNT(DISTINCT id), MIN(id), MAX(id) FROM example.projected_data(1000);
----
1000	1000	0	999

# Verify all columns present and correct with SELECT *
query IRTI
SELECT * FROM example.projected_data(5);
----
0	item_0	0.0	0
1	item_1	1.5	1
2	item_2	3.0	4
3	item_3	4.5	9
4	item_4	6.0	16

# SELECT * with aggregations (no projection pushdown)
query IRIRI
SELECT COUNT(*), SUM(value), COUNT(DISTINCT name), MIN(extra), MAX(extra)
FROM example.projected_data(100);
----
100	7425.0	100	0	9801

# SELECT * with ORDER BY
query IRTI
SELECT * FROM example.projected_data(5) ORDER BY id DESC;
----
4	item_4	6.0	16
3	item_3	4.5	9
2	item_2	3.0	4
1	item_1	1.5	1
0	item_0	0.0	0

# SELECT * with LIMIT
query IRTI
SELECT * FROM example.projected_data(1000) LIMIT 3;
----
0	item_0	0.0	0
1	item_1	1.5	1
2	item_2	3.0	4

# SELECT * with large dataset - verify no projection still works
query IIII
SELECT COUNT(*), COUNT(DISTINCT id), MIN(id), MAX(id) FROM example.projected_data(5000);
----
5000	5000	0	4999

# ============================================================================
# Projection pushdown - only select specific columns
# ============================================================================

query II
SELECT id, extra FROM example.projected_data(3);
----
0	0
1	1
2	4

query IR
SELECT id, value FROM example.projected_data(3);
----
0	0.0
1	1.5
2	3.0

query IT
SELECT id, name FROM example.projected_data(3);
----
0	item_0
1	item_1
2	item_2

# ============================================================================
# Out-of-order column selection (columns not in schema order)
# Schema order is: id (0), name (1), value (2), extra (3)
# ============================================================================

# Reverse pairs
query II
SELECT extra, id FROM example.projected_data(3);
----
0	0
1	1
4	2

query TI
SELECT name, extra FROM example.projected_data(3);
----
item_0	0
item_1	1
item_2	4

query RI
SELECT value, id FROM example.projected_data(3);
----
0.0	0
1.5	1
3.0	2

# Non-adjacent columns in reverse order
query IT
SELECT extra, name FROM example.projected_data(3);
----
0	item_0
1	item_1
4	item_2

# Three columns out of order
query RTI
SELECT value, name, id FROM example.projected_data(3);
----
0.0	item_0	0
1.5	item_1	1
3.0	item_2	2

query ITR
SELECT extra, name, value FROM example.projected_data(3);
----
0	item_0	0.0
1	item_1	1.5
4	item_2	3.0

# Complete reverse order (all 4 columns)
query IRTI
SELECT extra, value, name, id FROM example.projected_data(3);
----
0	0.0	item_0	0
1	1.5	item_1	1
4	3.0	item_2	2

# Single column selections
query T
SELECT name FROM example.projected_data(3);
----
item_0
item_1
item_2

query R
SELECT value FROM example.projected_data(3);
----
0.0
1.5
3.0

query I
SELECT extra FROM example.projected_data(3);
----
0
1
4

# ============================================================================
# Window functions with projection (large dataset)
# ============================================================================

# ROW_NUMBER with subset of columns - verify count and boundaries
query III
SELECT COUNT(*), MIN(rn), MAX(rn) FROM (
    SELECT id, ROW_NUMBER() OVER (ORDER BY id) as rn, name FROM example.projected_data(4000)
);
----
4000	1	4000

# LAG with out-of-order columns - count non-null lag values
query II
SELECT COUNT(*), COUNT(prev_name) FROM (
    SELECT id, name, LAG(name) OVER (ORDER BY id) as prev_name FROM example.projected_data(4000)
);
----
4000	3999

# Running sum with non-adjacent columns - verify final sum
query IR
SELECT MAX(id), MAX(running_sum) FROM (
    SELECT id, extra, SUM(value) OVER (ORDER BY id) as running_sum FROM example.projected_data(4000)
);
----
3999	11994000.0

# RANK with reverse column order - verify all ranks present
query III
SELECT COUNT(*), MIN(rnk), MAX(rnk) FROM (
    SELECT value, RANK() OVER (ORDER BY extra DESC) as rnk, id FROM example.projected_data(4000)
);
----
4000	1	4000

# Multiple window functions - verify consistency
query IIII
SELECT COUNT(*), MIN(rn), MAX(rn), MAX(total) FROM (
    SELECT id, name, ROW_NUMBER() OVER (ORDER BY id) as rn, COUNT(*) OVER () as total
    FROM example.projected_data(4000)
);
----
4000	1	4000	4000

# LEAD with reverse column selection
query II
SELECT COUNT(*), COUNT(next_extra) FROM (
    SELECT name, id, LEAD(extra) OVER (ORDER BY id) as next_extra FROM example.projected_data(4000)
);
----
4000	3999

# ============================================================================
# Large dataset tests - comparing projection vs no-projection
# ============================================================================

# Verify row count with larger dataset (no projection)
query I
SELECT COUNT(*) FROM example.projected_data(100);
----
100

# Large dataset with SELECT * (no projection)
query IIII
SELECT COUNT(*), COUNT(DISTINCT id), MIN(id), MAX(id) FROM example.projected_data(10000);
----
10000	10000	0	9999

# Large dataset with projection (single column)
query IIII
SELECT COUNT(*), COUNT(DISTINCT id), MIN(id), MAX(id) FROM (
    SELECT id FROM example.projected_data(10000)
);
----
10000	10000	0	9999

# Verify projection and no-projection produce same id values
query I
SELECT COUNT(*) FROM (
    SELECT id FROM example.projected_data(5000)
    EXCEPT
    SELECT id FROM example.projected_data(5000)
);
----
0

# Verify sum of extra is same with projection vs explicit column list
query I
SELECT SUM(extra) FROM example.projected_data(1000);
----
332833500

query I
SELECT SUM(extra) FROM (SELECT extra FROM example.projected_data(1000));
----
332833500

# Verify all 4 columns explicitly selected matches SELECT *
query IIII
SELECT COUNT(*), MIN(id), MAX(id), COUNT(DISTINCT name)
FROM (SELECT id, name, value, extra FROM example.projected_data(1000));
----
1000	0	999	1000

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
