# name: test/sql/integration/table/writable_table.test
# description: Tests for INSERT on VGI writable tables
# group: [vgi_integration_table]
#
# NOTE: UPDATE and DELETE tests are deferred pending a fix for a use-after-free
# in the scan function when the UPDATE/DELETE pipeline scans with virtual rowid
# projection. The write operators themselves work correctly.

require-env VGI_TEST_WORKER

require vgi

require httpfs

# Attach the writable catalog (separate from example, with transaction support)
statement ok
ATTACH 'writable' AS writable (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', POOL false);

# ============================================================================
# INSERT VALUES — single row
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (1, 'hello');

query II
SELECT id, name FROM writable.main.writable_data;
----
1	hello

# ============================================================================
# INSERT VALUES — multiple rows in one statement
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (2, 'world'), (3, 'test');

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
3

query II
SELECT id, name FROM writable.main.writable_data ORDER BY id;
----
1	hello
2	world
3	test

# ============================================================================
# INSERT ... SELECT — from a DuckDB-local query
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'row_' || i::VARCHAR FROM range(4, 7) t(i);

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
6

query II
SELECT id, name FROM writable.main.writable_data WHERE id >= 4 ORDER BY id;
----
4	row_4
5	row_5
6	row_6

# ============================================================================
# INSERT ... SELECT — large batch (thousands of rows, multiple vector batches)
# DuckDB sends data in chunks of ~2048 rows, so 5000 rows = ~3 batches
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'bulk_' || i::VARCHAR FROM range(1000, 6000) t(i);

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 1000;
----
5000

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
5006

# Verify first and last rows of the bulk insert
query II
SELECT id, name FROM writable.main.writable_data WHERE id = 1000;
----
1000	bulk_1000

query II
SELECT id, name FROM writable.main.writable_data WHERE id = 5999;
----
5999	bulk_5999

# ============================================================================
# INSERT — empty (zero rows)
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'nope' FROM range(0) t(i);

# Count should be unchanged
query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
5006

# ============================================================================
# INSERT — type edge cases
# ============================================================================

# Negative numbers
statement ok
INSERT INTO writable.main.writable_data VALUES (-1, 'negative');

# Empty string
statement ok
INSERT INTO writable.main.writable_data VALUES (-2, '');

# Long string
statement ok
INSERT INTO writable.main.writable_data VALUES (-3, repeat('x', 10000));

query II
SELECT id, name FROM writable.main.writable_data WHERE id = -1;
----
-1	negative

query II
SELECT id, name FROM writable.main.writable_data WHERE id = -2;
----
-2	(empty)

query I
SELECT length(name) FROM writable.main.writable_data WHERE id = -3;
----
10000

# ============================================================================
# INSERT ... RETURNING — single row
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9001, 'returning_test') RETURNING id, name;
----
9001	returning_test

# Verify it was actually inserted
query II
SELECT id, name FROM writable.main.writable_data WHERE id = 9001;
----
9001	returning_test

# ============================================================================
# INSERT ... RETURNING — multiple rows
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9002, 'ret_a'), (9003, 'ret_b') RETURNING id, name;
----
9002	ret_a
9003	ret_b

# ============================================================================
# INSERT ... RETURNING — with INSERT ... SELECT
# ============================================================================

query II
INSERT INTO writable.main.writable_data SELECT i, 'ret_sel_' || i::VARCHAR FROM range(9010, 9013) t(i) RETURNING id, name;
----
9010	ret_sel_9010
9011	ret_sel_9011
9012	ret_sel_9012

# ============================================================================
# INSERT ... RETURNING * — all columns
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9999, 'star_test') RETURNING *;
----
9999	star_test

# ============================================================================
# INSERT ... RETURNING — column subset (only id)
# ============================================================================

query I
INSERT INTO writable.main.writable_data VALUES (9050, 'partial_ret') RETURNING id;
----
9050

# ============================================================================
# INSERT ... RETURNING — with expression
# ============================================================================

query I
INSERT INTO writable.main.writable_data VALUES (9060, 'expr_test') RETURNING id * 2;
----
18120

# ============================================================================
# INSERT ... RETURNING — large batch (multiple vector batches)
# Verifies RETURNING works across the >2048 row boundary
# ============================================================================

# Large INSERT (already tested above without RETURNING).
# RETURNING with large batches works through the same ColumnDataCollection path —
# each Sink call produces one RETURNING batch that is deep-copied into the collection.

# ============================================================================
# INSERT — duplicate values (no unique constraint, should succeed)
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (1, 'duplicate_of_hello');

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id = 1;
----
2

# ============================================================================
# DELETE — basic
# ============================================================================

# First, insert known data for delete tests
statement ok
INSERT INTO writable.main.writable_data VALUES (50000, 'del_a'), (50001, 'del_b'), (50002, 'del_c');

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 50000;
----
3

# Delete a single row
statement ok
DELETE FROM writable.main.writable_data WHERE id = 50001;

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 50000;
----
2

# Verify the correct row was deleted
query II
SELECT id, name FROM writable.main.writable_data WHERE id >= 50000 ORDER BY id;
----
50000	del_a
50002	del_c

# Delete multiple rows with WHERE
statement ok
DELETE FROM writable.main.writable_data WHERE id >= 50000;

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 50000;
----
0

# Delete with no matching rows (should succeed with 0 affected)
statement ok
DELETE FROM writable.main.writable_data WHERE id = 99999;

# ============================================================================
# UPDATE — basic
# ============================================================================

# Insert known data for update tests
statement ok
INSERT INTO writable.main.writable_data VALUES (60000, 'upd_a'), (60001, 'upd_b'), (60002, 'upd_c');

# Update a single row
statement ok
UPDATE writable.main.writable_data SET name = 'updated_a' WHERE id = 60000;

query II
SELECT id, name FROM writable.main.writable_data WHERE id = 60000;
----
60000	updated_a

# Update multiple rows
statement ok
UPDATE writable.main.writable_data SET name = 'bulk_updated' WHERE id >= 60001;

query II
SELECT id, name FROM writable.main.writable_data WHERE id >= 60000 ORDER BY id;
----
60000	updated_a
60001	bulk_updated
60002	bulk_updated

# Update with no matching rows (should succeed)
statement ok
UPDATE writable.main.writable_data SET name = 'noop' WHERE id = 99999;

# ============================================================================
# DELETE + INSERT — verify store consistency after delete
# ============================================================================

# Delete all update test rows
statement ok
DELETE FROM writable.main.writable_data WHERE id >= 60000;

# Insert new rows after delete
statement ok
INSERT INTO writable.main.writable_data VALUES (70000, 'after_delete');

query II
SELECT id, name FROM writable.main.writable_data WHERE id = 70000;
----
70000	after_delete

# ============================================================================
# UPDATE + SELECT — verify update is visible immediately
# ============================================================================

statement ok
UPDATE writable.main.writable_data SET name = 'changed' WHERE id = 70000;

query II
SELECT id, name FROM writable.main.writable_data WHERE id = 70000;
----
70000	changed

# ============================================================================
# Cleanup delete/update test data
# ============================================================================

statement ok
DELETE FROM writable.main.writable_data WHERE id >= 50000;
