# name: test/sql/integration/table/partitioned_sequence.test
# description: Tests for VGI partitioned_sequence table function
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

require httpfs

require json

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# partitioned_sequence function (multi-worker capable)
# Generates a sequence that can be executed in parallel using a work queue pattern
# Default DuckDB vector size is 2048, default batch size is 10000
#
# Key invariants to test:
# - COUNT(*) equals requested count
# - COUNT(DISTINCT n) equals COUNT(*) (no duplicates)
# - MIN(n) = 0, MAX(n) = (count-1) * increment
# - All values are contiguous (no gaps)
# ============================================================================

# ============================================================================
# Edge cases
# ============================================================================

# Empty sequence
query III
SELECT COUNT(*) as total, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(0);
----
0	NULL	NULL

# Single value
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(1);
----
1	1	0	0

# Two values
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2);
----
2	2	0	1

# ============================================================================
# Increment parameter tests
# ============================================================================

# Small sequence with increment
query I
SELECT * FROM example.partitioned_sequence(5, increment=10);
----
0
10
20
30
40

# Verify increment produces correct range
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(100, increment=7);
----
100	100	0	693

# Verify increment sum formula: sum = increment * count * (count-1) / 2
query I
SELECT SUM(n) = (7::BIGINT * 100 * 99 / 2) as sum_correct
FROM example.partitioned_sequence(100, increment=7);
----
true

# Large sequence with increment
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000, increment=3);
----
10000	10000	0	29997

# Verify large increment sequence sum
query I
SELECT SUM(n) = (3::BIGINT * 10000 * 9999 / 2) as sum_correct
FROM example.partitioned_sequence(10000, increment=3);
----
true

# Scale test with increment
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000, increment=2);
----
20000	20000	0	39998

# ============================================================================
# Boundary cases around vector size (2048)
# ============================================================================

# Just under vector size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2047);
----
2047	2047	0	2046

# Exactly vector size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2048);
----
2048	2048	0	2047

# Just over vector size (requires 2 vectors)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2049);
----
2049	2049	0	2048

# Two full vectors
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(4096);
----
4096	4096	0	4095

# Three vectors minus one
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(6143);
----
6143	6143	0	6142

# ============================================================================
# Boundary cases around default batch size (10000)
# ============================================================================

# Just under batch size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(9999);
----
9999	9999	0	9998

# Exactly batch size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Just over batch size (requires 2 batches)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10001);
----
10001	10001	0	10000

# Two full batches
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# Multiple batches (tests work queue distribution)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(15000);
----
15000	15000	0	14999

# ============================================================================
# Scale tests - verify correctness at larger sizes
# ============================================================================

# 20K values - complete sequence verification with sum check
query I
SELECT SUM(n) = (20000::BIGINT * 19999 / 2) as sum_correct
FROM example.partitioned_sequence(20000);
----
true

# ============================================================================
# LIMIT tests
# ============================================================================

# Small limit on large sequence - early termination
query I
SELECT COUNT(*) FROM (SELECT * FROM example.partitioned_sequence(20000) LIMIT 10);
----
10

# Limit equals count
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM (SELECT * FROM example.partitioned_sequence(100) LIMIT 100);
----
100	100	0	99

# Limit larger than count - should return all rows
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM (SELECT * FROM example.partitioned_sequence(50) LIMIT 1000);
----
50	50	0	49

# Limit with ORDER BY - get smallest values
query I
SELECT * FROM example.partitioned_sequence(10000) ORDER BY n LIMIT 5;
----
0
1
2
3
4

# Limit with ORDER BY DESC - get largest values
query I
SELECT * FROM example.partitioned_sequence(10000) ORDER BY n DESC LIMIT 5;
----
9999
9998
9997
9996
9995

# Limit across batch boundaries (batch size = 10000)
query I
SELECT COUNT(*) FROM (SELECT * FROM example.partitioned_sequence(20000) LIMIT 15000);
----
15000

# Limit with increment
query I
SELECT * FROM example.partitioned_sequence(1000, increment=5) ORDER BY n LIMIT 5;
----
0
5
10
15
20

# LIMIT 1 - minimal result
query I
SELECT COUNT(*) FROM (SELECT * FROM example.partitioned_sequence(20000) LIMIT 1);
----
1

# LIMIT 0 - empty result
query I
SELECT COUNT(*) FROM (SELECT * FROM example.partitioned_sequence(20000) LIMIT 0);
----
0

# LIMIT with OFFSET
query I
SELECT * FROM example.partitioned_sequence(100) ORDER BY n LIMIT 5 OFFSET 10;
----
10
11
12
13
14

# Large LIMIT with OFFSET near end
query I
SELECT * FROM example.partitioned_sequence(100) ORDER BY n LIMIT 10 OFFSET 95;
----
95
96
97
98
99

# LIMIT with multi-threaded execution
statement ok
SET threads=4;

query I
SELECT COUNT(*) FROM (SELECT * FROM example.partitioned_sequence(100000) LIMIT 1000);
----
1000

# Verify LIMIT doesn't affect correctness of returned values
query I
SELECT SUM(n) = (1000::BIGINT * 999 / 2) as sum_correct
FROM (SELECT * FROM example.partitioned_sequence(100000) ORDER BY n LIMIT 1000);
----
true

statement ok
RESET threads;

# ============================================================================
# Threading tests
# ============================================================================

# Enable logging for worker verification
statement ok
CALL enable_logging(level := 'debug');

# --- Single-threaded execution (threads=1) ---
statement ok
SET threads=1;

# Correctness test
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Sum verification (no gaps)
query I
SELECT SUM(n) = (10000::BIGINT * 9999 / 2) as sum_correct
FROM example.partitioned_sequence(10000);
----
true

# Worker count verification - truncate logs, run query, check PID count
statement ok
CALL truncate_duckdb_logs();

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Verify only one worker was used (single conn= in batch_received logs).
# Uses conn= (transport-neutral, present for both subprocess and HTTP) rather
# than worker_pid= (subprocess-only — HTTP has no OS pid for the remote worker).
query I
SELECT COUNT(DISTINCT regexp_extract(message, 'conn=([0-9a-f]+)', 1)) = 1
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%batch_received%';
----
true

# --- Multi-threaded execution (threads=4) ---
statement ok
SET threads=4;

# Worker count verification - truncate logs, run query, check PID count
statement ok
CALL truncate_duckdb_logs();

# 100K with 4 threads - should use multiple workers
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(100000);
----
100000	100000	0	99999

# Verify multiple workers were used (at least 2 distinct conn= in
# batch_received logs). conn= is the transport-neutral per-connection id —
# under subprocess each conn maps to a distinct worker pid; under HTTP each
# conn is a distinct logical worker checkout against the remote server.
query I
SELECT COUNT(DISTINCT regexp_extract(message, 'conn=([0-9a-f]+)', 1)) >= 2
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%batch_received%';
----
true

# Sum verification (no gaps even with parallel execution)
query I
SELECT SUM(n) = (100000::BIGINT * 99999 / 2) as sum_correct
FROM example.partitioned_sequence(100000);
----
true

# --- Thread scaling verification ---

# 2 threads
statement ok
SET threads=2;

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# 8 threads
statement ok
SET threads=8;

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# Reset to default
statement ok
RESET threads;

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
