# name: test/sql/integration/table/partitioned_sequence.test
# description: Integration tests for VGI partitioned_sequence table function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# partitioned_sequence function (multi-worker capable)
# Generates a sequence that can be executed in parallel using a work queue pattern
# Default DuckDB vector size is 2048, default batch size is 10000
#
# Key invariants to test:
# - COUNT(*) equals requested count
# - COUNT(DISTINCT n) equals COUNT(*) (no duplicates)
# - MIN(n) = 0, MAX(n) = (count-1) * increment
# - All values are contiguous (no gaps)
# ============================================================================

# ----------------------------------------------------------------------------
# Edge cases
# ----------------------------------------------------------------------------

# Empty sequence
query III
SELECT COUNT(*) as total, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(0);
----
0	NULL	NULL

# Single value
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(1);
----
1	1	0	0

# Two values
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2);
----
2	2	0	1

# ----------------------------------------------------------------------------
# Boundary cases around vector size (2048)
# These test that chunking across DuckDB vectors works correctly
# ----------------------------------------------------------------------------

# Just under vector size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2047);
----
2047	2047	0	2046

# Exactly vector size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2048);
----
2048	2048	0	2047

# Just over vector size (requires 2 vectors)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(2049);
----
2049	2049	0	2048

# Two full vectors
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(4096);
----
4096	4096	0	4095

# Three vectors minus one
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(6143);
----
6143	6143	0	6142

# ----------------------------------------------------------------------------
# Boundary cases around default batch size (10000)
# These test that chunking across Arrow batches works correctly
# ----------------------------------------------------------------------------

# Just under batch size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(9999);
----
9999	9999	0	9998

# Exactly batch size
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Just over batch size (requires 2 batches)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10001);
----
10001	10001	0	10000

# Two full batches
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# Multiple batches (tests work queue distribution)
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(35000);
----
35000	35000	0	34999

# ----------------------------------------------------------------------------
# Scale tests - verify correctness at larger sizes
# Multi-worker execution may or may not occur depending on system configuration
# The key is that results are correct regardless of parallelism
# ----------------------------------------------------------------------------

# 100K values - complete sequence verification
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(100000);
----
100000	100000	0	99999

# Verify no gaps in sequence (sum should equal n*(n-1)/2)
query I
SELECT SUM(n) = (100000::BIGINT * 99999 / 2) as sum_correct
FROM example.partitioned_sequence(100000);
----
true

# 250K values
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(250000);
----
250000	250000	0	249999

# 500K values - stress test
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(500000);
----
500000	500000	0	499999

# Verify no gaps in 500K sequence
query I
SELECT SUM(n) = (500000::BIGINT * 499999 / 2) as sum_correct
FROM example.partitioned_sequence(500000);
----
true

# ----------------------------------------------------------------------------
# Increment parameter tests
# ----------------------------------------------------------------------------

# Small sequence with increment
query I
SELECT * FROM example.partitioned_sequence(5, increment=10);
----
0
10
20
30
40

# Verify increment produces correct range
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(100, increment=7);
----
100	100	0	693

# Verify increment sum formula: sum = increment * count * (count-1) / 2
query I
SELECT SUM(n) = (7::BIGINT * 100 * 99 / 2) as sum_correct
FROM example.partitioned_sequence(100, increment=7);
----
true

# Large sequence with increment
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000, increment=3);
----
10000	10000	0	29997

# Verify large increment sequence sum
query I
SELECT SUM(n) = (3::BIGINT * 10000 * 9999 / 2) as sum_correct
FROM example.partitioned_sequence(10000, increment=3);
----
true

# Scale test with increment
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(50000, increment=2);
----
50000	50000	0	99998

# ----------------------------------------------------------------------------
# Cleanup
# ----------------------------------------------------------------------------

statement ok
DETACH example;
