# name: test/sql/integration/table/filter_pushdown/sequence.test
# description: Filter pushdown tests for VGI sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Constant comparison filters
# ============================================================================

# Greater than filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n > 7;
----
8
9

# Greater than or equal filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n >= 8;
----
8
9

# Less than filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n < 3;
----
0
1
2

# Less than or equal filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n <= 2;
----
0
1
2

# Equality filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n = 5;
----
5

# Not equal filter
query I
SELECT * FROM example.sequence(5, 1000) WHERE n != 2;
----
0
1
3
4

# ============================================================================
# IN filter (tests list column serialization)
# ============================================================================

# Basic IN filter
query I
SELECT * FROM example.sequence(10, 1000) WHERE n IN (1, 3, 5, 7, 9);
----
1
3
5
7
9

# IN filter with single value
query I
SELECT * FROM example.sequence(10, 1000) WHERE n IN (5);
----
5

# IN filter with consecutive values
query I
SELECT * FROM example.sequence(10, 1000) WHERE n IN (2, 3, 4);
----
2
3
4

# IN filter with no matches
query I
SELECT * FROM example.sequence(5, 1000) WHERE n IN (10, 20, 30);
----

# ============================================================================
# IS NULL / IS NOT NULL filters
# ============================================================================

# IS NOT NULL (sequence never produces NULL, so all rows pass)
query I
SELECT COUNT(*) FROM example.sequence(10, 1000) WHERE n IS NOT NULL;
----
10

# ============================================================================
# Conjunction (AND) filters
# ============================================================================

# Range filter: n >= 3 AND n < 7
query I
SELECT * FROM example.sequence(10, 1000) WHERE n >= 3 AND n < 7;
----
3
4
5
6

# Range filter: n > 2 AND n <= 6
query I
SELECT * FROM example.sequence(10, 1000) WHERE n > 2 AND n <= 6;
----
3
4
5
6

# Tight range: n >= 5 AND n <= 5 (equivalent to n = 5)
query I
SELECT * FROM example.sequence(10, 1000) WHERE n >= 5 AND n <= 5;
----
5

# Empty range: n > 5 AND n < 5 (impossible condition)
query I
SELECT * FROM example.sequence(10, 1000) WHERE n > 5 AND n < 5;
----

# ============================================================================
# Combined with aggregations
# ============================================================================

# Count with filter
query I
SELECT COUNT(*) FROM example.sequence(100, 10) WHERE n >= 50;
----
50

# Sum with filter
query I
SELECT SUM(n) FROM example.sequence(10, 1000) WHERE n > 5;
----
30

# Min/max with filter
query II
SELECT MIN(n), MAX(n) FROM example.sequence(100, 10) WHERE n >= 20 AND n < 80;
----
20	79

# ============================================================================
# Filter with increment parameter
# ============================================================================

# Filter on sequence with increment
query I
SELECT * FROM example.sequence(5, 1000, increment=10) WHERE n >= 20;
----
20
30
40

# IN filter with increment
query I
SELECT * FROM example.sequence(5, 1000, increment=10) WHERE n IN (0, 20, 40);
----
0
20
40

# ============================================================================
# Larger dataset tests
# ============================================================================

# Filter pushdown should reduce data transfer
query I
SELECT COUNT(*) FROM example.sequence(10000, 100) WHERE n = 5000;
----
1

# Range on large dataset
query I
SELECT COUNT(*) FROM example.sequence(10000, 100) WHERE n >= 9990;
----
10

# IN filter on large dataset
query I
SELECT COUNT(*) FROM example.sequence(10000, 100) WHERE n IN (0, 1000, 2000, 3000, 4000, 5000, 6000, 7000, 8000, 9000);
----
10

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
