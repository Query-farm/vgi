# name: test/sql/integration/table/constant_columns/booleans.test
# description: Boolean type tests for VGI constant_columns table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Boolean type
# ----------------------------------------------------------------------------

query T
SELECT * FROM example.constant_columns(3, true);
----
true
true
true

query T
SELECT * FROM example.constant_columns(3, false);
----
false
false
false

# Multiple booleans
query TT
SELECT * FROM example.constant_columns(2, true, false);
----
true	false
true	false

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
