# name: test/sql/integration/table/constant_columns/edge_cases.test
# description: Edge case tests for VGI constant_columns table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Edge case: Zero rows
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM example.constant_columns(0, 42);
----
0

query I
SELECT COUNT(*) FROM example.constant_columns(0, 'hello', 123, 3.14);
----
0

# ----------------------------------------------------------------------------
# Edge case: Single row
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.constant_columns(1, 100);
----
100

query ITR
SELECT * FROM example.constant_columns(1, 1, 'single', 9.99);
----
1	single	9.99

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
