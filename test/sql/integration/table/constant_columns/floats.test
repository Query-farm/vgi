# name: test/sql/integration/table/constant_columns/floats.test
# description: Floating point type tests for VGI constant_columns table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Floating point types
# ----------------------------------------------------------------------------

# Basic doubles
query R
SELECT * FROM example.constant_columns(3, 3.14159);
----
3.14159
3.14159
3.14159

# Zero float
query R
SELECT * FROM example.constant_columns(2, 0.0);
----
0.0
0.0

# Negative float
query R
SELECT * FROM example.constant_columns(2, -123.456);
----
-123.456
-123.456

# Very small float
query R
SELECT * FROM example.constant_columns(2, 0.000001);
----
0.000001
0.000001

# Very large float
query R
SELECT * FROM example.constant_columns(2, 1e15);
----
1000000000000000.0
1000000000000000.0

# Multiple float columns
query RR
SELECT * FROM example.constant_columns(2, 1.5, 2.5);
----
1.5	2.5
1.5	2.5

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
