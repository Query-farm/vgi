# name: test/sql/integration/table/writable_pushdown.test
# description: Filter and projection pushdown on VGI writable tables
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'writable' AS writable (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CREATE TABLE writable.main.writable_data (id BIGINT NOT NULL, name VARCHAR NOT NULL);

statement ok
DELETE FROM writable.main.writable_data;

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
0

statement ok
INSERT INTO writable.main.writable_data SELECT i, CASE WHEN i % 3 = 0 THEN 'apple' WHEN i % 3 = 1 THEN 'banana' ELSE 'cherry' END FROM range(0, 1000) t(i);

# ============================================================================
# Projection pushdown — column subsets
# ============================================================================

# Only name column (no id in projection)
query I
SELECT COUNT(*) FROM (SELECT name FROM writable.main.writable_data WHERE id >= 0 AND id < 1000);
----
1000

# Only id column (no name in projection)
query I
SELECT COUNT(*) FROM (SELECT id FROM writable.main.writable_data WHERE id >= 0 AND id < 1000);
----
1000

# ============================================================================
# Filter pushdown — range filter
# ============================================================================

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 100 AND id <= 200;
----
101

# ============================================================================
# Filter pushdown — string equality
# ============================================================================

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE name = 'apple';
----
334

# ============================================================================
# Filter pushdown — combined filters
# ============================================================================

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id > 500 AND name = 'apple';
----
167

statement ok
DROP TABLE writable.main.writable_data;
