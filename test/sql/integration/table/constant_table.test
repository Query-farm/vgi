# name: test/sql/integration/table/constant_table.test
# description: Integration tests for VGI constant_table table function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# constant_table function
# Returns a table with repeated constant int64 values
# Args: count (int >= 1), value (int64)
# Internal batch size: 1000 rows
# ============================================================================

# ----------------------------------------------------------------------------
# Basic functionality - single row
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.constant_table(1, 42);
----
42

query I
SELECT * FROM example.constant_table(1, 0);
----
0

query I
SELECT * FROM example.constant_table(1, -100);
----
-100

# ----------------------------------------------------------------------------
# Basic functionality - multiple rows
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.constant_table(3, 42);
----
42
42
42

query I
SELECT * FROM example.constant_table(5, 7);
----
7
7
7
7
7

# ----------------------------------------------------------------------------
# Integer value edge cases
# ----------------------------------------------------------------------------

# Large positive value
query I
SELECT * FROM example.constant_table(2, 9223372036854775807);
----
9223372036854775807
9223372036854775807

# Large negative value
query I
SELECT * FROM example.constant_table(2, -9223372036854775808);
----
-9223372036854775808
-9223372036854775808

# Powers of 2
query I
SELECT * FROM example.constant_table(3, 1024);
----
1024
1024
1024

query I
SELECT * FROM example.constant_table(3, -2147483648);
----
-2147483648
-2147483648
-2147483648

# ----------------------------------------------------------------------------
# Single batch (count <= 1000)
# Internal BATCH_SIZE is 1000, so these should all be single-batch
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM example.constant_table(100, 999);
----
100

query I
SELECT COUNT(*) FROM example.constant_table(500, 123);
----
500

query I
SELECT COUNT(*) FROM example.constant_table(1000, 456);
----
1000

# Verify all values are correct
query I
SELECT COUNT(*) FROM example.constant_table(100, 42) WHERE value = 42;
----
100

query I
SELECT COUNT(*) FROM example.constant_table(1000, -999) WHERE value = -999;
----
1000

# ----------------------------------------------------------------------------
# Multi-batch scenarios (count > 1000)
# Tests that batching works correctly
# ----------------------------------------------------------------------------

# Just over one batch (1001 rows = 2 batches: 1000 + 1)
query I
SELECT COUNT(*) FROM example.constant_table(1001, 77);
----
1001

query I
SELECT COUNT(*) FROM example.constant_table(1001, 77) WHERE value = 77;
----
1001

# Two full batches (2000 rows)
query I
SELECT COUNT(*) FROM example.constant_table(2000, 88);
----
2000

query I
SELECT COUNT(*) FROM example.constant_table(2000, 88) WHERE value = 88;
----
2000

# Two batches + partial (2500 rows = 1000 + 1000 + 500)
query I
SELECT COUNT(*) FROM example.constant_table(2500, 99);
----
2500

# Three full batches (3000 rows)
query I
SELECT COUNT(*) FROM example.constant_table(3000, 111);
----
3000

# Large multi-batch (5000 rows = 5 batches)
query I
SELECT COUNT(*) FROM example.constant_table(5000, 222);
----
5000

query I
SELECT COUNT(*) FROM example.constant_table(5000, 222) WHERE value = 222;
----
5000

# 10000 rows (10 batches)
query I
SELECT COUNT(*) FROM example.constant_table(10000, 333);
----
10000

# Verify consistency across batches
query II
SELECT MIN(value), MAX(value) FROM example.constant_table(5000, 12345);
----
12345	12345

query I
SELECT COUNT(DISTINCT value) FROM example.constant_table(5000, 999);
----
1

# ----------------------------------------------------------------------------
# Aggregations
# ----------------------------------------------------------------------------

# SUM
query I
SELECT SUM(value) FROM example.constant_table(10, 5);
----
50

query I
SELECT SUM(value) FROM example.constant_table(100, 7);
----
700

query I
SELECT SUM(value) FROM example.constant_table(1000, 3);
----
3000

# SUM across batches
query I
SELECT SUM(value) FROM example.constant_table(2500, 4);
----
10000

# AVG (should equal the constant value)
query R
SELECT AVG(value) FROM example.constant_table(100, 42);
----
42.0

query R
SELECT AVG(value) FROM example.constant_table(2500, 100);
----
100.0

# MIN/MAX (should both equal the constant)
query II
SELECT MIN(value), MAX(value) FROM example.constant_table(100, 999);
----
999	999

query II
SELECT MIN(value), MAX(value) FROM example.constant_table(3000, -50);
----
-50	-50

# COUNT
query I
SELECT COUNT(*) FROM example.constant_table(100, 1);
----
100

query I
SELECT COUNT(value) FROM example.constant_table(100, 1);
----
100

# Multiple aggregations
query IIRIII
SELECT SUM(value), COUNT(*), AVG(value), MIN(value), MAX(value), COUNT(DISTINCT value)
FROM example.constant_table(1500, 77);
----
115500	1500	77.0	77	77	1

# ----------------------------------------------------------------------------
# Filtering
# ----------------------------------------------------------------------------

# All rows should match
query I
SELECT COUNT(*) FROM example.constant_table(100, 42) WHERE value = 42;
----
100

# No rows should match
query I
SELECT COUNT(*) FROM example.constant_table(100, 42) WHERE value = 43;
----
0

# Range filter (constant is inside range)
query I
SELECT COUNT(*) FROM example.constant_table(100, 50) WHERE value BETWEEN 1 AND 100;
----
100

# Range filter (constant is outside range)
query I
SELECT COUNT(*) FROM example.constant_table(100, 50) WHERE value BETWEEN 51 AND 100;
----
0

# Filter across batches
query I
SELECT COUNT(*) FROM example.constant_table(2500, 999) WHERE value = 999;
----
2500

# ----------------------------------------------------------------------------
# Expressions and computed columns
# ----------------------------------------------------------------------------

# Arithmetic
query I
SELECT value * 2 FROM example.constant_table(3, 10);
----
20
20
20

query I
SELECT value + 100 FROM example.constant_table(3, 5);
----
105
105
105

# Expressions in aggregations
query I
SELECT SUM(value * 2) FROM example.constant_table(100, 5);
----
1000

query R
SELECT AVG(value + 10) FROM example.constant_table(100, 20);
----
30.0

# ----------------------------------------------------------------------------
# Window functions
# ----------------------------------------------------------------------------

query II
SELECT value, ROW_NUMBER() OVER () as rn
FROM example.constant_table(5, 42)
LIMIT 5;
----
42	1
42	2
42	3
42	4
42	5

query II
SELECT value, SUM(value) OVER (ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as running_sum
FROM example.constant_table(5, 10);
----
10	10
10	20
10	30
10	40
10	50

# ----------------------------------------------------------------------------
# Joins
# ----------------------------------------------------------------------------

# Join two constant tables
query II
SELECT a.value as a_val, b.value as b_val
FROM example.constant_table(3, 10) a, example.constant_table(2, 20) b
ORDER BY a_val, b_val;
----
10	20
10	20
10	20
10	20
10	20
10	20

# Join with sequence (cross join: 5 * 5 = 25 rows, all pass filter since 100 > 0..4)
query I
SELECT COUNT(*)
FROM example.constant_table(5, 100) c, example.sequence(5, 10) s
WHERE c.value > s.n;
----
25

# Conditional join
query II
SELECT c.value, s.n
FROM example.constant_table(3, 5) c, example.sequence(10, 10) s
WHERE s.n < c.value
ORDER BY s.n;
----
5	0
5	0
5	0
5	1
5	1
5	1
5	2
5	2
5	2
5	3
5	3
5	3
5	4
5	4
5	4

# ----------------------------------------------------------------------------
# LIMIT and OFFSET
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.constant_table(100, 42) LIMIT 5;
----
42
42
42
42
42

query I
SELECT * FROM example.constant_table(100, 42) LIMIT 5 OFFSET 95;
----
42
42
42
42
42

query I
SELECT COUNT(*) FROM (SELECT * FROM example.constant_table(5000, 1) LIMIT 100);
----
100

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
