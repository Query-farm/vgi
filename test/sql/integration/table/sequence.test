# name: test/sql/integration/table/sequence.test
# description: Integration tests for VGI sequence table function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sequence function
# Generates integers 0 to count-1, with optional increment (named arg)
# Args: count (int), batch_size (int, default=1000), increment (named, default=1)
# ============================================================================

# ----------------------------------------------------------------------------
# Edge case: Zero rows (count=0)
# Should return empty result, no batches produced
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM example.sequence(0, 1000);
----
0

query I
SELECT COUNT(*) FROM example.sequence(0, 1);
----
0

query I
SELECT SUM(n) FROM example.sequence(0, 100);
----
NULL

# ----------------------------------------------------------------------------
# Edge case: Single row (count=1)
# Minimal non-empty result
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(1, 1000);
----
0

query I
SELECT * FROM example.sequence(1, 1);
----
0

query I
SELECT COUNT(*) FROM example.sequence(1, 10000);
----
1

# ----------------------------------------------------------------------------
# Batch size = 1 (stress test: one row per batch, many IPC round-trips)
# Tests that small batches work correctly
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(5, 1);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(100, 1);
----
100

query I
SELECT SUM(n) FROM example.sequence(50, 1);
----
1225

query II
SELECT MIN(n), MAX(n) FROM example.sequence(10, 1);
----
0	9

# ----------------------------------------------------------------------------
# Batch size > count (all rows fit in single batch)
# Tests that oversized batch_size doesn't cause issues
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(5, 10000);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(10, 100000);
----
10

query I
SELECT SUM(n) FROM example.sequence(100, 10000);
----
4950

# ----------------------------------------------------------------------------
# Batch size = count (exactly one full batch)
# Exact fit case
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(5, 5);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(100, 100);
----
100

query I
SELECT SUM(n) FROM example.sequence(10, 10);
----
45

# ----------------------------------------------------------------------------
# Batch size doesn't evenly divide count (partial final batch)
# Tests handling of remainder rows
# ----------------------------------------------------------------------------

# 7 rows, batch_size=3: batches of [3, 3, 1]
query I
SELECT * FROM example.sequence(7, 3);
----
0
1
2
3
4
5
6

# 10 rows, batch_size=3: batches of [3, 3, 3, 1]
query I
SELECT COUNT(*) FROM example.sequence(10, 3);
----
10

# 11 rows, batch_size=4: batches of [4, 4, 3]
query I
SELECT SUM(n) FROM example.sequence(11, 4);
----
55

# 99 rows, batch_size=10: batches of [10, 10, ..., 9]
query I
SELECT COUNT(*) FROM example.sequence(99, 10);
----
99

# 101 rows, batch_size=100: batches of [100, 1]
query I
SELECT COUNT(*) FROM example.sequence(101, 100);
----
101

# ----------------------------------------------------------------------------
# Large row counts with various batch sizes
# Tests sustained streaming
# ----------------------------------------------------------------------------

# 1000 rows, batch_size=1: 1000 batches
query I
SELECT COUNT(*) FROM example.sequence(1000, 1);
----
1000

query I
SELECT SUM(n) FROM example.sequence(1000, 1);
----
499500

# 10000 rows, batch_size=100: 100 batches
query I
SELECT COUNT(*) FROM example.sequence(10000, 100);
----
10000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(10000, 100);
----
0	9999

query I
SELECT SUM(n) FROM example.sequence(10000, 100);
----
49995000

# 10000 rows, batch_size=10000: single batch
query I
SELECT COUNT(*) FROM example.sequence(10000, 10000);
----
10000

query I
SELECT SUM(n) FROM example.sequence(10000, 10000);
----
49995000

# 10000 rows, batch_size=9999: batches of [9999, 1]
query I
SELECT COUNT(*) FROM example.sequence(10000, 9999);
----
10000

# 10000 rows, batch_size=3333: batches of [3333, 3333, 3333, 1]
query I
SELECT COUNT(*) FROM example.sequence(10000, 3333);
----
10000

# ----------------------------------------------------------------------------
# Increment parameter variations
# Tests value generation with different increments
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(5, 1000, increment=1);
----
0
1
2
3
4

query I
SELECT * FROM example.sequence(5, 1000, increment=10);
----
0
10
20
30
40

query I
SELECT * FROM example.sequence(4, 1000, increment=25);
----
0
25
50
75

# Small batch with increment
query I
SELECT * FROM example.sequence(5, 2, increment=3);
----
0
3
6
9
12

# Batch size = 1 with increment
query I
SELECT * FROM example.sequence(4, 1, increment=100);
----
0
100
200
300

# Large increment
query I
SELECT SUM(n) FROM example.sequence(100, 10, increment=7);
----
34650

# Verify increment math: sum of 0, 7, 14, 21, ..., 693 (100 terms)
# = 7 * (0 + 1 + 2 + ... + 99) = 7 * 4950 = 34650

# ----------------------------------------------------------------------------
# Combined edge cases
# Tests interactions between parameters
# ----------------------------------------------------------------------------

# Single row with large increment (should just return 0)
query I
SELECT * FROM example.sequence(1, 1, increment=1000000);
----
0

# Two rows with increment, batch_size=1
query I
SELECT * FROM example.sequence(2, 1, increment=50);
----
0
50

# Zero rows with increment (still empty)
query I
SELECT COUNT(*) FROM example.sequence(0, 1, increment=100);
----
0

# ----------------------------------------------------------------------------
# Aggregations and filtering on sequences
# Tests that generated data works correctly with SQL operations
# ----------------------------------------------------------------------------

# --- Basic aggregations ---

# SUM: 0+1+2+...+99 = 4950
query I
SELECT SUM(n) FROM example.sequence(100, 10);
----
4950

# SUM with different batch sizes (verify consistency)
query I
SELECT SUM(n) FROM example.sequence(100, 1);
----
4950

query I
SELECT SUM(n) FROM example.sequence(100, 100);
----
4950

query I
SELECT SUM(n) FROM example.sequence(100, 1000);
----
4950

# AVG: average of 0..99 = 49.5
query R
SELECT AVG(n) FROM example.sequence(100, 10);
----
49.5

# MIN/MAX
query II
SELECT MIN(n), MAX(n) FROM example.sequence(100, 10);
----
0	99

# COUNT
query I
SELECT COUNT(*) FROM example.sequence(100, 10);
----
100

# Multiple aggregations in one query
query IIRIII
SELECT SUM(n), COUNT(*), AVG(n), MIN(n), MAX(n), COUNT(DISTINCT n)
FROM example.sequence(1000, 50);
----
499500	1000	499.5	0	999	1000

# --- Aggregations on empty sequences ---

query I
SELECT SUM(n) FROM example.sequence(0, 10);
----
NULL

query I
SELECT COUNT(*) FROM example.sequence(0, 10);
----
0

query R
SELECT AVG(n) FROM example.sequence(0, 10);
----
NULL

query II
SELECT MIN(n), MAX(n) FROM example.sequence(0, 10);
----
NULL	NULL

# --- Aggregations on single row ---

query I
SELECT SUM(n) FROM example.sequence(1, 10);
----
0

query R
SELECT AVG(n) FROM example.sequence(1, 10);
----
0.0

query II
SELECT MIN(n), MAX(n) FROM example.sequence(1, 10);
----
0	0

# --- Aggregations with increment ---

# SUM with increment=2: 0+2+4+6+8 = 20
query I
SELECT SUM(n) FROM example.sequence(5, 10, increment=2);
----
20

# AVG with increment=2: avg(0,2,4,6,8) = 4.0
query R
SELECT AVG(n) FROM example.sequence(5, 10, increment=2);
----
4.0

# --- Aggregations with GROUP BY ---

# Group by modulo (count values in each bucket)
query II
SELECT n % 10 as bucket, COUNT(*) as cnt
FROM example.sequence(100, 7)
GROUP BY bucket
ORDER BY bucket;
----
0	10
1	10
2	10
3	10
4	10
5	10
6	10
7	10
8	10
9	10

# Sum within groups
query II
SELECT n % 5 as bucket, SUM(n) as total
FROM example.sequence(20, 3)
GROUP BY bucket
ORDER BY bucket;
----
0	30
1	34
2	38
3	42
4	46

# --- Filtering ---

# Filter half the values
query I
SELECT COUNT(*) FROM example.sequence(100, 7) WHERE n >= 50;
----
50

# Filter with modulo
query I
SELECT COUNT(*) FROM example.sequence(100, 13) WHERE n % 10 = 0;
----
10

# Filter with range
query I
SELECT COUNT(*) FROM example.sequence(1000, 50) WHERE n BETWEEN 100 AND 199;
----
100

# Aggregation on filtered data
query I
SELECT SUM(n) FROM example.sequence(100, 10) WHERE n < 10;
----
45

query R
SELECT AVG(n) FROM example.sequence(100, 10) WHERE n >= 90;
----
94.5

# --- Sorting ---

# ORDER BY (should already be ordered, but verify)
query I
SELECT * FROM example.sequence(5, 2) ORDER BY n DESC;
----
4
3
2
1
0

# ORDER BY with LIMIT
query I
SELECT * FROM example.sequence(100, 10) ORDER BY n DESC LIMIT 5;
----
99
98
97
96
95

query I
SELECT * FROM example.sequence(100, 10) ORDER BY n ASC LIMIT 5;
----
0
1
2
3
4

# --- DISTINCT ---

# All values should be unique
query I
SELECT COUNT(DISTINCT n) FROM example.sequence(1000, 50);
----
1000

# DISTINCT on small set
query I
SELECT DISTINCT n FROM example.sequence(5, 2) ORDER BY n;
----
0
1
2
3
4

# --- Window functions ---

# Running sum
query II
SELECT n, SUM(n) OVER (ORDER BY n) as running_sum
FROM example.sequence(5, 2)
ORDER BY n;
----
0	0
1	1
2	3
3	6
4	10

# Row number
query II
SELECT n, ROW_NUMBER() OVER (ORDER BY n) as rn
FROM example.sequence(5, 2)
ORDER BY n;
----
0	1
1	2
2	3
3	4
4	5

# --- HAVING clause ---

query II
SELECT n % 3 as bucket, COUNT(*) as cnt
FROM example.sequence(30, 5)
GROUP BY bucket
HAVING COUNT(*) = 10
ORDER BY bucket;
----
0	10
1	10
2	10

# ----------------------------------------------------------------------------
# Join sequences (stress test multiple concurrent generators)
# ----------------------------------------------------------------------------

query II
SELECT a.n as a_val, b.n as b_val
FROM example.sequence(5, 2) a, example.sequence(5, 3) b
WHERE a.n = b.n
ORDER BY a.n;
----
0	0
1	1
2	2
3	3
4	4

# Self-join with different batch sizes
query I
SELECT COUNT(*) FROM example.sequence(100, 7) a, example.sequence(100, 13) b WHERE a.n = b.n;
----
100

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
