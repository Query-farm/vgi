# name: test/sql/integration/table/sequence.test
# description: Tests for VGI sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sequence function
# Generates integers 0 to count-1, with optional increment (named arg)
# Args: count (int), batch_size (int, default=1000), increment (named, default=1)
# ============================================================================

# ============================================================================
# Basic sequence generation
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 1000);
----
0
1
2
3
4

# Verify count
query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 10);
----
100

# Verify values
query II
SELECT MIN(n), MAX(n) FROM example.sequence(100, batch_size := 10);
----
0	99

# Verify sum
query I
SELECT SUM(n) FROM example.sequence(10, batch_size := 10);
----
45

# ============================================================================
# Batch boundaries - batch_size=1 (one row per batch, many IPC round-trips)
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 1);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 1);
----
100

query I
SELECT SUM(n) FROM example.sequence(50, batch_size := 1);
----
1225

query II
SELECT MIN(n), MAX(n) FROM example.sequence(10, batch_size := 1);
----
0	9

# ============================================================================
# Batch boundaries - batch_size > count (all rows fit in single batch)
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 10000);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(10, batch_size := 100000);
----
10

query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 10000);
----
4950

# ============================================================================
# Batch boundaries - batch_size = count (exactly one full batch)
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 5);
----
0
1
2
3
4

query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 100);
----
100

query I
SELECT SUM(n) FROM example.sequence(10, batch_size := 10);
----
45

# ============================================================================
# Batch boundaries - partial final batch
# ============================================================================

# 7 rows, batch_size=3: batches of [3, 3, 1]
query I
SELECT * FROM example.sequence(7, batch_size := 3);
----
0
1
2
3
4
5
6

# 10 rows, batch_size=3: batches of [3, 3, 3, 1]
query I
SELECT COUNT(*) FROM example.sequence(10, batch_size := 3);
----
10

# 11 rows, batch_size=4: batches of [4, 4, 3]
query I
SELECT SUM(n) FROM example.sequence(11, batch_size := 4);
----
55

# 99 rows, batch_size=10: batches of [10, 10, ..., 9]
query I
SELECT COUNT(*) FROM example.sequence(99, batch_size := 10);
----
99

# 101 rows, batch_size=100: batches of [100, 1]
query I
SELECT COUNT(*) FROM example.sequence(101, batch_size := 100);
----
101

# ============================================================================
# Edge cases - Zero rows (count=0)
# ============================================================================

query I
SELECT COUNT(*) FROM example.sequence(0, batch_size := 1000);
----
0

query I
SELECT COUNT(*) FROM example.sequence(0, batch_size := 1);
----
0

query I
SELECT SUM(n) FROM example.sequence(0, batch_size := 100);
----
NULL

query I
SELECT MIN(n) FROM example.sequence(0, batch_size := 100);
----
NULL

# Empty result in subquery
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(0, batch_size := 10)) sub;
----
0

# ============================================================================
# Edge cases - Single row (count=1)
# ============================================================================

query I
SELECT * FROM example.sequence(1, batch_size := 1000);
----
0

query I
SELECT * FROM example.sequence(1, batch_size := 1);
----
0

query I
SELECT COUNT(*) FROM example.sequence(1, batch_size := 10000);
----
1

# ============================================================================
# Parameter variations - Increment
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 1000, increment=1);
----
0
1
2
3
4

query I
SELECT * FROM example.sequence(5, batch_size := 1000, increment=10);
----
0
10
20
30
40

query I
SELECT * FROM example.sequence(4, batch_size := 1000, increment=25);
----
0
25
50
75

# Small batch with increment
query I
SELECT * FROM example.sequence(5, batch_size := 2, increment=3);
----
0
3
6
9
12

# Batch size = 1 with increment
query I
SELECT * FROM example.sequence(4, batch_size := 1, increment=100);
----
0
100
200
300

# Large increment
query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 10, increment=7);
----
34650

# Verify increment math: sum of 0, 7, 14, 21, ..., 693 (100 terms)
# = 7 * (0 + 1 + 2 + ... + 99) = 7 * 4950 = 34650

# Single row with large increment (should just return 0)
query I
SELECT * FROM example.sequence(1, batch_size := 1, increment=1000000);
----
0

# Two rows with increment, batch_size=1
query I
SELECT * FROM example.sequence(2, batch_size := 1, increment=50);
----
0
50

# Zero rows with increment (still empty)
query I
SELECT COUNT(*) FROM example.sequence(0, batch_size := 1, increment=100);
----
0

# ============================================================================
# Large batches exceeding STANDARD_VECTOR_SIZE (2048)
# Forces the extension to handle oversized batches via pending_output
# ============================================================================

# batch_size=5000 > 2048 (STANDARD_VECTOR_SIZE)
query I
SELECT COUNT(*) FROM example.sequence(5000, batch_size := 5000);
----
5000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(5000, batch_size := 5000);
----
0	4999

query I
SELECT SUM(n) FROM example.sequence(5000, batch_size := 5000);
----
12497500

# batch_size=10000, multiple oversized batches
query I
SELECT COUNT(*) FROM example.sequence(25000, batch_size := 10000);
----
25000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(25000, batch_size := 10000);
----
0	24999

# batch_size=3000 (just above 2048), many batches
query I
SELECT COUNT(*) FROM example.sequence(9000, batch_size := 3000);
----
9000

query I
SELECT SUM(n) FROM example.sequence(9000, batch_size := 3000);
----
40495500

# ============================================================================
# SQL operations - Aggregations
# ============================================================================

# SUM: 0+1+2+...+99 = 4950
query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 10);
----
4950

# SUM with different batch sizes (verify consistency)
query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 1);
----
4950

query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 100);
----
4950

query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 1000);
----
4950

# AVG: average of 0..99 = 49.5
query R
SELECT AVG(n) FROM example.sequence(100, batch_size := 10);
----
49.5

# MIN/MAX
query II
SELECT MIN(n), MAX(n) FROM example.sequence(100, batch_size := 10);
----
0	99

# COUNT
query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 10);
----
100

# Multiple aggregations in one query
query IIRIII
SELECT SUM(n), COUNT(*), AVG(n), MIN(n), MAX(n), COUNT(DISTINCT n)
FROM example.sequence(1000, batch_size := 50);
----
499500	1000	499.5	0	999	1000

# Aggregations on empty sequences
query I
SELECT SUM(n) FROM example.sequence(0, batch_size := 10);
----
NULL

query I
SELECT COUNT(*) FROM example.sequence(0, batch_size := 10);
----
0

query R
SELECT AVG(n) FROM example.sequence(0, batch_size := 10);
----
NULL

query II
SELECT MIN(n), MAX(n) FROM example.sequence(0, batch_size := 10);
----
NULL	NULL

# Aggregations on single row
query I
SELECT SUM(n) FROM example.sequence(1, batch_size := 10);
----
0

query R
SELECT AVG(n) FROM example.sequence(1, batch_size := 10);
----
0.0

query II
SELECT MIN(n), MAX(n) FROM example.sequence(1, batch_size := 10);
----
0	0

# Aggregations with increment
# SUM with increment=2: 0+2+4+6+8 = 20
query I
SELECT SUM(n) FROM example.sequence(5, batch_size := 10, increment=2);
----
20

# AVG with increment=2: avg(0,2,4,6,8) = 4.0
query R
SELECT AVG(n) FROM example.sequence(5, batch_size := 10, increment=2);
----
4.0

# ============================================================================
# SQL operations - GROUP BY
# ============================================================================

# Group by modulo (count values in each bucket)
query II
SELECT n % 10 as bucket, COUNT(*) as cnt
FROM example.sequence(100, batch_size := 7)
GROUP BY bucket
ORDER BY bucket;
----
0	10
1	10
2	10
3	10
4	10
5	10
6	10
7	10
8	10
9	10

# Sum within groups
query II
SELECT n % 5 as bucket, SUM(n) as total
FROM example.sequence(20, batch_size := 3)
GROUP BY bucket
ORDER BY bucket;
----
0	30
1	34
2	38
3	42
4	46

# ============================================================================
# SQL operations - Filtering
# ============================================================================

# Filter half the values
query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 7) WHERE n >= 50;
----
50

# Filter with modulo
query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 13) WHERE n % 10 = 0;
----
10

# Filter with range
query I
SELECT COUNT(*) FROM example.sequence(1000, batch_size := 50) WHERE n BETWEEN 100 AND 199;
----
100

# Aggregation on filtered data
query I
SELECT SUM(n) FROM example.sequence(100, batch_size := 10) WHERE n < 10;
----
45

query R
SELECT AVG(n) FROM example.sequence(100, batch_size := 10) WHERE n >= 90;
----
94.5

# ============================================================================
# SQL operations - Sorting
# ============================================================================

query I
SELECT * FROM example.sequence(5, batch_size := 2) ORDER BY n DESC;
----
4
3
2
1
0

query I
SELECT * FROM example.sequence(100, batch_size := 10) ORDER BY n DESC LIMIT 5;
----
99
98
97
96
95

query I
SELECT * FROM example.sequence(100, batch_size := 10) ORDER BY n ASC LIMIT 5;
----
0
1
2
3
4

# ============================================================================
# SQL operations - DISTINCT
# ============================================================================

query I
SELECT COUNT(DISTINCT n) FROM example.sequence(1000, batch_size := 50);
----
1000

query I
SELECT DISTINCT n FROM example.sequence(5, batch_size := 2) ORDER BY n;
----
0
1
2
3
4

# ============================================================================
# SQL operations - Window functions
# ============================================================================

# Running sum
query II
SELECT n, SUM(n) OVER (ORDER BY n) as running_sum
FROM example.sequence(5, batch_size := 2)
ORDER BY n;
----
0	0
1	1
2	3
3	6
4	10

# Row number
query II
SELECT n, ROW_NUMBER() OVER (ORDER BY n) as rn
FROM example.sequence(5, batch_size := 2)
ORDER BY n;
----
0	1
1	2
2	3
3	4
4	5

# ============================================================================
# SQL operations - HAVING
# ============================================================================

query II
SELECT n % 3 as bucket, COUNT(*) as cnt
FROM example.sequence(30, batch_size := 5)
GROUP BY bucket
HAVING COUNT(*) = 10
ORDER BY bucket;
----
0	10
1	10
2	10

# ============================================================================
# SQL operations - Joins
# ============================================================================

query II
SELECT a.n as a_val, b.n as b_val
FROM example.sequence(5, batch_size := 2) a, example.sequence(5, batch_size := 3) b
WHERE a.n = b.n
ORDER BY a.n;
----
0	0
1	1
2	2
3	3
4	4

# Self-join with different batch sizes
query I
SELECT COUNT(*) FROM example.sequence(100, batch_size := 7) a, example.sequence(100, batch_size := 13) b WHERE a.n = b.n;
----
100

# ============================================================================
# SQL operations - LIMIT
# ============================================================================

# Small limit on large sequence - early termination
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(10000, batch_size := 100) LIMIT 10);
----
10

# Limit equals count
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(100, batch_size := 10) LIMIT 100);
----
100

# Limit larger than count - should return all rows
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(50, batch_size := 10) LIMIT 1000);
----
50

# Limit with ORDER BY - get smallest values
query I
SELECT * FROM example.sequence(1000, batch_size := 50) ORDER BY n LIMIT 5;
----
0
1
2
3
4

# Limit with ORDER BY DESC - get largest values
query I
SELECT * FROM example.sequence(1000, batch_size := 50) ORDER BY n DESC LIMIT 5;
----
999
998
997
996
995

# Limit across batch boundaries (batch size = 100)
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(5000, batch_size := 100) LIMIT 350);
----
350

# Limit with increment
query I
SELECT * FROM example.sequence(1000, batch_size := 50, increment=5) ORDER BY n LIMIT 5;
----
0
5
10
15
20

# LIMIT 1 - minimal result
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(10000, batch_size := 100) LIMIT 1);
----
1

# LIMIT 0 - empty result
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(10000, batch_size := 100) LIMIT 0);
----
0

# LIMIT with OFFSET
query I
SELECT * FROM example.sequence(100, batch_size := 10) ORDER BY n LIMIT 5 OFFSET 10;
----
10
11
12
13
14

# Large LIMIT with OFFSET near end
query I
SELECT * FROM example.sequence(100, batch_size := 10) ORDER BY n LIMIT 10 OFFSET 95;
----
95
96
97
98
99

# LIMIT with small batch size (batch_size=1)
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(1000, batch_size := 1) LIMIT 50);
----
50

# Verify LIMIT doesn't affect correctness of returned values
query I
SELECT SUM(n) = (100::BIGINT * 99 / 2) as sum_correct
FROM (SELECT * FROM example.sequence(10000, batch_size := 50) ORDER BY n LIMIT 100);
----
true

# LIMIT with filtering
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(1000, batch_size := 50) WHERE n % 2 = 0 LIMIT 25);
----
25

# LIMIT with aggregation in subquery
query I
SELECT total FROM (SELECT SUM(n) as total FROM example.sequence(100, batch_size := 10)) LIMIT 1;
----
4950

# ============================================================================
# Scale tests - Large row counts
# ============================================================================

# 1000 rows, batch_size=1: 1000 batches
query I
SELECT COUNT(*) FROM example.sequence(1000, batch_size := 1);
----
1000

query I
SELECT SUM(n) FROM example.sequence(1000, batch_size := 1);
----
499500

# 10000 rows, batch_size=100: 100 batches
query I
SELECT COUNT(*) FROM example.sequence(10000, batch_size := 100);
----
10000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(10000, batch_size := 100);
----
0	9999

query I
SELECT SUM(n) FROM example.sequence(10000, batch_size := 100);
----
49995000

# 10000 rows, batch_size=10000: single batch
query I
SELECT COUNT(*) FROM example.sequence(10000, batch_size := 10000);
----
10000

query I
SELECT SUM(n) FROM example.sequence(10000, batch_size := 10000);
----
49995000

# 10000 rows, batch_size=9999: batches of [9999, 1]
query I
SELECT COUNT(*) FROM example.sequence(10000, batch_size := 9999);
----
10000

# 10000 rows, batch_size=3333: batches of [3333, 3333, 3333, 1]
query I
SELECT COUNT(*) FROM example.sequence(10000, batch_size := 3333);
----
10000

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
