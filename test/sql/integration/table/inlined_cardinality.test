# name: test/sql/integration/table/inlined_cardinality.test
# description: When TableInfo.cardinality_estimate / cardinality_max are
#              inlined, the extension uses them directly and skips the
#              per-bind ``table_function_cardinality`` RPC.
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CALL enable_logging(level := 'debug');

statement ok
CALL truncate_duckdb_logs();

# ============================================================================
# Inlined cardinality: ``cardinality_inlined_table`` declares
# ``cardinality_estimate=10000, cardinality_max=10000`` on its Table descriptor.
# DuckDB's optimizer must see the estimate in the plan, the inlined trace
# must fire, and the per-bind RPC must NOT fire.
# ============================================================================

# Plan reports the inlined estimate. (Use a base SELECT — EXPLAIN doesn't
# trigger execution but does trigger bind.)
query II
EXPLAIN (FORMAT JSON) SELECT * FROM example.data.cardinality_inlined_table;
----
physical_plan	<REGEX>:.*"Estimated Cardinality":\s*"10000".*

# Inlined-trace event fires.
query I
SELECT COUNT(*) >= 1 FROM duckdb_logs() WHERE type = 'VGI'
  AND message LIKE '%vgi.cardinality.inlined%'
  AND message LIKE '%cardinality_inlined_table%';
----
true

# The per-bind cardinality RPC does NOT fire for this table.
query I
SELECT COUNT(*) = 0 FROM duckdb_logs() WHERE type = 'VGI'
  AND message LIKE '%table_function_cardinality%'
  AND message LIKE '%cardinality_inlined_table%';
----
true

# ============================================================================
# Legacy path: ``ten_thousand_table`` is function-backed but does NOT inline
# cardinality on its Table descriptor — the per-bind RPC must still fire.
# ============================================================================

statement ok
CALL truncate_duckdb_logs();

query II
EXPLAIN (FORMAT JSON) SELECT * FROM example.data.ten_thousand_table;
----
physical_plan	<REGEX>:.*"Estimated Cardinality":\s*"10000".*

# No inlined-trace event for the legacy path.
query I
SELECT COUNT(*) = 0 FROM duckdb_logs() WHERE type = 'VGI'
  AND message LIKE '%vgi.cardinality.inlined%'
  AND message LIKE '%ten_thousand_table%';
----
true
