# name: test/sql/integration/table/comments.test
# description: Test comment metadata visibility on tables, views, and columns
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Table comments (via duckdb_tables)
# ============================================================================

query TT
SELECT table_name, comment
FROM duckdb_tables()
WHERE database_name = 'example' AND schema_name = 'data'
  AND comment IS NOT NULL
  AND table_name != 'geo_points'  -- geo_points requires spatial extension
  AND table_name NOT LIKE 'rff_%'  -- rff_* fixtures live in required_field_filter_paths_*.test
ORDER BY table_name;
----
cardinality_inlined_table	Function-backed table with inlined cardinality (10000 rows)
colors	Colors table with ENUM-derived statistics
departments	Department reference table
employees	Employee table with FK to departments
filter_echo_table	Catalog table echoing pushed-down filters (filter-pushdown-through-view tests).
funny_numbers	123456 integers; stats served by the sequence function, not the table
generated_sequence	Table with generated columns backed by sequence(10)
large_sequence	A large sequence of integers from 0 to 1,000,000
late_mat	Late-materialization table (1000 rows, unique rowid)
late_mat_dup	Late-materialization table with deliberately non-unique rowid (contract violation)
late_mat_nulls	Late-materialization table with NULLs in the ord column
multi_branch_empty	Multi-branch: empty branches list — used by multi_branch_empty_branches.test
multi_branch_filtered_numbers	Multi-branch with complementary branch_filters — exercises pruning
multi_branch_hetero	Multi-branch: sequence(50) + read_parquet — used by multi_branch_heterogeneous.test
multi_branch_nopushdown	Multi-branch: VGI + read_csv — used by multi_branch_pushdown_incapable.test
multi_branch_numbers	Multi-branch: UNION of sequence(50) + sequence(50) — used by multi_branch_scan.test
multi_branch_recon	Multi-branch: column reconciliation — used by multi_branch_reconciliation.test
multi_branch_two_writable	Multi-branch with two writable=True arms — used by multi_branch_two_writable.test
numbers	First 100 integers (demonstrates explicit columns)
products	Product table with column defaults
projects	Projects with composite PK and FK to departments
rowid_first	Table with row_id at column index 0
rowid_last	Table with row_id at column index 2
rowid_middle	Table with row_id at column index 1
rowid_string	Table with string row_id
rowid_struct	Table with struct row_id
ten_thousand_table	Function-backed table over the no-arg ten_thousand function
tt_pushdown_cols	Columns-based: prunes by filter AND time-travels (AT → version arg).
tt_pushdown_fn	Function-backed: prunes by filter AND time-travels (AT read at init).
versioned_constraints	Table with constraints that evolve across versions
versioned_data	Versioned data table demonstrating time travel with schema evolution
volatile_numbers	Numbers with volatile stats (TTL=0, always re-fetched)

# ============================================================================
# View comments (via duckdb_views)
# ============================================================================

query TT
SELECT view_name, comment
FROM duckdb_views()
WHERE database_name = 'example' AND schema_name = 'main'
  AND comment IS NOT NULL
ORDER BY view_name;
----
even_numbers	Even numbers from 0 to 98
first_ten	First 10 integers

# ============================================================================
# View tags (via duckdb_views)
# ============================================================================

# first_ten declares view-level tags; even_numbers declares none (empty map).
query TT
SELECT view_name, tags
FROM duckdb_views()
WHERE database_name = 'example' AND schema_name = 'main'
ORDER BY view_name;
----
even_numbers	{}
first_ten	{layer=demo, origin=sequence}

# ============================================================================
# View column comments (via duckdb_columns)
# ============================================================================

# first_ten (main schema) carries a comment on its single output column `n`.
query TT
SELECT column_name, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'main'
  AND table_name = 'first_ten'
ORDER BY column_name;
----
n	Sequence index 0..9

# small_numbers (data schema) carries a comment on its `value` column —
# exercises a view column comment outside the default schema, aligned by name.
query TT
SELECT column_name, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'data'
  AND table_name = 'small_numbers'
ORDER BY column_name;
----
value	Single-digit value 0..9

# even_numbers has a view-level comment but no column comments, so its column
# `n` must report a NULL comment (commented view != commented columns).
query TT
SELECT column_name, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'main'
  AND table_name = 'even_numbers'
ORDER BY column_name;
----
n	NULL

# ============================================================================
# Column comments on products table (via duckdb_columns)
# ============================================================================

query TT
SELECT column_name, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'data'
  AND table_name = 'products'
  AND comment IS NOT NULL
ORDER BY column_name;
----
id	Unique product identifier
name	Product display name
price	Unit price in USD

# Columns without comments have NULL
query TT
SELECT column_name, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'data'
  AND table_name = 'products'
  AND comment IS NULL
ORDER BY column_name;
----
quantity	NULL

# ============================================================================
# Column with both default AND comment (coexistence test)
# ============================================================================

query TTT
SELECT column_name, column_default, comment
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'data'
  AND table_name = 'products'
  AND column_default IS NOT NULL AND comment IS NOT NULL
ORDER BY column_name;
----
name	'unknown'	Product display name
price	9.99	Unit price in USD

# ============================================================================
# Tables without column comments have all NULL comments
# ============================================================================

query I
SELECT COUNT(*)
FROM duckdb_columns()
WHERE database_name = 'example' AND schema_name = 'data'
  AND table_name = 'departments'
  AND comment IS NOT NULL;
----
0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
