# name: test/sql/integration/table/function_registration.test
# description: Validates table function registration metadata matches the VGI example worker specification
# group: [vgi_integration_table]

# Table functions registered by the example worker must expose consistent metadata
# through duckdb_functions() so that all VGI worker implementations (Python, Go, etc.)
# can be validated against the same expectations.
#
# Note: Table-in-out functions also register as function_type='table' in DuckDB.
# They are tested separately in table_in_out/function_registration.test.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Function Inventory
# 59 pure table functions + 9 table-in-out functions = 68 total table-type functions (+1 overload of an existing group = 69)
# (59 includes the 3 partitioned_*_order fixtures used by order_preservation_modes.test,
# the tx_cached_value fixture used by the catalog transaction tests, 2 batch_index
# reference fixtures, 3 deliberately-broken batch_index fixtures used by
# batch_index_contract.test, 4 partition_columns reference fixtures, 4
# deliberately-broken partition_columns fixtures used by
# partition_columns_contract.test, and the dict_filter_echo fixture used by
# filter_pushdown/dictionary_varchar.test.)
# ============================================================================

# Total table-type function count (includes table-in-out)
# 69 base + 5 table_buffering failure-injection fixtures (crash_on_process,
# crash_on_combine, crash_on_finalize, hang_on_process, large_state) +
# 3 ordering-knob fixtures (ordered_buffer_input, batch_index_buffer_input,
# ordered_source) +
# 2 cancel/pushdown probes (slow_cancellable_buffering, echo_buffering) +
# 1 projection-pushdown witness (echo_witness)
# = 80
query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table';
----
80

# The 33 pure table functions (no TABLE parameter type)
# Note: make_series appears 5 times (5 overloads), make_pairs appears 3 times,
#       repeat_value appears 2 times
query T
SELECT function_name
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table'
AND function_name IN (
    'constant_columns', 'double_sequence', 'dynamic_filter_echo', 'expression_filter_test', 'filter_echo',
    'filter_echo_partitioned',
    'generator_exception', 'logging_generator', 'make_series',
    'make_pairs', 'order_echo', 'repeat_value',
    'named_params_echo', 'nested_sequence', 'partitioned_sequence',
    'projected_data', 'rowid_sequence', 'sample_echo', 'scoped_secret_demo', 'secret_demo', 'sequence',
    'settings_aware', 'spatial_filter_example', 'struct_settings', 'ten_thousand', 'versioned_data_scan'
)
ORDER BY function_name;
----
constant_columns
double_sequence
dynamic_filter_echo
expression_filter_test
filter_echo
filter_echo_partitioned
generator_exception
logging_generator
make_pairs
make_pairs
make_pairs
make_series
make_series
make_series
make_series
make_series
named_params_echo
nested_sequence
order_echo
partitioned_sequence
projected_data
repeat_value
repeat_value
rowid_sequence
sample_echo
scoped_secret_demo
secret_demo
sequence
settings_aware
spatial_filter_example
struct_settings
ten_thousand
versioned_data_scan

# ============================================================================
# Per-function Registration
# Each query checks: name, parameters, parameter_types, description
# Note: Table functions have return_type=NULL (output schema is determined at bind)
# ============================================================================

# ----------------------------------------------------------------------------
# constant_columns — Varargs with dynamic output schema
# Parameters: count (BIGINT), varargs=ANY
# Each vararg value becomes a column in the output
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'constant_columns';
----
constant_columns	[count]	[BIGINT]	Generates rows with constant values from varargs

# ----------------------------------------------------------------------------
# double_sequence — Float sequence generator
# Parameters: count (BIGINT), batch_size (BIGINT named), increment (DOUBLE named)
# Note: increment is DOUBLE (not BIGINT) for this function
# Note: Named parameter ordering in duckdb_functions() is hash-dependent,
#       so we sort the arrays for deterministic comparison.
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, list_sort(parameters), list_sort(parameter_types), description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'double_sequence';
----
double_sequence	[batch_size, count, increment]	[BIGINT, BIGINT, DOUBLE]	Generates a sequence of floating-point numbers from 0 to n-1

# ----------------------------------------------------------------------------
# generator_exception — Error handling test function
# Parameters: fail_after (BIGINT)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'generator_exception';
----
generator_exception	[fail_after]	[BIGINT]	Raises an exception after N batches for testing

# ----------------------------------------------------------------------------
# logging_generator — Log message emission during generation
# Parameters: count (BIGINT)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'logging_generator';
----
logging_generator	[count]	[BIGINT]	Emits log messages during generation

# ----------------------------------------------------------------------------
# named_params_echo — Echoes named parameter values in output columns
# Parameters: count (BIGINT), enabled (BOOLEAN named), greeting (VARCHAR named),
#             multiplier (BIGINT named), scale (DOUBLE named)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, list_sort(parameters), list_sort(parameter_types), description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'named_params_echo';
----
named_params_echo	[count, enabled, greeting, multiplier, scale]	[BIGINT, BIGINT, BOOLEAN, DOUBLE, VARCHAR]	Echoes named parameter values in output columns

# ----------------------------------------------------------------------------
# make_series — Overloaded function with 5 variants (3 by arg count, 2 by type)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'make_series'
ORDER BY length(parameters::VARCHAR), parameter_types::VARCHAR;
----
make_series	[step]	[DOUBLE]	Generate 10 float values with given step size
make_series	[count]	[BIGINT]	Generate integers from 0 to count-1
make_series	[values]	[VARCHAR]	Parse comma-separated integers into rows
make_series	[start, stop]	[BIGINT, BIGINT]	Generate integers from start to stop-1
make_series	[start, stop, step]	[BIGINT, BIGINT, BIGINT]	Generate integers from start to stop-1 with step

# ----------------------------------------------------------------------------
# make_pairs — Overloaded function with 3 variants (by argument type)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'make_pairs'
ORDER BY parameter_types::VARCHAR;
----
make_pairs	[start, stop]	[BIGINT, BIGINT]	Generate integer pairs (i, i*2)
make_pairs	[start, label]	[BIGINT, VARCHAR]	Generate mixed int/string pairs
make_pairs	[prefix, suffix]	[VARCHAR, VARCHAR]	Generate string pairs with prefix and suffix

# ----------------------------------------------------------------------------
# nested_sequence — Struct and list output columns
# Parameters: count (BIGINT), batch_size (BIGINT named), history_size (BIGINT named)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, list_sort(parameters), list_sort(parameter_types), description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'nested_sequence';
----
nested_sequence	[batch_size, count, history_size]	[BIGINT, BIGINT, BIGINT]	Generates a sequence with nested struct and list columns

# ----------------------------------------------------------------------------
# partitioned_sequence — Multi-worker parallel execution via work queue
# Parameters: count (BIGINT), increment (BIGINT named)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'partitioned_sequence';
----
partitioned_sequence	[count, increment]	[BIGINT, BIGINT]	Generates a partitioned sequence for multi-worker execution

# ----------------------------------------------------------------------------
# filter_echo_partitioned — Multi-worker filter pushdown via work queue
# Parameters: count (BIGINT)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'filter_echo_partitioned';
----
filter_echo_partitioned	[count]	[BIGINT]	Multi-worker partitioned sequence that echoes pushed-down filters

# ----------------------------------------------------------------------------
# projected_data — 4-column output with projection pushdown
# Parameters: count (BIGINT)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'projected_data';
----
projected_data	[count]	[BIGINT]	Generates data with 4 columns, supporting projection pushdown

# ----------------------------------------------------------------------------
# sequence — Integer sequence generator with optional increment
# Parameters: count (BIGINT), batch_size (BIGINT named), increment (BIGINT named)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, list_sort(parameters), list_sort(parameter_types), description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sequence';
----
sequence	[batch_size, count, increment]	[BIGINT, BIGINT, BIGINT]	Generates a sequence of integers from 0 to n-1

# ----------------------------------------------------------------------------
# settings_aware — Output depends on DuckDB settings
# Parameters: count (BIGINT)
# Note: Settings (vgi_verbose_mode, greeting, multiplier) are passed internally,
#       not as function parameters
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'settings_aware';
----
settings_aware	[count]	[BIGINT]	Generates data demonstrating settings are passed

# ----------------------------------------------------------------------------
# struct_settings — Sequence configured by struct setting
# Parameters: count (BIGINT)
# Note: The config setting is passed internally via DuckDB settings
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'struct_settings';
----
struct_settings	[count]	[BIGINT]	Generate a sequence configured by a struct setting

# ----------------------------------------------------------------------------
# ten_thousand — No parameters, fixed 10000-row output
# Parameters: (none)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'ten_thousand';
----
ten_thousand	[]	[]	Generates 10000 integers from 0 to 9999

# ============================================================================
# Varargs
# Only constant_columns declares varargs (accepts variable number of ANY-typed args)
# ============================================================================

query TT
SELECT function_name, varargs
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table'
AND function_name IN (
    'constant_columns', 'double_sequence', 'generator_exception',
    'logging_generator', 'named_params_echo', 'nested_sequence',
    'partitioned_sequence', 'projected_data', 'repeat_value', 'sequence',
    'settings_aware', 'struct_settings', 'ten_thousand'
)
AND varargs IS NOT NULL
ORDER BY function_name, varargs;
----
constant_columns	ANY
repeat_value	BIGINT
repeat_value	VARCHAR

# ============================================================================
# Categories
# Functions declare categories for discoverability
# ============================================================================

query TT
SELECT function_name, categories
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sequence';
----
sequence	[generator, utility]

query TT
SELECT function_name, categories
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'generator_exception';
----
generator_exception	[testing]

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
