# name: test/sql/integration/table/writable_products.test
# description: Tests for INSERT with defaults, constraints, and RETURNING on writable_products
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'writable' AS writable (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', POOL false);

# ============================================================================
# Default resolution — column-subset INSERT (price, status, created_at have defaults)
# ============================================================================

# product_id + name only: price=0.0, status='draft', created_at='server-assigned'
statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (1, 'Widget');

query IRT
SELECT name, price, status FROM writable.main.writable_products WHERE name = 'Widget';
----
Widget	0.0	draft

# product_id + name + price: status defaults to 'draft'
statement ok
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (2, 'Gadget', 19.99);

query IRT
SELECT name, price, status FROM writable.main.writable_products WHERE name = 'Gadget';
----
Gadget	19.99	draft

# All columns explicit (no defaults needed)
statement ok
INSERT INTO writable.main.writable_products(product_id, name, price, status, created_at) VALUES (100, 'Explicit', 5.0, 'active', '2026-01-01');

query IIRT
SELECT product_id, name, price, status FROM writable.main.writable_products WHERE name = 'Explicit';
----
100	Explicit	5.0	active

# ============================================================================
# Defaults visible in RETURNING
# ============================================================================

# RETURNING shows default price and status
query RT
INSERT INTO writable.main.writable_products(product_id, name) VALUES (3, 'RetDefault') RETURNING price, status;
----
0.0	draft

# RETURNING with name + price: status is default
query IRT
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (4, 'RetPrice', 9.99) RETURNING name, price, status;
----
RetPrice	9.99	draft

# NOTE: NOT NULL and CHECK constraint tests are deferred — errors from the
# transactor's DuckDB propagate as IO Errors which may break subsequent
# transactor connections in the same test session.

# ============================================================================
# Multi-row INSERT with defaults
# ============================================================================

statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (10, 'Alpha'), (11, 'Beta'), (12, 'Gamma');

query I
SELECT COUNT(*) FROM writable.main.writable_products WHERE status = 'draft' AND price = 0.0 AND name IN ('Alpha', 'Beta', 'Gamma');
----
3

# ============================================================================
# Multi-row INSERT with defaults + RETURNING
# ============================================================================

query IT
INSERT INTO writable.main.writable_products(product_id, name) VALUES (20, 'Ret1'), (21, 'Ret2'), (22, 'Ret3') RETURNING product_id, name;
----
20	Ret1
21	Ret2
22	Ret3

# ============================================================================
# INSERT with mixed defaults and explicit values
# ============================================================================

query IRT
INSERT INTO writable.main.writable_products(product_id, name, status) VALUES (30, 'Custom', 'published') RETURNING name, price, status;
----
Custom	0.0	published

# ============================================================================
# RETURNING with expression
# ============================================================================

query R
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (40, 'ExprTest', 25.0) RETURNING price * 2;
----
50.0

# ============================================================================
# RETURNING column subset
# ============================================================================

query I
INSERT INTO writable.main.writable_products(product_id, name) VALUES (50, 'SubsetRet') RETURNING name;
----
SubsetRet
