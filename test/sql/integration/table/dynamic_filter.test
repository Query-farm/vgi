# name: test/sql/integration/table/dynamic_filter.test
# description: Tests dynamic filter pushdown via tick batches for Top-N queries.
#              DynamicFilter from ORDER BY ... LIMIT is sent to the worker on each
#              tick batch's custom metadata, tightening as the Top-N heap improves.
# group: [vgi_integration_table]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# EXPLAIN shows Dynamic Filter in the scan node
# ============================================================================

query II
EXPLAIN SELECT n FROM example.sequence(10000) ORDER BY n LIMIT 5;
----
physical_plan	<REGEX>:.*Dynamic Filter.*

# ============================================================================
# ASC LIMIT — correct results
# ============================================================================

query I
SELECT n FROM example.sequence(10000, batch_size := 100) ORDER BY n LIMIT 5;
----
0
1
2
3
4

# ============================================================================
# DESC LIMIT — correct results
# ============================================================================

query I
SELECT n FROM example.sequence(10000, batch_size := 100) ORDER BY n DESC LIMIT 5;
----
9999
9998
9997
9996
9995

# ============================================================================
# LIMIT with OFFSET
# ============================================================================

query I
SELECT n FROM example.sequence(10000, batch_size := 100) ORDER BY n LIMIT 5 OFFSET 10;
----
10
11
12
13
14

# ============================================================================
# LIMIT 1 — tightest possible filter
# ============================================================================

query I
SELECT n FROM example.sequence(10000, batch_size := 100) ORDER BY n LIMIT 1;
----
0

# ============================================================================
# LIMIT larger than table — all rows returned
# ============================================================================

query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(10) ORDER BY n LIMIT 100);
----
10

# ============================================================================
# VARCHAR ordering (also supported by DynamicFilter)
# ============================================================================

query I
SELECT s FROM example.filter_echo(100) ORDER BY s LIMIT 3;
----
row_0
row_1
row_10

# ============================================================================
# Multi-key ORDER BY (inclusive <= on first key)
# ============================================================================

query III
SELECT n, s, pushed_filters FROM example.filter_echo(100) ORDER BY n, s LIMIT 3;
----
0	row_0	(none)
1	row_1	(none)
2	row_2	(none)

# ============================================================================
# Regression: compare VGI result to local table
# ============================================================================

statement ok
CREATE TABLE local_seq AS SELECT * FROM example.sequence(10000);

query I
(SELECT n FROM example.sequence(10000) ORDER BY n LIMIT 5)
EXCEPT
(SELECT n FROM local_seq ORDER BY n LIMIT 5);
----

query I
(SELECT n FROM example.sequence(10000) ORDER BY n DESC LIMIT 5)
EXCEPT
(SELECT n FROM local_seq ORDER BY n DESC LIMIT 5);
----

statement ok
DROP TABLE local_seq;

# ============================================================================
# Dynamic filter echo — proves filter tightens over time
# Data is descending (9999, 9998, ..., 0), ORDER BY n ASC LIMIT 500
# forces Top-N to tighten the boundary each batch.
# With batch_size=100, each batch shifts the boundary by ~100.
# ============================================================================

# Multiple distinct filter values prove the filter tightened
query I
SELECT COUNT(DISTINCT pushed_filters) > 1 AS filter_tightened FROM (
    SELECT * FROM example.dynamic_filter_echo(10000, batch_size := 100)
    ORDER BY n LIMIT 500
);
----
true

# Correct results despite dynamic filtering
query I
SELECT COUNT(*) FROM (
    SELECT * FROM example.dynamic_filter_echo(10000, batch_size := 100) ORDER BY n LIMIT 5
);
----
5

query I
SELECT MIN(n) FROM (
    SELECT * FROM example.dynamic_filter_echo(10000, batch_size := 100) ORDER BY n LIMIT 5
);
----
0

# ============================================================================
# Combined static filter + dynamic filter on the SAME column
# DuckDB creates ConjunctionAnd(ConstantFilter(n>=500), OptionalFilter(DynamicFilter(n)))
# Both the static filter and the dynamic filter must work correctly.
# ============================================================================

# Static filter must be pushed — verify the filter text contains "n >= 500"
query I
SELECT pushed_filters FROM example.filter_echo(1000)
WHERE n >= 500
ORDER BY n LIMIT 1;
----
(n >= 500)

# Correct results: static filter narrows to [500, 999], Top-N takes first 5
query I
SELECT n FROM example.filter_echo(1000) WHERE n >= 500 ORDER BY n LIMIT 5;
----
500
501
502
503
504

# DESC with static filter
query I
SELECT n FROM example.filter_echo(1000) WHERE n >= 500 ORDER BY n DESC LIMIT 5;
----
999
998
997
996
995

# ============================================================================
# Static filter on one column, dynamic filter on another
# The s='row_5' filter must be pushed despite DynamicFilter on n
# ============================================================================

query I
SELECT pushed_filters LIKE '%row_5%' FROM example.filter_echo(100)
WHERE s = 'row_5'
ORDER BY n LIMIT 1;
----
true

# ============================================================================
# Dynamic filter tightening works alongside a static WHERE filter
#
# This is the critical test: when DuckDB creates
#   ConjunctionAnd(ConstantFilter(n >= 5000), OptionalFilter(DynamicFilter(n)))
# both the static filter (init-time) and the dynamic filter (per-tick) must
# reach the worker. The tick filters show ConstantFilter(n < ...) values
# that tighten as the Top-N heap improves.
# ============================================================================

# Multiple distinct dynamic filter values prove the per-tick filter is working
query I
SELECT COUNT(DISTINCT pushed_filters) > 1 AS filter_tightened FROM (
    SELECT * FROM example.dynamic_filter_echo(10000, batch_size := 100)
    WHERE n >= 5000
    ORDER BY n LIMIT 500
);
----
true

# The dynamic filter values must contain "ConstantFilter(n <" — proving
# the DynamicFilter was captured from inside the ConjunctionAndFilter
query I
SELECT bool_and(pushed_filters LIKE '%ConstantFilter(n <%') AS has_dynamic_bound FROM (
    SELECT DISTINCT pushed_filters FROM (
        SELECT * FROM example.dynamic_filter_echo(10000, batch_size := 100)
        WHERE n >= 5000
        ORDER BY n LIMIT 500
    )
    WHERE pushed_filters != '(none)'
);
----
true

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
