# name: test/sql/integration/table/dynamic_to_string.test
# description: dynamic_to_string callback exposes per-execution diagnostics in EXPLAIN ANALYZE
# group: [vgi_integration_table]

# DuckDB calls TableFunction::dynamic_to_string() once per parallel scan
# thread inside OperatorProfiler::FinishSource. The VGI extension surfaces:
#   - intrinsic keys (Worker, Function) read from gstate without an RPC.
#     "Rows Read" and "Threads" were intentionally removed: DuckDB already
#     prints the operator row count in the profile box, and Threads was
#     init_response.max_workers (an upper bound, not realised concurrency).
#   - user-defined keys returned by the function class's dynamic_to_string
#     hook, fetched via a unary RPC carrying the global execution_id
#
# DuckDB merges per-thread maps with last-write-wins; the last thread to
# finish wins, by which point every thread has persisted its diagnostics.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# 1. Function without an override: only intrinsic keys appear under EA.
# ============================================================================

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.sequence(1000);
----
analyzed_plan	<REGEX>:.*Function: sequence.*

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.sequence(1000);
----
analyzed_plan	<REGEX>:.*Worker: .*

# ============================================================================
# 2. Function WITH override: user keys appear post-execution.
# ============================================================================

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(500);
----
analyzed_plan	<REGEX>:.*rows_produced: 500.*

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(500);
----
analyzed_plan	<REGEX>:.*batches_emitted:.*

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(500);
----
analyzed_plan	<REGEX>:.*elapsed_ms:.*

# ============================================================================
# 3. Plain EXPLAIN (no ANALYZE) does NOT call dynamic_to_string —
#    only to_string keys appear, no rows_produced.
# ============================================================================

query II
EXPLAIN SELECT * FROM example.profiling_demo(500);
----
physical_plan	<!REGEX>:.*rows_produced.*

# ============================================================================
# 4. Early termination via LIMIT does not call FinishSource on the source
#    (the pipeline tears down via Operator-level limit instead), so
#    dynamic_to_string never fires. The query still runs cleanly — just
#    no Extra Info from our callback. Smoke-test that the query succeeds
#    and the basic to_string keys still render.
# ============================================================================

query II
EXPLAIN ANALYZE SELECT * FROM example.profiling_demo(1000000) LIMIT 10;
----
analyzed_plan	<REGEX>:.*profiling_demo.*

# ============================================================================
# 5. Parallel scan: with threads forced > 1, each thread fires
#    dynamic_to_string. Last-write-wins surfaces the all-threads-final view.
# ============================================================================

statement ok
SET threads=4;

query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(10000);
----
analyzed_plan	<REGEX>:.*rows_produced: 10000.*

# ============================================================================
# 6. Bounded-batch streaming: a large scan emits its rows in many bounded
#    batches, never a single mega-batch. profiling_demo's batches_emitted is
#    a worker-side count of out.emit() calls, so it directly witnesses that
#    the worker chunks output by batch_size rather than materialising the
#    whole result in memory. ceil(count / batch_size) batches, exactly.
#
#    batch_size is pinned explicitly in both queries below: the DEFAULT
#    batch_size is NOT part of the cross-language worker contract (Python/Go
#    default to 1000, Java to 1024, Rust/TypeScript to 2048), so asserting a
#    batch-count value against the default would only hold for some workers.
#    Pinning batch_size makes the count well-defined for every implementation.
#    The two row-counts below are exact multiples of their batch_size, so the
#    count is unambiguous (no partial final batch to round).
#
#    profiling_demo is @init_single_worker, so the count is stable regardless
#    of `threads`. Transport-agnostic: identical over subprocess and HTTP
#    (HTTP just pays a round-trip per batch — same batch count, more latency).
# ============================================================================

statement ok
SET threads=1;

# 1,000,000 rows in batches of 1000 = 1000 batches (not one mega-batch).
query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(1000000, batch_size := 1000);
----
analyzed_plan	<REGEX>:.*batches_emitted: 1000\b.*

# Same row count, larger batch_size: the batch count tracks ceil(count /
# batch_size) = 4, proving the chunking is genuine, not coincidental.
query II
EXPLAIN ANALYZE SELECT count(*) FROM example.profiling_demo(1000000, batch_size := 250000);
----
analyzed_plan	<REGEX>:.*batches_emitted: 4\b.*
