# name: test/sql/integration/table/sequence/edge_cases.test
# description: Edge case tests for VGI sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Edge case: Zero rows (count=0)
# Should return empty result, no batches produced
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM example.sequence(0, 1000);
----
0

query I
SELECT COUNT(*) FROM example.sequence(0, 1);
----
0

query I
SELECT SUM(n) FROM example.sequence(0, 100);
----
NULL

# ----------------------------------------------------------------------------
# Edge case: Single row (count=1)
# Minimal non-empty result
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sequence(1, 1000);
----
0

query I
SELECT * FROM example.sequence(1, 1);
----
0

query I
SELECT COUNT(*) FROM example.sequence(1, 10000);
----
1

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
