# name: test/sql/integration/table/sequence/basic.test
# description: Basic tests for VGI sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sequence function
# Generates integers 0 to count-1, with optional increment (named arg)
# Args: count (int), batch_size (int, default=1000), increment (named, default=1)
# ============================================================================

# Basic sequence generation
query I
SELECT * FROM example.sequence(5, 1000);
----
0
1
2
3
4

# Verify count
query I
SELECT COUNT(*) FROM example.sequence(100, 10);
----
100

# Verify values
query II
SELECT MIN(n), MAX(n) FROM example.sequence(100, 10);
----
0	99

# Verify sum
query I
SELECT SUM(n) FROM example.sequence(10, 10);
----
45

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
