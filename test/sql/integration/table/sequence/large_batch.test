# name: test/sql/integration/table/sequence/large_batch.test
# description: Test batches exceeding STANDARD_VECTOR_SIZE (2048)
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Single batch larger than STANDARD_VECTOR_SIZE (2048)
# Forces the extension to handle oversized batches via pending_output
# ----------------------------------------------------------------------------

# batch_size=5000 > 2048 (STANDARD_VECTOR_SIZE)
query I
SELECT COUNT(*) FROM example.sequence(5000, 5000);
----
5000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(5000, 5000);
----
0	4999

query I
SELECT SUM(n) FROM example.sequence(5000, 5000);
----
12497500

# batch_size=10000, multiple oversized batches
query I
SELECT COUNT(*) FROM example.sequence(25000, 10000);
----
25000

query II
SELECT MIN(n), MAX(n) FROM example.sequence(25000, 10000);
----
0	24999

# batch_size=3000 (just above 2048), many batches
query I
SELECT COUNT(*) FROM example.sequence(9000, 3000);
----
9000

query I
SELECT SUM(n) FROM example.sequence(9000, 3000);
----
40495500

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
