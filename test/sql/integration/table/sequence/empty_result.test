# name: test/sql/integration/table/sequence/empty_result.test
# description: Test functions that return 0 rows
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Empty result set (0-row output)
# Verifies the extension handles empty output without crashing
# ----------------------------------------------------------------------------

# sequence(0, ...) should produce zero rows
query I
SELECT COUNT(*) FROM example.sequence(0, batch_size := 1000);
----
0

# Aggregates on empty result
query I
SELECT SUM(n) FROM example.sequence(0, batch_size := 1000);
----
NULL

query I
SELECT MIN(n) FROM example.sequence(0, batch_size := 100);
----
NULL

# Empty result in subquery
query I
SELECT COUNT(*) FROM (SELECT * FROM example.sequence(0, batch_size := 10)) sub;
----
0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
