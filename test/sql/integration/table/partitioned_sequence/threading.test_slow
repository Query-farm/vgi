# name: test/sql/integration/table/partitioned_sequence/threading.test_slow
# description: Threading tests for VGI partitioned_sequence table function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

require json

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Enable logging for worker verification
statement ok
CALL enable_logging(level := 'debug');

# ============================================================================
# Single-threaded execution (threads=1)
# Verifies correctness when only one worker can be used
# Using smaller sizes (10K) since single-threaded is slower
# ============================================================================

statement ok
SET threads=1;

# Correctness test
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Sum verification (no gaps)
query I
SELECT SUM(n) = (10000::BIGINT * 9999 / 2) as sum_correct
FROM example.partitioned_sequence(10000);
----
true

# Worker count verification - truncate logs, run query, check PID count
statement ok
CALL truncate_duckdb_logs();

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(10000);
----
10000	10000	0	9999

# Verify only one worker was used (single PID in batch_received logs)
query I
SELECT COUNT(DISTINCT regexp_extract(message, 'worker_pid=(\d+)', 1)) = 1
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%batch_received%';
----
true

# ============================================================================
# Multi-threaded execution (threads=4)
# Verifies correctness and multi-worker usage with parallelism
# ============================================================================

statement ok
SET threads=4;

# Worker count verification - truncate logs, run query, check PID count
statement ok
CALL truncate_duckdb_logs();

# 100K with 4 threads - should use multiple workers
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(100000);
----
100000	100000	0	99999

# Verify multiple workers were used (at least 2 PIDs in batch_received logs)
query I
SELECT COUNT(DISTINCT regexp_extract(message, 'worker_pid=(\d+)', 1)) >= 2
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%batch_received%';
----
true

# Sum verification (no gaps even with parallel execution)
query I
SELECT SUM(n) = (100000::BIGINT * 99999 / 2) as sum_correct
FROM example.partitioned_sequence(100000);
----
true

# ============================================================================
# Thread scaling verification
# ============================================================================

# 2 threads
statement ok
SET threads=2;

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# 8 threads
statement ok
SET threads=8;

query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM example.partitioned_sequence(20000);
----
20000	20000	0	19999

# Reset to default
statement ok
RESET threads;

# ----------------------------------------------------------------------------
# Cleanup
# ----------------------------------------------------------------------------

statement ok
DETACH example;
