# name: test/sql/integration/copy_from/secrets.test
# description: COPY ... FROM forwards CREATE SECRET credentials to the worker reader (two-phase secret bind)
# group: [vgi_integration_copy_from]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS acme (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# The secret-forwarding reader is advertised like any other COPY FROM format.
query TTT
SELECT catalog_name, format_name, direction
FROM vgi_copy_formats()
WHERE catalog_name = 'acme' AND format_name = 'acme.secret_lines_in' AND option_name = 'secret_type';
----
acme	acme.secret_lines_in	from

# A dummy source file (the reader ignores its contents — it emits the secret).
statement ok
COPY (SELECT 'x') TO '__TEST_DIR__/copy_from_secret.src' (FORMAT csv, HEADER false);

# ============================================================================
# A CREATE SECRET scoped to the source path is forwarded to the worker reader.
# read() emits the resolved api_key, proving the caller's secret reached it.
# ============================================================================

statement ok
CREATE SECRET reader_creds (TYPE vgi_example, secret_string 's', api_key 'READER_KEY', port 1, use_ssl true, timeout 1.0, SCOPE '__TEST_DIR__/copy_from_secret.src');

statement ok
CREATE TABLE got (k VARCHAR);

statement ok
COPY got FROM '__TEST_DIR__/copy_from_secret.src' (FORMAT 'acme.secret_lines_in');

query T
SELECT k FROM got;
----
READER_KEY

# ============================================================================
# No matching secret → silent miss (NONE), not an error.
# ============================================================================

statement ok
COPY (SELECT 'x') TO '__TEST_DIR__/copy_from_nosecret.src' (FORMAT csv, HEADER false);

statement ok
CREATE TABLE got2 (k VARCHAR);

statement ok
COPY got2 FROM '__TEST_DIR__/copy_from_nosecret.src' (FORMAT 'acme.secret_lines_in');

query T
SELECT k FROM got2;
----
NONE

statement ok
DROP SECRET reader_creds;

statement ok
DETACH acme;
