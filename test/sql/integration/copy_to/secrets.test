# name: test/sql/integration/copy_to/secrets.test
# description: COPY ... TO forwards CREATE SECRET credentials to the worker writer (two-phase secret bind)
# group: [vgi_integration_copy_to]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS acme (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# The secret-forwarding writer is advertised like any other COPY TO format.
query TTT
SELECT catalog_name, format_name, direction
FROM vgi_copy_formats()
WHERE catalog_name = 'acme' AND format_name = 'acme.secret_lines_out' AND option_name = 'secret_type';
----
acme	acme.secret_lines_out	to

# ============================================================================
# A CREATE SECRET scoped to the destination path is forwarded to the worker.
# The writer's on_secrets() hook requests a vgi_example secret scoped by the
# destination path; the framework's two-phase bind resolves it and surfaces it
# at close(), which writes the resolved api_key into the file.
# ============================================================================

statement ok
CREATE SECRET writer_creds (TYPE vgi_example, secret_string 's', api_key 'FORWARDED_KEY', port 1, use_ssl true, timeout 1.0, SCOPE '__TEST_DIR__/copy_to_secret.bin');

query I
COPY (SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))
TO '__TEST_DIR__/copy_to_secret.bin' (FORMAT 'acme.secret_lines_out');
----
3

# The worker received the caller's secret and wrote its api_key + row count.
query TT
SELECT regexp_extract(content, 'api_key=([^\n]*)', 1),
       regexp_extract(content, 'rows=([0-9]*)', 1)
FROM read_text('__TEST_DIR__/copy_to_secret.bin');
----
FORWARDED_KEY	3

# ============================================================================
# No matching secret → the lookup is a silent miss (api_key=NONE), not an error.
# A distinct destination path means the scoped secret above does not match.
# ============================================================================

query I
COPY (SELECT * FROM (VALUES (9, 'z')) t(x, y))
TO '__TEST_DIR__/copy_to_nosecret.bin' (FORMAT 'acme.secret_lines_out');
----
1

query TT
SELECT regexp_extract(content, 'api_key=([^\n]*)', 1),
       regexp_extract(content, 'rows=([0-9]*)', 1)
FROM read_text('__TEST_DIR__/copy_to_nosecret.bin');
----
NONE	1

# ============================================================================
# Parallel sharded sink: each per-thread worker (and the combine worker) must
# receive the forwarded secret. Larger input + multiple threads fans out shards.
# ============================================================================

statement ok
SET threads = 4;

statement ok
CREATE SECRET writer_creds_par (TYPE vgi_example, secret_string 's', api_key 'PAR_KEY', port 1, use_ssl true, timeout 1.0, SCOPE '__TEST_DIR__/copy_to_secret_par.bin');

query I
COPY (SELECT * FROM range(5000) t(x)) TO '__TEST_DIR__/copy_to_secret_par.bin' (FORMAT 'acme.secret_lines_out');
----
5000

query TT
SELECT regexp_extract(content, 'api_key=([^\n]*)', 1),
       regexp_extract(content, 'rows=([0-9]*)', 1)
FROM read_text('__TEST_DIR__/copy_to_secret_par.bin');
----
PAR_KEY	5000

statement ok
DROP SECRET writer_creds_par;

statement ok
DROP SECRET writer_creds;

statement ok
DETACH acme;
