# name: test/sql/integration/filter_pushdown/hugeint.test
# description: Differential filter-pushdown tests for HUGEINT and UHUGEINT.
#   Both serialise through canonical Arrow extension types
#   (`DuckDB.hugeint` / `DuckDB.uhugeint`,
#   vgi/duckdb/src/common/arrow/arrow_type_extension.cpp:558-560).
#   Same kernel-mismatch failure mode as bool8/UUID; same
#   normalisation in the worker fixes it. This pins the behavior plus
#   the boundary values that exceed signed/unsigned 64-bit ranges
#   where naive numeric coercion would silently overflow.
#
#   Coverage: full comparison set (=, !=, <, >, <=, >=), IN, IS NULL,
#   plus Int128 boundary literals.
#
# group: [vgi_integration_filter_pushdown]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# HUGEINT — equality and ordered comparisons
# ============================================================================

# Note: the literal max HUGEINT (2^127-1, 39 digits) trips a separate
# data-path bug in echo's RETURN serialisation
# (decimal128(38,0) can't hold 39 digits) — independent of filter
# pushdown. We avoid that boundary here and exercise it specifically
# below with a value that fits in decimal128(38,0).
query II
SELECT n, h FROM (VALUES
  (1, 100::HUGEINT),
  (2, 200::HUGEINT),
  (3, NULL::HUGEINT),
  (4, 999999999::HUGEINT)
) t(n, h)
WHERE h = 200::HUGEINT ORDER BY n;
----
2	200

query II
SELECT n, h FROM example.echo((SELECT * FROM (VALUES
  (1, 100::HUGEINT),
  (2, 200::HUGEINT),
  (3, NULL::HUGEINT),
  (4, 999999999::HUGEINT)
) v(n, h)))
WHERE h = 200::HUGEINT ORDER BY n;
----
2	200

# Boundary: large value past int64 max — exercises the int128 storage path.
# Note: the literal max HUGEINT (2^127-1, 39 digits) trips a separate
# data-path bug in echo's return serialisation
# (decimal128(38,0) can't hold 39 digits), unrelated to filter pushdown.
# Use a value safely inside decimal128(38,0) to keep this test focused.
query II
SELECT n, h FROM (VALUES
  (1, 100::HUGEINT),
  (2, 99999999999999999999999999999999999999::HUGEINT)
) t(n, h)
WHERE h = 99999999999999999999999999999999999999::HUGEINT;
----
2	99999999999999999999999999999999999999

query II
SELECT n, h FROM example.echo((SELECT * FROM (VALUES
  (1, 100::HUGEINT),
  (2, 99999999999999999999999999999999999999::HUGEINT)
) v(n, h)))
WHERE h = 99999999999999999999999999999999999999::HUGEINT;
----
2	99999999999999999999999999999999999999

# Range comparison — > beyond int64 max
query II
SELECT n, h FROM (VALUES
  (1, 9223372036854775807::HUGEINT),
  (2, 9223372036854775808::HUGEINT),
  (3, 18446744073709551616::HUGEINT)
) t(n, h)
WHERE h > 9223372036854775807::HUGEINT ORDER BY n;
----
2	9223372036854775808
3	18446744073709551616

query II
SELECT n, h FROM example.echo((SELECT * FROM (VALUES
  (1, 9223372036854775807::HUGEINT),
  (2, 9223372036854775808::HUGEINT),
  (3, 18446744073709551616::HUGEINT)
) v(n, h)))
WHERE h > 9223372036854775807::HUGEINT ORDER BY n;
----
2	9223372036854775808
3	18446744073709551616

# IN
query II
SELECT n, h FROM (VALUES (1, 100::HUGEINT), (2, 200::HUGEINT), (3, 300::HUGEINT)) t(n, h)
WHERE h IN (100::HUGEINT, 300::HUGEINT) ORDER BY n;
----
1	100
3	300

query II
SELECT n, h FROM example.echo((SELECT * FROM (VALUES (1, 100::HUGEINT), (2, 200::HUGEINT), (3, 300::HUGEINT)) v(n, h)))
WHERE h IN (100::HUGEINT, 300::HUGEINT) ORDER BY n;
----
1	100
3	300

# ============================================================================
# UHUGEINT — equality + boundary
# ============================================================================

# Note: UHUGEINT max (2^128-1, 39 digits) hits the same return-path
# decimal128(38,0) overflow as HUGEINT max. Use a value that fits.
query II
SELECT n, h FROM (VALUES
  (1, 0::UHUGEINT),
  (2, 1::UHUGEINT),
  (3, 99999999999999999999999999999999999999::UHUGEINT)
) t(n, h)
WHERE h = 99999999999999999999999999999999999999::UHUGEINT;
----
3	99999999999999999999999999999999999999

query II
SELECT n, h FROM example.echo((SELECT * FROM (VALUES
  (1, 0::UHUGEINT),
  (2, 1::UHUGEINT),
  (3, 99999999999999999999999999999999999999::UHUGEINT)
) v(n, h)))
WHERE h = 99999999999999999999999999999999999999::UHUGEINT;
----
3	99999999999999999999999999999999999999
