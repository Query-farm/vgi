# name: test/sql/integration/scalar/add_values.test
# description: Tests for VGI add_values scalar function
# group: [vgi_integration_scalar]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# add_values function
# Adds two numeric columns together
# Args: col1 (numeric), col2 (numeric)
# Returns: numeric (sum, promoted type)
# ============================================================================

# ============================================================================
# Basic integer tests
# ============================================================================

query I
SELECT example.add_values(1, 2);
----
3

query I
SELECT example.add_values(10, 20);
----
30

query I
SELECT example.add_values(0, 0);
----
0

query I
SELECT example.add_values(-5, 10);
----
5

query I
SELECT example.add_values(-10, -5);
----
-15

# ============================================================================
# Multiple rows from table
# ============================================================================

query I
SELECT example.add_values(a, b) FROM (VALUES (1, 10), (2, 20), (3, 30)) t(a, b);
----
11
22
33

query I
SELECT example.add_values(x, y) FROM (VALUES (5, 5), (10, 10), (15, 15)) t(x, y) ORDER BY x;
----
10
20
30

# ============================================================================
# Larger datasets
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.add_values(i::INTEGER, i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.add_values(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# All should equal 100 (i + (100 - i) = 100)
query I
SELECT COUNT(*) FROM (
    SELECT example.add_values(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE result = 100;
----
50

# ============================================================================
# Integration with other SQL operations
# ============================================================================

query III
SELECT a, b, example.add_values(a, b) AS sum
FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)
ORDER BY a;
----
1	2	3
3	4	7
5	6	11

query I
SELECT SUM(example.add_values(a, b)) FROM (VALUES (1, 1), (2, 2), (3, 3)) t(a, b);
----
12

# ============================================================================
# With expressions
# ============================================================================

query I
SELECT example.add_values(10 + 5, 20 + 5);
----
40

query I
SELECT example.add_values(x * 2, y * 3) FROM (VALUES (5, 10)) t(x, y);
----
40

# ============================================================================
# Type-specific tests
# ============================================================================

# INTEGER + INTEGER
query I
SELECT example.add_values(100::INTEGER, 200::INTEGER);
----
300

# BIGINT + BIGINT
query I
SELECT example.add_values(1000::BIGINT, 2000::BIGINT);
----
3000

# DOUBLE + DOUBLE
query R
SELECT example.add_values(1.5::DOUBLE, 2.5::DOUBLE);
----
4.0

query R
SELECT example.add_values(3.14::DOUBLE, 2.86::DOUBLE);
----
6.0

# FLOAT + FLOAT
query R
SELECT example.add_values(1.25::FLOAT, 2.75::FLOAT);
----
4.0

# Mixed precision (both promoted)
query R
SELECT example.add_values(1::INTEGER, 2.5::DOUBLE);
----
3.5

# ============================================================================
# Return type validation (ANY type resolution via on_bind)
# add_values uses ArrowAny for both input params and the output. The worker's
# on_bind finds the common type of both inputs, then promotes it one size up
# for overflow safety. These tests ensure the type resolution is correct.
# ============================================================================

# INTEGER + INTEGER -> common int32, promoted to BIGINT (int64)
query I
SELECT typeof(example.add_values(1::INTEGER, 2::INTEGER));
----
BIGINT

# BIGINT + BIGINT -> common int64, promoted to BIGINT (int64, no further promotion)
query I
SELECT typeof(example.add_values(1::BIGINT, 2::BIGINT));
----
BIGINT

# SMALLINT + SMALLINT -> common int16, promoted to INTEGER (int32)
query I
SELECT typeof(example.add_values(1::SMALLINT, 2::SMALLINT));
----
INTEGER

# TINYINT + TINYINT -> common int8, promoted to SMALLINT (int16)
query I
SELECT typeof(example.add_values(1::TINYINT, 2::TINYINT));
----
SMALLINT

# DOUBLE + DOUBLE -> common float64, no promotion for floats -> DOUBLE
query I
SELECT typeof(example.add_values(1.0::DOUBLE, 2.0::DOUBLE));
----
DOUBLE

# FLOAT + FLOAT -> common float32, promoted to float64 -> DOUBLE
query I
SELECT typeof(example.add_values(1.0::FLOAT, 2.0::FLOAT));
----
DOUBLE

# Mixed: INTEGER + DOUBLE -> common float64 (Arrow upcasts int32 to float64), promoted to DOUBLE
query I
SELECT typeof(example.add_values(1::INTEGER, 2.5::DOUBLE));
----
DOUBLE

# Mixed: SMALLINT + BIGINT -> common int64, promoted to BIGINT
query I
SELECT typeof(example.add_values(1::SMALLINT, 2::BIGINT));
----
BIGINT

# Mixed: INTEGER + BIGINT -> common int64, promoted to BIGINT
query I
SELECT typeof(example.add_values(1::INTEGER, 2::BIGINT));
----
BIGINT

# Note: typeof() with NULL args returns "NULL" because DuckDB short-circuits
# scalar NULLs before the worker bind resolves the output type

# ============================================================================
# NULL handling
# ============================================================================

# First argument NULL
query I
SELECT example.add_values(NULL::INTEGER, 10);
----
NULL

# Second argument NULL
query I
SELECT example.add_values(10, NULL::INTEGER);
----
NULL

# Both arguments NULL (need cast for type inference)
query I
SELECT example.add_values(NULL::INTEGER, NULL::INTEGER);
----
NULL

# Mixed NULL and non-NULL in batch
query I
SELECT example.add_values(a, b) FROM (VALUES (1, 2), (NULL, 3), (4, NULL), (5, 6)) t(a, b);
----
3
NULL
NULL
11

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.add_values(a, b) AS result
    FROM (VALUES (1, 1), (NULL, 2), (3, NULL), (4, 4)) t(a, b)
) WHERE result IS NOT NULL;
----
2

# ============================================================================
# Zero combinations
# ============================================================================

query I
SELECT example.add_values(0, 100);
----
100

query I
SELECT example.add_values(100, 0);
----
100

query I
SELECT example.add_values(0, -100);
----
-100

query R
SELECT example.add_values(0.0::DOUBLE, 3.14::DOUBLE);
----
3.14

# ============================================================================
# Opposite signs (cancellation)
# ============================================================================

query I
SELECT example.add_values(100, -100);
----
0

query I
SELECT example.add_values(-50, 50);
----
0

query R
SELECT example.add_values(3.14::DOUBLE, -3.14::DOUBLE);
----
0.0

query R
SELECT example.add_values(-1.5::DOUBLE, 1.5::DOUBLE);
----
0.0

# ============================================================================
# Large values
# ============================================================================

query I
SELECT example.add_values(1000000000::BIGINT, 1000000000::BIGINT);
----
2000000000

query I
SELECT example.add_values(999999999::BIGINT, 1::BIGINT);
----
1000000000

query I
SELECT example.add_values(-1000000000::BIGINT, -1000000000::BIGINT);
----
-2000000000

# Large positive + large negative
query I
SELECT example.add_values(1000000000::BIGINT, -999999999::BIGINT);
----
1

# ============================================================================
# Small decimal values
# ============================================================================

query R
SELECT example.add_values(0.001::DOUBLE, 0.002::DOUBLE);
----
0.003

query R
SELECT example.add_values(0.0001::DOUBLE, 0.0002::DOUBLE);
----
0.0003

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
