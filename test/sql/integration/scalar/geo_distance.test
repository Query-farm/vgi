# name: test/sql/integration/scalar/geo_distance.test
# description: Tests for VGI geo_distance scalar functions (struct, list, fixed-size list)
# group: [vgi_integration_scalar]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# example.geo_distance_struct — Euclidean distance between struct points
# ============================================================================

# Basic 3-4-5 triangle
query R
SELECT round(example.geo_distance_struct(
    {lat: 0.0, lon: 0.0}::STRUCT(lat DOUBLE, lon DOUBLE),
    {lat: 3.0, lon: 4.0}::STRUCT(lat DOUBLE, lon DOUBLE)
), 2);
----
5.0

# Zero distance (same point)
query R
SELECT round(example.geo_distance_struct(
    {lat: 1.5, lon: 2.5}::STRUCT(lat DOUBLE, lon DOUBLE),
    {lat: 1.5, lon: 2.5}::STRUCT(lat DOUBLE, lon DOUBLE)
), 2);
----
0.0

# Multiple rows from table
query R
SELECT round(example.geo_distance_struct(
    {lat: a, lon: b}::STRUCT(lat DOUBLE, lon DOUBLE),
    {lat: c, lon: d}::STRUCT(lat DOUBLE, lon DOUBLE)
), 2)
FROM (VALUES (0.0, 0.0, 3.0, 4.0), (1.0, 1.0, 4.0, 5.0), (0.0, 0.0, 0.0, 0.0)) t(a, b, c, d);
----
5.0
5.0
0.0

# ============================================================================
# example.geo_distance_list — Euclidean distance between list points
# ============================================================================

# Basic 3-4-5 triangle
query R
SELECT round(example.geo_distance_list(
    [0.0, 0.0],
    [3.0, 4.0]
), 2);
----
5.0

# Zero distance
query R
SELECT round(example.geo_distance_list(
    [1.5, 2.5],
    [1.5, 2.5]
), 2);
----
0.0

# Multiple rows from table
query R
SELECT round(example.geo_distance_list(
    [a, b],
    [c, d]
), 2)
FROM (VALUES (0.0, 0.0, 3.0, 4.0), (1.0, 1.0, 4.0, 5.0), (0.0, 0.0, 0.0, 0.0)) t(a, b, c, d);
----
5.0
5.0
0.0

# ============================================================================
# example.geo_distance_fixed — Euclidean distance between fixed-size list points
# ============================================================================

# Basic 3-4-5 triangle
query R
SELECT round(example.geo_distance_fixed(
    [0.0, 0.0]::DOUBLE[2],
    [3.0, 4.0]::DOUBLE[2]
), 2);
----
5.0

# Zero distance
query R
SELECT round(example.geo_distance_fixed(
    [1.5, 2.5]::DOUBLE[2],
    [1.5, 2.5]::DOUBLE[2]
), 2);
----
0.0

# Multiple rows from table
query R
SELECT round(example.geo_distance_fixed(
    [a, b]::DOUBLE[2],
    [c, d]::DOUBLE[2]
), 2)
FROM (VALUES (0.0, 0.0, 3.0, 4.0), (1.0, 1.0, 4.0, 5.0), (0.0, 0.0, 0.0, 0.0)) t(a, b, c, d);
----
5.0
5.0
0.0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
