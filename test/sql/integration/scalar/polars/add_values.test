# name: test/sql/integration/scalar/polars/add_values.test
# description: Tests for VGI polars_add_values scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# polars_add_values function
# Adds two numeric values using Polars
# Args: left (float64), right (float64)
# Returns: float64 (sum)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic addition tests
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(1, 2);
----
3.0

query R
SELECT example.polars_add_values(10, 20);
----
30.0

query R
SELECT example.polars_add_values(0, 0);
----
0.0

query R
SELECT example.polars_add_values(-5, 10);
----
5.0

query R
SELECT example.polars_add_values(-10, -5);
----
-15.0

# ----------------------------------------------------------------------------
# Floating point values
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(1.5, 2.5);
----
4.0

query R
SELECT example.polars_add_values(3.14, 2.86);
----
6.0

query R
SELECT example.polars_add_values(0.1, 0.2);
----
0.3

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(a, b) FROM (VALUES (1, 10), (2, 20), (3, 30)) t(a, b);
----
11.0
22.0
33.0

query R
SELECT example.polars_add_values(x, y) FROM (VALUES (5, 5), (10, 10), (15, 15)) t(x, y);
----
10.0
20.0
30.0

# ----------------------------------------------------------------------------
# Zero combinations
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(0, 100);
----
100.0

query R
SELECT example.polars_add_values(100, 0);
----
100.0

query R
SELECT example.polars_add_values(0, -100);
----
-100.0

# ----------------------------------------------------------------------------
# Opposite signs (cancellation)
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(100, -100);
----
0.0

query R
SELECT example.polars_add_values(-50, 50);
----
0.0

query R
SELECT example.polars_add_values(3.14, -3.14);
----
0.0

# ----------------------------------------------------------------------------
# Large values
# ----------------------------------------------------------------------------

query R
SELECT example.polars_add_values(1000000, 1000000);
----
2000000.0

query R
SELECT example.polars_add_values(999999999, 1);
----
1000000000.0

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.polars_add_values(i::DOUBLE, i::DOUBLE) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

# All should equal 100 (i + (100 - i) = 100)
query I
SELECT COUNT(*) FROM (
    SELECT example.polars_add_values(i::DOUBLE, (100 - i)::DOUBLE) AS result
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE result = 100.0;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query R
SELECT SUM(example.polars_add_values(a, b)) FROM (VALUES (1, 1), (2, 2), (3, 3)) t(a, b);
----
12.0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
