# name: test/sql/integration/scalar/polars/double.test
# description: Tests for VGI polars_double scalar function
# group: [vgi]

require-env VGI_TEST_POLARS_WORKER

require vgi

statement ok
ATTACH 'example_polars' AS example (TYPE vgi, LOCATION '${VGI_TEST_POLARS_WORKER}');

# ============================================================================
# polars_double function
# Doubles numeric values using Polars, preserving input type
# Args: value (numeric - integer or float)
# Returns: numeric (same type as input)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic integer tests
# ----------------------------------------------------------------------------

query I
SELECT example.polars_double(1);
----
2

query I
SELECT example.polars_double(21);
----
42

query I
SELECT example.polars_double(0);
----
0

query I
SELECT example.polars_double(-5);
----
-10

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.polars_double(x) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
2
4
6
8
10

query I
SELECT example.polars_double(val) FROM (VALUES (10), (20), (30)) t(val) ORDER BY val;
----
20
40
60

# ----------------------------------------------------------------------------
# Floating point values
# ----------------------------------------------------------------------------

query R
SELECT example.polars_double(3.14::DOUBLE);
----
6.28

query R
SELECT example.polars_double(2.5::DOUBLE);
----
5.0

query R
SELECT example.polars_double(1.5::FLOAT);
----
3.0

# ----------------------------------------------------------------------------
# Negative numbers
# ----------------------------------------------------------------------------

query I
SELECT example.polars_double(-100);
----
-200

query R
SELECT example.polars_double(-3.14::DOUBLE);
----
-6.28

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.polars_double(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

# Verify values are correct
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.polars_double(i::INTEGER) AS doubled
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE doubled = val * 2;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query II
SELECT val, example.polars_double(val) AS doubled
FROM (VALUES (5), (10), (15)) t(val)
ORDER BY val;
----
5	10
10	20
15	30

query I
SELECT SUM(example.polars_double(x)) FROM (VALUES (1), (2), (3)) t(x);
----
12

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
