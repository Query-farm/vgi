# name: test/sql/integration/scalar/polars/upper_case.test
# description: Tests for VGI polars_upper_case scalar function
# group: [vgi]

require-env VGI_TEST_POLARS_WORKER

require vgi

statement ok
ATTACH 'example_polars' AS example (TYPE vgi, LOCATION '${VGI_TEST_POLARS_WORKER}');

# ============================================================================
# polars_upper_case function
# Converts strings to uppercase using Polars
# Args: text (string)
# Returns: string (uppercase)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic uppercase tests
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('hello');
----
HELLO

query I
SELECT example.polars_upper_case('world');
----
WORLD

query I
SELECT example.polars_upper_case('Hello World');
----
HELLO WORLD

query I
SELECT example.polars_upper_case('');
----
(empty)

# ----------------------------------------------------------------------------
# Already uppercase
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('HELLO');
----
HELLO

query I
SELECT example.polars_upper_case('ABC123');
----
ABC123

# ----------------------------------------------------------------------------
# Mixed case
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('HeLLo WoRLd');
----
HELLO WORLD

query I
SELECT example.polars_upper_case('camelCase');
----
CAMELCASE

query I
SELECT example.polars_upper_case('snake_case');
----
SNAKE_CASE

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case(s) FROM (VALUES ('hello'), ('world'), ('test')) t(s);
----
HELLO
WORLD
TEST

query I
SELECT example.polars_upper_case(word) FROM (VALUES ('cat'), ('dog'), ('bird')) t(word);
----
CAT
DOG
BIRD

# ----------------------------------------------------------------------------
# Special characters (should pass through unchanged)
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('hello!');
----
HELLO!

query I
SELECT example.polars_upper_case('test@123');
----
TEST@123

query I
SELECT example.polars_upper_case('a-b-c');
----
A-B-C

# ----------------------------------------------------------------------------
# Whitespace handling
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('hello world');
----
HELLO WORLD

query I
SELECT example.polars_upper_case(' hello');
----
 HELLO

# ----------------------------------------------------------------------------
# Numbers (should pass through unchanged)
# ----------------------------------------------------------------------------

query I
SELECT example.polars_upper_case('123');
----
123

query I
SELECT example.polars_upper_case('abc123xyz');
----
ABC123XYZ

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.polars_upper_case(s) AS upper
    FROM (VALUES ('one'), ('two'), ('three'), ('four'), ('five')) t(s)
) WHERE upper = UPPER(upper);
----
5

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query II
SELECT s, example.polars_upper_case(s) AS upper
FROM (VALUES ('hi'), ('hello'), ('greetings')) t(s)
ORDER BY s;
----
greetings	GREETINGS
hello	HELLO
hi	HI

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
