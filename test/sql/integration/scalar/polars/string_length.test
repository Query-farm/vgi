# name: test/sql/integration/scalar/polars/string_length.test
# description: Tests for VGI polars_string_length scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# polars_string_length function
# Returns the length of a string using Polars
# Args: text (string)
# Returns: uint32 (length in characters)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic string length tests
# ----------------------------------------------------------------------------

query I
SELECT example.polars_string_length('hello');
----
5

query I
SELECT example.polars_string_length('');
----
0

query I
SELECT example.polars_string_length('a');
----
1

query I
SELECT example.polars_string_length('hello world');
----
11

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.polars_string_length(s) FROM (VALUES ('a'), ('bb'), ('ccc')) t(s);
----
1
2
3

query I
SELECT example.polars_string_length(word) FROM (VALUES ('cat'), ('dog'), ('elephant')) t(word);
----
3
3
8

# ----------------------------------------------------------------------------
# Special characters and whitespace
# ----------------------------------------------------------------------------

query I
SELECT example.polars_string_length('  ');
----
2

query I
SELECT example.polars_string_length('tab	here');
----
8

query I
SELECT example.polars_string_length('line
break');
----
10

# ----------------------------------------------------------------------------
# Longer strings
# ----------------------------------------------------------------------------

query I
SELECT example.polars_string_length('the quick brown fox jumps over the lazy dog');
----
43

query I
SELECT example.polars_string_length(repeat('x', 100));
----
100

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.polars_string_length(s) AS len
    FROM (VALUES ('one'), ('two'), ('three'), ('four'), ('five')) t(s)
) WHERE len > 0;
----
5

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query II
SELECT s, example.polars_string_length(s) AS len
FROM (VALUES ('hi'), ('hello'), ('greetings')) t(s)
ORDER BY s;
----
greetings	9
hello	5
hi	2

query I
SELECT SUM(example.polars_string_length(s)) FROM (VALUES ('a'), ('bb'), ('ccc')) t(s);
----
6

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
