# name: test/sql/integration/scalar/per_value_edge.test
# description: Scalar per-value memoization edge cases: const-param keying (two calls with the
#   same value but different const args must NOT cross-serve), NULL + VARCHAR output round-trip
#   through the cache, and the per-chunk store cap (bounded amplification, correctness preserved).
# group: [vgi_integration_scalar]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET threads=1;

statement ok
SELECT * FROM vgi_result_cache_flush();

# ---------------------------------------------------------------------------
# Const-param keying: cached_add_const(v, K) folds K into the cache key, so the same
# distinct values under a DIFFERENT const addend must not reuse the wrong entries.
# ---------------------------------------------------------------------------

# distinct {0,1,2}+10 = {10,11,12} over 6 rows → (10+11+12)*2 = 66
query I
SELECT sum(ex.cached_add_const(x % 3, 10))::BIGINT FROM range(6) t(x);
----
66

# SAME distinct values {0,1,2} but +20 → {20,21,22}. If the const arg weren't in the key,
# this would cross-serve the +10 entries (→ 66). Correct = (20+21+22)*2 = 126.
query I
SELECT sum(ex.cached_add_const(x % 3, 20))::BIGINT FROM range(6) t(x);
----
126

# Repeat the +10 call over a different chunk → per-value hit with the +10 results (99), not +20.
query I
SELECT sum(ex.cached_add_const(x % 3, 10))::BIGINT FROM range(9) t(x);
----
99

# Repeat the +20 call → its own results, 189.
query I
SELECT sum(ex.cached_add_const(x % 3, 20))::BIGINT FROM range(9) t(x);
----
189

# ---------------------------------------------------------------------------
# NULL + VARCHAR round-trip: cached_label(x) = 'lbl-<x>' for x>=0, NULL for negatives.
# A cached per-value entry must round-trip both a heap string and a NULL.
# ---------------------------------------------------------------------------

statement ok
SELECT * FROM vgi_result_cache_flush();

# Cold: distinct {-1,0,1,2} → {NULL, lbl-0, lbl-1, lbl-2}.
query II
SELECT count(*), count(ex.cached_label(x))
FROM (VALUES (-1::BIGINT), (0::BIGINT), (1::BIGINT), (2::BIGINT), (-1::BIGINT), (0::BIGINT)) v(x);
----
6	4

# Different chunk, same distinct {-1,0,1,2} → served from per-value; the NULL entry (-1) and the
# string entries round-trip. Exact values checked.
query T
SELECT ex.cached_label(x)
FROM (VALUES (2::BIGINT), (-1::BIGINT), (0::BIGINT), (1::BIGINT)) v(x)
ORDER BY x;
----
NULL
lbl-0
lbl-1
lbl-2

# ---------------------------------------------------------------------------
# Store cap: a low cap over a high-cardinality chunk stores only `cap` new entries; the
# result stays correct (uncapped values recompute) — bounded amplification, no corruption.
# ---------------------------------------------------------------------------

statement ok
SELECT * FROM vgi_result_cache_flush();

statement ok
SET vgi_result_cache_per_value_max_stores_per_chunk = 2;

# 10 distinct values, cap 2 → only 2 memoized, but the sum is correct: 2*(0+..+9) = 90.
query I
SELECT sum(ex.cached_double_scalar(x))::BIGINT FROM range(10) t(x);
----
90

# Repeat: a partial hit (only 2 cached) → still correct (the other 8 recompute).
query I
SELECT sum(ex.cached_double_scalar(x))::BIGINT FROM range(10) t(x);
----
90

statement ok
RESET vgi_result_cache_per_value_max_stores_per_chunk;

statement ok
DETACH ex;
