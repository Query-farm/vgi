# name: test/sql/integration/scalar/random_int.test
# description: Tests for VGI random_int scalar function
# group: [vgi_integration_scalar]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# random_int function
# Generates random integers (demonstrates VOLATILE stability)
# Args: min_val (int), max_val (int)
# Returns: int64
# Uses FunctionStability.VOLATILE - non-deterministic
# ============================================================================

# ============================================================================
# Basic usage with range [0, 100]
# ============================================================================

# Single value in range
query I
SELECT CASE WHEN example.random_int(0, 100) BETWEEN 0 AND 100 THEN 1 ELSE 0 END;
----
1

query I
SELECT CASE WHEN example.random_int(0, 100) >= 0 AND example.random_int(0, 100) <= 100 THEN 1 ELSE 0 END;
----
1

# ============================================================================
# Return type validation
# ============================================================================

query I
SELECT typeof(example.random_int(0, 100));
----
BIGINT

# ============================================================================
# Custom range
# ============================================================================

# Range [1, 10]
query I
SELECT CASE WHEN example.random_int(1, 10) BETWEEN 1 AND 10 THEN 1 ELSE 0 END;
----
1

# Range [50, 60]
query I
SELECT CASE WHEN example.random_int(50, 60) BETWEEN 50 AND 60 THEN 1 ELSE 0 END;
----
1

# Negative range
query I
SELECT CASE WHEN example.random_int(-100, -50) BETWEEN -100 AND -50 THEN 1 ELSE 0 END;
----
1

# Range spanning zero
query I
SELECT CASE WHEN example.random_int(-10, 10) BETWEEN -10 AND 10 THEN 1 ELSE 0 END;
----
1

# ============================================================================
# Multiple rows
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(0, 100) AS r
    FROM (SELECT unnest(generate_series(1, 10)) AS i)
) WHERE r BETWEEN 0 AND 100;
----
10

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(1, 5) AS r
    FROM (SELECT unnest(generate_series(1, 20)) AS i)
) WHERE r BETWEEN 1 AND 5;
----
20

# ============================================================================
# Larger datasets
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(0, 1000) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
) WHERE result BETWEEN 0 AND 1000;
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(-500, 500) AS result
    FROM (SELECT unnest(generate_series(1, 200)) AS i)
) WHERE result BETWEEN -500 AND 500;
----
200

# ============================================================================
# Integration with other SQL operations
# ============================================================================

# Aggregations work correctly
query I
SELECT COUNT(example.random_int(0, 100)) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
5

# MIN/MAX should be within bounds
query I
SELECT CASE WHEN MIN(r) >= 0 AND MAX(r) <= 100 THEN 1 ELSE 0 END
FROM (
    SELECT example.random_int(0, 100) AS r
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
);
----
1

query I
SELECT CASE WHEN MIN(r) >= 10 AND MAX(r) <= 20 THEN 1 ELSE 0 END
FROM (
    SELECT example.random_int(10, 20) AS r
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
1

# ============================================================================
# Scale tests - all values in range
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(1, 1000) AS result
    FROM (SELECT unnest(generate_series(1, 1000)) AS i)
) WHERE result BETWEEN 1 AND 1000;
----
1000

query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(-1000, 1000) AS result
    FROM (SELECT unnest(generate_series(1, 2000)) AS i)
) WHERE result BETWEEN -1000 AND 1000;
----
2000

# Verify bounds are respected at scale
query I
SELECT CASE WHEN MIN(r) >= 1 AND MAX(r) <= 10 THEN 1 ELSE 0 END
FROM (
    SELECT example.random_int(1, 10) AS r
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
1

query I
SELECT CASE WHEN MIN(r) >= -100 AND MAX(r) <= 100 THEN 1 ELSE 0 END
FROM (
    SELECT example.random_int(-100, 100) AS r
    FROM (SELECT unnest(generate_series(1, 1000)) AS i)
);
----
1

# Multiple batches (larger than typical batch size)
query I
SELECT COUNT(*) FROM (
    SELECT example.random_int(0, 100) AS result
    FROM (SELECT unnest(generate_series(1, 5000)) AS i)
) WHERE result BETWEEN 0 AND 100;
----
5000

# ============================================================================
# Regression: random_int(0, INT64_MAX) used to crash with "ValueError:
# high <= 0" because the fixture computed `max_val + 1` to make the range
# inclusive — INT64_MAX + 1 wraps to a negative int64 and numpy rejects
# negative `high`. Switched to np.random.default_rng().integers(endpoint=True).
# ============================================================================

query I
SELECT CASE WHEN example.random_int(0::BIGINT, 9223372036854775807::BIGINT) >= 0 THEN 1 ELSE 0 END;
----
1

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
