# name: test/sql/integration/scalar/double_column.test
# description: Integration tests for VGI double_column scalar function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# double_column function
# Doubles values in a numeric column
# Args: column (numeric)
# Returns: numeric (doubled value, promoted type)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic integer tests
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(1);
----
2

query I
SELECT example.double_column(21);
----
42

query I
SELECT example.double_column(0);
----
0

query I
SELECT example.double_column(-5);
----
-10

# ----------------------------------------------------------------------------
# Type-specific tests (verify type promotion)
# ----------------------------------------------------------------------------

# BIGINT -> INT64
query I
SELECT example.double_column(100::BIGINT);
----
200

# INTEGER -> INT64 (promoted to prevent overflow)
query I
SELECT example.double_column(50::INTEGER);
----
100

# SMALLINT -> INT32 (promoted)
query I
SELECT example.double_column(10::SMALLINT);
----
20

# DOUBLE -> DOUBLE (preserved)
query R
SELECT example.double_column(3.14::DOUBLE);
----
6.28

query R
SELECT example.double_column(2.5::DOUBLE);
----
5.0

# FLOAT -> FLOAT (preserved)
query R
SELECT example.double_column(1.5::FLOAT);
----
3.0

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(x) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
2
4
6
8
10

query I
SELECT example.double_column(val) FROM (VALUES (10), (20), (30)) t(val) ORDER BY val;
----
20
40
60

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# Verify values are correct
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.double_column(i::INTEGER) AS doubled
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE doubled = val * 2;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query II
SELECT val, example.double_column(val) AS doubled
FROM (VALUES (5), (10), (15)) t(val)
ORDER BY val;
----
5	10
10	20
15	30

query I
SELECT SUM(example.double_column(x)) FROM (VALUES (1), (2), (3)) t(x);
----
12

# ----------------------------------------------------------------------------
# With expressions
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(10 + 5);
----
30

query I
SELECT example.double_column(x * 2) FROM (VALUES (5)) t(x);
----
20

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
