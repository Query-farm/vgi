# name: test/sql/integration/scalar/double_column.test
# description: Integration tests for VGI double_column scalar function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# double_column function
# Doubles values in a numeric column
# Args: column (numeric)
# Returns: numeric (doubled value, promoted type)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic integer tests
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(1);
----
2

query I
SELECT example.double_column(21);
----
42

query I
SELECT example.double_column(0);
----
0

query I
SELECT example.double_column(-5);
----
-10

# ----------------------------------------------------------------------------
# Type-specific tests (verify type promotion)
# ----------------------------------------------------------------------------

# BIGINT -> INT64
query I
SELECT example.double_column(100::BIGINT);
----
200

# INTEGER -> INT64 (promoted to prevent overflow)
query I
SELECT example.double_column(50::INTEGER);
----
100

# SMALLINT -> INT32 (promoted)
query I
SELECT example.double_column(10::SMALLINT);
----
20

# DOUBLE -> DOUBLE (preserved)
query R
SELECT example.double_column(3.14::DOUBLE);
----
6.28

query R
SELECT example.double_column(2.5::DOUBLE);
----
5.0

# FLOAT -> FLOAT (preserved)
query R
SELECT example.double_column(1.5::FLOAT);
----
3.0

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(x) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
2
4
6
8
10

query I
SELECT example.double_column(val) FROM (VALUES (10), (20), (30)) t(val) ORDER BY val;
----
20
40
60

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# Verify values are correct
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.double_column(i::INTEGER) AS doubled
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE doubled = val * 2;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query II
SELECT val, example.double_column(val) AS doubled
FROM (VALUES (5), (10), (15)) t(val)
ORDER BY val;
----
5	10
10	20
15	30

query I
SELECT SUM(example.double_column(x)) FROM (VALUES (1), (2), (3)) t(x);
----
12

# ----------------------------------------------------------------------------
# With expressions
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(10 + 5);
----
30

query I
SELECT example.double_column(x * 2) FROM (VALUES (5)) t(x);
----
20

# ----------------------------------------------------------------------------
# Boundary cases: NULL handling
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(NULL::INTEGER);
----
NULL

query I
SELECT example.double_column(col) FROM (VALUES (1), (NULL), (3)) t(col);
----
2
NULL
6

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(col) AS result
    FROM (VALUES (1), (NULL), (2), (NULL), (3)) t(col)
) WHERE result IS NOT NULL;
----
3

# ----------------------------------------------------------------------------
# Boundary cases: Zero values
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(0::INTEGER);
----
0

query I
SELECT example.double_column(0::BIGINT);
----
0

query R
SELECT example.double_column(0.0::DOUBLE);
----
0.0

# Negative zero (should still be zero)
query R
SELECT example.double_column(-0.0::DOUBLE);
----
0.0

# ----------------------------------------------------------------------------
# Boundary cases: Negative numbers
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(-1);
----
-2

query I
SELECT example.double_column(-100);
----
-200

query I
SELECT example.double_column(-1000000);
----
-2000000

query R
SELECT example.double_column(-3.14::DOUBLE);
----
-6.28

# ----------------------------------------------------------------------------
# Boundary cases: Large integer values
# ----------------------------------------------------------------------------

# Large positive integer
query I
SELECT example.double_column(1000000000::BIGINT);
----
2000000000

# Billion range
query I
SELECT example.double_column(999999999::BIGINT);
----
1999999998

# Large negative integer
query I
SELECT example.double_column(-1000000000::BIGINT);
----
-2000000000

# ----------------------------------------------------------------------------
# Boundary cases: Small decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.double_column(0.001::DOUBLE);
----
0.002

query R
SELECT example.double_column(0.0001::DOUBLE);
----
0.0002

query R
SELECT example.double_column(0.123456789::DOUBLE);
----
0.246913578

# Very small value
query R
SELECT example.double_column(0.000001::DOUBLE);
----
0.000002

# ----------------------------------------------------------------------------
# Boundary cases: Large decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.double_column(999999.99::DOUBLE);
----
1999999.98

query R
SELECT example.double_column(1234567.89::DOUBLE);
----
2469135.78

# ----------------------------------------------------------------------------
# Boundary cases: Mixed signs in batch
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(x) FROM (VALUES (-5), (0), (5), (-10), (10)) t(x);
----
-10
0
10
-20
20

# Note: VALUES with decimals creates DECIMAL type, need explicit cast to DOUBLE
query R
SELECT example.double_column(x::DOUBLE) FROM (VALUES (-1.5), (0.0), (1.5)) t(x);
----
-3.0
0.0
3.0

# ----------------------------------------------------------------------------
# Boundary cases: Type coercion
# Note: Python preserves input type, so small types can overflow
# Use INTEGER to test boundary values safely
# ----------------------------------------------------------------------------

# Values at TINYINT boundaries (using INTEGER to avoid overflow)
query I
SELECT example.double_column(127::INTEGER);
----
254

query I
SELECT example.double_column(-128::INTEGER);
----
-256

# Values at SMALLINT boundaries (using INTEGER to avoid overflow)
query I
SELECT example.double_column(32767::INTEGER);
----
65534

query I
SELECT example.double_column(-32768::INTEGER);
----
-65536

# ============================================================================
# Large table tests (5000 rows) - tests parallelism
# ============================================================================

# Create a table with 5000 rows of integers
statement ok
CREATE TABLE large_numbers AS
SELECT i AS num_col, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Verify table size
query I
SELECT COUNT(*) FROM large_numbers;
----
5000

# Run double_column on all rows
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(num_col) AS result
    FROM large_numbers
);
----
5000

# Verify all results are correctly doubled
query I
SELECT COUNT(*) FROM (
    SELECT num_col, example.double_column(num_col) AS doubled
    FROM large_numbers
) WHERE doubled = num_col * 2;
----
5000

# Test with filtering
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(num_col) AS result
    FROM large_numbers
    WHERE id <= 2500
);
----
2500

# Test with aggregation
query I
SELECT SUM(example.double_column(num_col))
FROM large_numbers
WHERE id <= 100;
----
10100

# Create table with double precision values
statement ok
CREATE TABLE large_doubles AS
SELECT (i * 0.1)::DOUBLE AS dbl_col, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Run double_column on all double rows
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(dbl_col) AS result
    FROM large_doubles
);
----
5000

# Verify doubling with tolerance for floating point
query I
SELECT COUNT(*) FROM (
    SELECT dbl_col, example.double_column(dbl_col) AS doubled
    FROM large_doubles
) WHERE ABS(doubled - dbl_col * 2) < 0.0001;
----
5000

# Cleanup test tables
statement ok
DROP TABLE large_numbers;

statement ok
DROP TABLE large_doubles;

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
