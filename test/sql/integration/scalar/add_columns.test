# name: test/sql/integration/scalar/add_columns.test
# description: Integration tests for VGI add_columns scalar function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# add_columns function
# Adds two numeric columns together
# Args: col1 (numeric), col2 (numeric)
# Returns: numeric (sum, promoted type)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic integer tests
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(1, 2);
----
3

query I
SELECT example.add_columns(10, 20);
----
30

query I
SELECT example.add_columns(0, 0);
----
0

query I
SELECT example.add_columns(-5, 10);
----
5

query I
SELECT example.add_columns(-10, -5);
----
-15

# ----------------------------------------------------------------------------
# Type-specific tests
# ----------------------------------------------------------------------------

# INTEGER + INTEGER -> INT64 (promoted)
query I
SELECT example.add_columns(100::INTEGER, 200::INTEGER);
----
300

# BIGINT + BIGINT -> INT64
query I
SELECT example.add_columns(1000::BIGINT, 2000::BIGINT);
----
3000

# DOUBLE + DOUBLE -> DOUBLE
query R
SELECT example.add_columns(1.5::DOUBLE, 2.5::DOUBLE);
----
4.0

query R
SELECT example.add_columns(3.14::DOUBLE, 2.86::DOUBLE);
----
6.0

# FLOAT + FLOAT -> FLOAT
query R
SELECT example.add_columns(1.25::FLOAT, 2.75::FLOAT);
----
4.0

# Mixed precision (both promoted)
query R
SELECT example.add_columns(1::INTEGER, 2.5::DOUBLE);
----
3.5

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(a, b) FROM (VALUES (1, 10), (2, 20), (3, 30)) t(a, b);
----
11
22
33

query I
SELECT example.add_columns(x, y) FROM (VALUES (5, 5), (10, 10), (15, 15)) t(x, y) ORDER BY x;
----
10
20
30

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# All should equal 100 (i + (100 - i) = 100)
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE result = 100;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query III
SELECT a, b, example.add_columns(a, b) AS sum
FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)
ORDER BY a;
----
1	2	3
3	4	7
5	6	11

query I
SELECT SUM(example.add_columns(a, b)) FROM (VALUES (1, 1), (2, 2), (3, 3)) t(a, b);
----
12

# ----------------------------------------------------------------------------
# With expressions
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(10 + 5, 20 + 5);
----
40

query I
SELECT example.add_columns(x * 2, y * 3) FROM (VALUES (5, 10)) t(x, y);
----
40

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
