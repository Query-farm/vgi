# name: test/sql/integration/scalar/add_columns.test
# description: Integration tests for VGI add_columns scalar function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# add_columns function
# Adds two numeric columns together
# Args: col1 (numeric), col2 (numeric)
# Returns: numeric (sum, promoted type)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic integer tests
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(1, 2);
----
3

query I
SELECT example.add_columns(10, 20);
----
30

query I
SELECT example.add_columns(0, 0);
----
0

query I
SELECT example.add_columns(-5, 10);
----
5

query I
SELECT example.add_columns(-10, -5);
----
-15

# ----------------------------------------------------------------------------
# Type-specific tests
# ----------------------------------------------------------------------------

# INTEGER + INTEGER -> INT64 (promoted)
query I
SELECT example.add_columns(100::INTEGER, 200::INTEGER);
----
300

# BIGINT + BIGINT -> INT64
query I
SELECT example.add_columns(1000::BIGINT, 2000::BIGINT);
----
3000

# DOUBLE + DOUBLE -> DOUBLE
query R
SELECT example.add_columns(1.5::DOUBLE, 2.5::DOUBLE);
----
4.0

query R
SELECT example.add_columns(3.14::DOUBLE, 2.86::DOUBLE);
----
6.0

# FLOAT + FLOAT -> FLOAT
query R
SELECT example.add_columns(1.25::FLOAT, 2.75::FLOAT);
----
4.0

# Mixed precision (both promoted)
query R
SELECT example.add_columns(1::INTEGER, 2.5::DOUBLE);
----
3.5

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(a, b) FROM (VALUES (1, 10), (2, 20), (3, 30)) t(a, b);
----
11
22
33

query I
SELECT example.add_columns(x, y) FROM (VALUES (5, 5), (10, 10), (15, 15)) t(x, y) ORDER BY x;
----
10
20
30

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# All should equal 100 (i + (100 - i) = 100)
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(i::INTEGER, (100 - i)::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE result = 100;
----
50

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query III
SELECT a, b, example.add_columns(a, b) AS sum
FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)
ORDER BY a;
----
1	2	3
3	4	7
5	6	11

query I
SELECT SUM(example.add_columns(a, b)) FROM (VALUES (1, 1), (2, 2), (3, 3)) t(a, b);
----
12

# ----------------------------------------------------------------------------
# With expressions
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(10 + 5, 20 + 5);
----
40

query I
SELECT example.add_columns(x * 2, y * 3) FROM (VALUES (5, 10)) t(x, y);
----
40

# ----------------------------------------------------------------------------
# Boundary cases: NULL handling
# ----------------------------------------------------------------------------

# First argument NULL
query I
SELECT example.add_columns(NULL::INTEGER, 10);
----
NULL

# Second argument NULL
query I
SELECT example.add_columns(10, NULL::INTEGER);
----
NULL

# Both arguments NULL
query I
SELECT example.add_columns(NULL::INTEGER, NULL::INTEGER);
----
NULL

# Mixed NULL and non-NULL in batch
query I
SELECT example.add_columns(a, b) FROM (VALUES (1, 2), (NULL, 3), (4, NULL), (5, 6)) t(a, b);
----
3
NULL
NULL
11

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(a, b) AS result
    FROM (VALUES (1, 1), (NULL, 2), (3, NULL), (4, 4)) t(a, b)
) WHERE result IS NOT NULL;
----
2

# ----------------------------------------------------------------------------
# Boundary cases: Zero combinations
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(0, 0);
----
0

query I
SELECT example.add_columns(0, 100);
----
100

query I
SELECT example.add_columns(100, 0);
----
100

query I
SELECT example.add_columns(0, -100);
----
-100

query R
SELECT example.add_columns(0.0::DOUBLE, 3.14::DOUBLE);
----
3.14

# ----------------------------------------------------------------------------
# Boundary cases: Opposite signs (cancellation)
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(100, -100);
----
0

query I
SELECT example.add_columns(-50, 50);
----
0

query R
SELECT example.add_columns(3.14::DOUBLE, -3.14::DOUBLE);
----
0.0

query R
SELECT example.add_columns(-1.5::DOUBLE, 1.5::DOUBLE);
----
0.0

# ----------------------------------------------------------------------------
# Boundary cases: Large values
# ----------------------------------------------------------------------------

query I
SELECT example.add_columns(1000000000::BIGINT, 1000000000::BIGINT);
----
2000000000

query I
SELECT example.add_columns(999999999::BIGINT, 1::BIGINT);
----
1000000000

query I
SELECT example.add_columns(-1000000000::BIGINT, -1000000000::BIGINT);
----
-2000000000

# Large positive + large negative
query I
SELECT example.add_columns(1000000000::BIGINT, -999999999::BIGINT);
----
1

# ----------------------------------------------------------------------------
# Boundary cases: Small decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.add_columns(0.001::DOUBLE, 0.002::DOUBLE);
----
0.003

query R
SELECT example.add_columns(0.0001::DOUBLE, 0.0002::DOUBLE);
----
0.0003

query R
SELECT example.add_columns(0.123456::DOUBLE, 0.654321::DOUBLE);
----
0.777777

# ----------------------------------------------------------------------------
# Boundary cases: Type mixing
# Note: Python preserves input types, so mixing int/float can cause truncation
# Use consistent types within each call for reliable results
# ----------------------------------------------------------------------------

# Both DOUBLE (for float results)
query R
SELECT example.add_columns(10.0::DOUBLE, 0.5::DOUBLE);
----
10.5

# Both DOUBLE (negative + positive)
query R
SELECT example.add_columns(-10.0::DOUBLE, 10.5::DOUBLE);
----
0.5

# Both BIGINT
query I
SELECT example.add_columns(100::BIGINT, 1000000::BIGINT);
----
1000100

# Both INTEGER
query I
SELECT example.add_columns(1000::INTEGER, 1000000::INTEGER);
----
1001000

# ----------------------------------------------------------------------------
# Boundary cases: Extreme values of small types
# Note: Python's numpy preserves input type, so small types can overflow
# We cast to larger types to avoid overflow
# ----------------------------------------------------------------------------

# TINYINT values cast to INTEGER to avoid overflow
query I
SELECT example.add_columns(127::INTEGER, 127::INTEGER);
----
254

query I
SELECT example.add_columns(-128::INTEGER, -128::INTEGER);
----
-256

# SMALLINT values cast to INTEGER to avoid overflow
query I
SELECT example.add_columns(32767::INTEGER, 32767::INTEGER);
----
65534

query I
SELECT example.add_columns(-32768::INTEGER, -32768::INTEGER);
----
-65536

# ============================================================================
# Large table tests (5000 rows) - tests parallelism
# ============================================================================

# Create a table with 5000 rows and two integer columns
statement ok
CREATE TABLE large_pairs AS
SELECT i AS col_a, (5000 - i) AS col_b, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Verify table size
query I
SELECT COUNT(*) FROM large_pairs;
----
5000

# Run add_columns on all rows
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(col_a, col_b) AS result
    FROM large_pairs
);
----
5000

# All sums should equal 5000 (i + (5000 - i) = 5000)
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(col_a, col_b) AS result
    FROM large_pairs
) WHERE result = 5000;
----
5000

# Test with filtering
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(col_a, col_b) AS result
    FROM large_pairs
    WHERE id <= 2500
);
----
2500

# Test with aggregation (5000 * 5000 = 25000000)
query I
SELECT SUM(example.add_columns(col_a, col_b))
FROM large_pairs;
----
25000000

# Create table with double precision values
statement ok
CREATE TABLE large_double_pairs AS
SELECT (i * 0.1)::DOUBLE AS col_a, (i * 0.2)::DOUBLE AS col_b, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Run add_columns on all double rows
query I
SELECT COUNT(*) FROM (
    SELECT example.add_columns(col_a, col_b) AS result
    FROM large_double_pairs
);
----
5000

# Verify addition with tolerance
query I
SELECT COUNT(*) FROM (
    SELECT col_a, col_b, example.add_columns(col_a, col_b) AS sum_result
    FROM large_double_pairs
) WHERE ABS(sum_result - (col_a + col_b)) < 0.0001;
----
5000

# Cleanup test tables
statement ok
DROP TABLE large_pairs;

statement ok
DROP TABLE large_double_pairs;

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
