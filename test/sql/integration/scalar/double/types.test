# name: test/sql/integration/scalar/double/types.test
# description: Type tests for VGI double scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Type-specific tests (verify type promotion)
# ----------------------------------------------------------------------------

# BIGINT
query I
SELECT example.double(100::BIGINT);
----
200

# INTEGER
query I
SELECT example.double(50::INTEGER);
----
100

# SMALLINT
query I
SELECT example.double(10::SMALLINT);
----
20

# DOUBLE
query R
SELECT example.double(3.14::DOUBLE);
----
6.28

query R
SELECT example.double(2.5::DOUBLE);
----
5.0

# FLOAT
query R
SELECT example.double(1.5::FLOAT);
----
3.0

# ----------------------------------------------------------------------------
# NULL handling
# ----------------------------------------------------------------------------

query I
SELECT example.double(NULL::INTEGER);
----
NULL

query I
SELECT example.double(col) FROM (VALUES (1), (NULL), (3)) t(col);
----
2
NULL
6

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.double(col) AS result
    FROM (VALUES (1), (NULL), (2), (NULL), (3)) t(col)
) WHERE result IS NOT NULL;
----
3

# ----------------------------------------------------------------------------
# Zero values
# ----------------------------------------------------------------------------

query I
SELECT example.double(0::INTEGER);
----
0

query I
SELECT example.double(0::BIGINT);
----
0

query R
SELECT example.double(0.0::DOUBLE);
----
0.0

# ----------------------------------------------------------------------------
# Negative numbers
# ----------------------------------------------------------------------------

query I
SELECT example.double(-1);
----
-2

query I
SELECT example.double(-100);
----
-200

query I
SELECT example.double(-1000000);
----
-2000000

query R
SELECT example.double(-3.14::DOUBLE);
----
-6.28

# ----------------------------------------------------------------------------
# Large integer values
# ----------------------------------------------------------------------------

# Large positive integer
query I
SELECT example.double(1000000000::BIGINT);
----
2000000000

# Billion range
query I
SELECT example.double(999999999::BIGINT);
----
1999999998

# Large negative integer
query I
SELECT example.double(-1000000000::BIGINT);
----
-2000000000

# ----------------------------------------------------------------------------
# Small decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.double(0.001::DOUBLE);
----
0.002

query R
SELECT example.double(0.0001::DOUBLE);
----
0.0002

# ----------------------------------------------------------------------------
# Mixed signs in batch
# ----------------------------------------------------------------------------

query I
SELECT example.double(x) FROM (VALUES (-5), (0), (5), (-10), (10)) t(x);
----
-10
0
10
-20
20

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
