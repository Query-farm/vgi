# name: test/sql/integration/scalar/sum_values/scale.test_slow
# description: Scale tests for VGI sum_values scalar function (5000+ rows)
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Larger datasets
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT example.sum_values(i::INTEGER, i::INTEGER, i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

# Verify values are correct (sum of i + i + i = 3*i)
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.sum_values(i::INTEGER, i::INTEGER, i::INTEGER) AS summed
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE summed = val * 3;
----
50

# ============================================================================
# Large table tests (5000 rows) - tests parallelism
# ============================================================================

# Create a table with 5000 rows and three integer columns
statement ok
CREATE TABLE large_triplets AS
SELECT i AS col_a, i * 2 AS col_b, i * 3 AS col_c, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Verify table size
query I
SELECT COUNT(*) FROM large_triplets;
----
5000

# Run sum_values on all rows (3 columns)
query I
SELECT COUNT(*) FROM (
    SELECT example.sum_values(col_a, col_b, col_c) AS result
    FROM large_triplets
);
----
5000

# Verify all sums are correct (i + 2i + 3i = 6i)
query I
SELECT COUNT(*) FROM (
    SELECT id, example.sum_values(col_a, col_b, col_c) AS sum_result
    FROM large_triplets
) WHERE sum_result = id * 6;
----
5000

# Test with filtering
query I
SELECT COUNT(*) FROM (
    SELECT example.sum_values(col_a, col_b, col_c) AS result
    FROM large_triplets
    WHERE id <= 2500
);
----
2500

# Test with aggregation
# Sum of 6*i for i=1 to 100 = 6 * (100 * 101 / 2) = 30300
query I
SELECT SUM(example.sum_values(col_a, col_b, col_c))
FROM large_triplets
WHERE id <= 100;
----
30300

# Create table with 4 columns to test more varargs
statement ok
CREATE TABLE large_quads AS
SELECT i AS col_a, i AS col_b, i AS col_c, i AS col_d, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Run sum_values with 4 columns
query I
SELECT COUNT(*) FROM (
    SELECT example.sum_values(col_a, col_b, col_c, col_d) AS result
    FROM large_quads
);
----
5000

# All sums should be 4*i
query I
SELECT COUNT(*) FROM (
    SELECT id, example.sum_values(col_a, col_b, col_c, col_d) AS sum_result
    FROM large_quads
) WHERE sum_result = id * 4;
----
5000

# Create table with double precision values
statement ok
CREATE TABLE large_double_triplets AS
SELECT (i * 0.1)::DOUBLE AS col_a, (i * 0.2)::DOUBLE AS col_b, (i * 0.3)::DOUBLE AS col_c, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Run sum_values on all double rows
query I
SELECT COUNT(*) FROM (
    SELECT example.sum_values(col_a, col_b, col_c) AS result
    FROM large_double_triplets
);
----
5000

# Verify sums with tolerance (0.1i + 0.2i + 0.3i = 0.6i)
query I
SELECT COUNT(*) FROM (
    SELECT id, col_a, col_b, col_c, example.sum_values(col_a, col_b, col_c) AS sum_result
    FROM large_double_triplets
) WHERE ABS(sum_result - (id * 0.6)) < 0.0001;
----
5000

# Cleanup test tables
statement ok
DROP TABLE large_triplets;

statement ok
DROP TABLE large_quads;

statement ok
DROP TABLE large_double_triplets;

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
