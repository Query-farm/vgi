# name: test/sql/integration/scalar/sum_values/basic.test
# description: Basic tests for VGI sum_values scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sum_values function
# Sums multiple numeric columns together (varargs)
# Args: columns... (numeric, varargs)
# Returns: numeric (sum, promoted type)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic tests with 2 arguments
# ----------------------------------------------------------------------------

query I
SELECT example.sum_values(10, 20);
----
30

query I
SELECT example.sum_values(0, 0);
----
0

query I
SELECT example.sum_values(-10, 20);
----
10

query I
SELECT example.sum_values(-10, -20);
----
-30

# ----------------------------------------------------------------------------
# Multiple rows from table
# ----------------------------------------------------------------------------

query I
SELECT example.sum_values(a, b, c) FROM (VALUES (1, 2, 3), (4, 5, 6), (7, 8, 9)) t(a, b, c);
----
6
15
24

query I
SELECT example.sum_values(x, y) FROM (VALUES (10, 1), (20, 2), (30, 3)) t(x, y) ORDER BY x;
----
11
22
33

# ----------------------------------------------------------------------------
# Integration with other SQL operations
# ----------------------------------------------------------------------------

query IIII
SELECT a, b, c, example.sum_values(a, b, c) AS total
FROM (VALUES (1, 2, 3), (4, 5, 6), (7, 8, 9)) t(a, b, c)
ORDER BY a;
----
1	2	3	6
4	5	6	15
7	8	9	24

query I
SELECT SUM(example.sum_values(a, b)) FROM (VALUES (1, 1), (2, 2), (3, 3)) t(a, b);
----
12

# ----------------------------------------------------------------------------
# With expressions
# ----------------------------------------------------------------------------

query I
SELECT example.sum_values(10 + 5, 20 + 5, 30 + 5);
----
75

query I
SELECT example.sum_values(x * 2, y * 2, z * 2) FROM (VALUES (5, 10, 15)) t(x, y, z);
----
60

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
