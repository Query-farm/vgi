# name: test/sql/integration/scalar/function_registration.test
# description: Validates scalar function registration metadata matches the VGI example worker specification
# group: [vgi_integration_scalar]

# Scalar functions registered by the example worker must expose consistent metadata
# through duckdb_functions() so that all VGI worker implementations (Python, Go, etc.)
# can be validated against the same expectations.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Function Inventory
# All scalar functions must be registered (includes overloads)
# ============================================================================

query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar';
----
49

query T
SELECT function_name
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar'
ORDER BY function_name;
----
add_values
any_mixed
any_mixed
bernoulli
binary_packet
cached_add_const
cached_double_scalar
cached_label
collatz_steps
concat_values
concat_values
conditional_message
double
format_number
format_number
format_number
geo_centroid_fixed
geo_centroid_list
geo_centroid_struct
geo_distance_fixed
geo_distance_list
geo_distance_struct
hash_rounds
hash_seed
multiply
multiply_by_setting
null_handling
pair_type
pair_type
pair_type
passthru
query_seed
random_bytes
random_int
return_secret_value
scale_by_setting
secret_field
sha256_hex
smart_format
smart_format
sum_values
type_info
type_info
type_info
type_info
type_info
unnest_tensor
upper_case
whoami

# ============================================================================
# Per-function Registration
# Each query checks: name, parameters, parameter_types, return_type, stability, description
# ============================================================================

# ----------------------------------------------------------------------------
# add_values — Adds two AnyArrow numeric columns with dynamic return type
# Parameters: col1 (ANY), col2 (ANY) → ANY
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'add_values';
----
add_values	[col1, col2]	[ANY, ANY]	ANY	CONSISTENT	Adds two numeric values

# ----------------------------------------------------------------------------
# bernoulli — No input parameters, returns random booleans (VOLATILE)
# Parameters: (none) → BOOLEAN
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'bernoulli';
----
bernoulli	[]	[]	BOOLEAN	VOLATILE	Generate random booleans (demonstrates VOLATILE stability)

# ----------------------------------------------------------------------------
# binary_packet — Complex ConstParam types (binary header, struct config)
# Parameters: header (BLOB), payload (BLOB), config (STRUCT) → BLOB
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'binary_packet';
----
binary_packet	[header, payload, config]	[BLOB, BLOB, 'STRUCT("label" VARCHAR, "version" BIGINT)']	BLOB	CONSISTENT	Build binary packets with header, payload, and config

# ----------------------------------------------------------------------------
# conditional_message — Multiple ConstParam parameters (int, string) + column
# Parameters: repeat_count (BIGINT), message (VARCHAR), condition (BOOLEAN) → VARCHAR
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'conditional_message';
----
conditional_message	[repeat_count, message, condition]	[BIGINT, VARCHAR, BOOLEAN]	VARCHAR	CONSISTENT	Returns repeated message when condition is true

# ----------------------------------------------------------------------------
# double — AnyArrow input with dynamic return type via on_bind
# Parameters: value (ANY) → ANY
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'double';
----
double	[value]	[ANY]	ANY	CONSISTENT	Doubles numeric values

# ----------------------------------------------------------------------------
# geo_centroid_fixed — Varargs fixed-size list centroid
# Parameters: (none positional), varargs=DOUBLE[2] → STRUCT(lat DOUBLE, lon DOUBLE)
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_centroid_fixed';
----
geo_centroid_fixed	[]	[]	STRUCT(lat DOUBLE, lon DOUBLE)	CONSISTENT	Centroid of N fixed-size list points

# ----------------------------------------------------------------------------
# geo_centroid_list — Varargs list centroid
# Parameters: (none positional), varargs=DOUBLE[] → STRUCT(lat DOUBLE, lon DOUBLE)
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_centroid_list';
----
geo_centroid_list	[]	[]	STRUCT(lat DOUBLE, lon DOUBLE)	CONSISTENT	Centroid of N list points

# ----------------------------------------------------------------------------
# geo_centroid_struct — Varargs struct centroid
# Parameters: (none positional), varargs=STRUCT(lat DOUBLE, lon DOUBLE) → STRUCT(lat DOUBLE, lon DOUBLE)
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_centroid_struct';
----
geo_centroid_struct	[]	[]	STRUCT(lat DOUBLE, lon DOUBLE)	CONSISTENT	Centroid of N struct points

# ----------------------------------------------------------------------------
# geo_distance_fixed — Distance between two fixed-size list points
# Parameters: p1 (DOUBLE[2]), p2 (DOUBLE[2]) → DOUBLE
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_distance_fixed';
----
geo_distance_fixed	[p1, p2]	['DOUBLE[2]', 'DOUBLE[2]']	DOUBLE	CONSISTENT	Euclidean distance between two fixed-size list points

# ----------------------------------------------------------------------------
# geo_distance_list — Distance between two list points
# Parameters: p1 (DOUBLE[]), p2 (DOUBLE[]) → DOUBLE
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_distance_list';
----
geo_distance_list	[p1, p2]	['DOUBLE[]', 'DOUBLE[]']	DOUBLE	CONSISTENT	Euclidean distance between two list points

# ----------------------------------------------------------------------------
# geo_distance_struct — Distance between two struct points
# Parameters: p1 (STRUCT(lat DOUBLE, lon DOUBLE)), p2 (STRUCT(lat DOUBLE, lon DOUBLE)) → DOUBLE
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'geo_distance_struct';
----
geo_distance_struct	[p1, p2]	['STRUCT(lat DOUBLE, lon DOUBLE)', 'STRUCT(lat DOUBLE, lon DOUBLE)']	DOUBLE	CONSISTENT	Euclidean distance between two struct points

# ----------------------------------------------------------------------------
# format_number — Overloaded function with 3 variants (0, 1, 2 ConstParams)
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'format_number'
ORDER BY length(parameters::VARCHAR);
----
format_number	[value]	[DOUBLE]	VARCHAR	CONSISTENT	Format number with default precision (0 decimals)
format_number	[precision, value]	[BIGINT, DOUBLE]	VARCHAR	CONSISTENT	Format number with specified precision
format_number	[precision, prefix, value]	[BIGINT, VARCHAR, DOUBLE]	VARCHAR	CONSISTENT	Format number with precision and prefix

# ----------------------------------------------------------------------------
# hash_seed — Single ConstParam, no Params (1 ConstParam, 0 Params pattern)
# Parameters: seed (BIGINT) → BIGINT
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'hash_seed';
----
hash_seed	[seed]	[BIGINT]	BIGINT	CONSISTENT	Generate deterministic integers from a constant seed

# ----------------------------------------------------------------------------
# multiply — ConstParam example with static types
# Parameters: value (BIGINT), factor (BIGINT) → BIGINT
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'multiply';
----
multiply	[value, factor]	[BIGINT, BIGINT]	BIGINT	CONSISTENT	Multiplies a value by a constant factor

# ----------------------------------------------------------------------------
# multiply_by_setting — Setting() parameter (not visible in duckdb_functions)
# Parameters: value (BIGINT) → BIGINT
# Note: 'multiplier' setting is passed internally, not as a function parameter
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'multiply_by_setting';
----
multiply_by_setting	[value]	[BIGINT]	BIGINT	CONSISTENT	Multiply the input value by a setting value

# ----------------------------------------------------------------------------
# null_handling — NullHandling.SPECIAL (receives NULLs instead of skipping)
# Parameters: value (BIGINT) → BIGINT
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'null_handling';
----
null_handling	[value]	[BIGINT]	BIGINT	CONSISTENT	Returns value or -5000 if null

# ----------------------------------------------------------------------------
# random_bytes — ConstParam seed + length, CONSISTENT stability
# Parameters: seed (BIGINT), byte_length (BIGINT) → BLOB
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'random_bytes';
----
random_bytes	[seed, byte_length]	[BIGINT, BIGINT]	BLOB	CONSISTENT	Generate pseudo-random binary blobs from seed and length

# ----------------------------------------------------------------------------
# random_int — VOLATILE stability (non-deterministic output)
# Parameters: min_val (BIGINT), max_val (BIGINT) → BIGINT
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'random_int';
----
random_int	[min_val, max_val]	[BIGINT, BIGINT]	BIGINT	VOLATILE	Generate random integers (demonstrates VOLATILE stability)

# ----------------------------------------------------------------------------
# return_secret_value — Secret() parameter (not visible in duckdb_functions)
# Parameters: (none) → VARCHAR
# Note: 'vgi_example_secret' is passed internally, not as a function parameter
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'return_secret_value';
----
return_secret_value	[]	[]	VARCHAR	CONSISTENT	Return a secret's value

# ----------------------------------------------------------------------------
# scale_by_setting — float Setting() parameter (read via get_f64, not visible)
# Parameters: value (DOUBLE) → DOUBLE
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'scale_by_setting';
----
scale_by_setting	[value]	[DOUBLE]	DOUBLE	CONSISTENT	Scale the input value by the float setting `scale_factor`

# ----------------------------------------------------------------------------
# secret_field — Secret() parameter, looks up individual fields by name
# Parameters: (none) → VARCHAR
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'secret_field';
----
secret_field	[]	[]	VARCHAR	CONSISTENT	Look up secret fields by name

# ----------------------------------------------------------------------------
# sum_values — Varargs with AnyArrow type and dynamic return type
# Parameters: (none positional), varargs=ANY → ANY
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sum_values';
----
sum_values	[]	[]	ANY	CONSISTENT	Sum multiple numeric values

# ----------------------------------------------------------------------------
# upper_case — Simple string→string transformation
# Parameters: value (VARCHAR) → VARCHAR
# ----------------------------------------------------------------------------

query TTTTTT
SELECT function_name, parameters, parameter_types, return_type, stability, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'upper_case';
----
upper_case	[value]	[VARCHAR]	VARCHAR	CONSISTENT	Converts string values to uppercase

# ============================================================================
# Varargs
# Functions with varargs
# ============================================================================

query TT
SELECT function_name, varargs
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar' AND varargs IS NOT NULL
ORDER BY function_name, varargs;
----
concat_values	BIGINT
concat_values	VARCHAR
geo_centroid_fixed	DOUBLE[2]
geo_centroid_list	DOUBLE[]
geo_centroid_struct	STRUCT(lat DOUBLE, lon DOUBLE)
sum_values	ANY

# Verify all other scalar functions have no varargs
query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar' AND varargs IS NULL;
----
43

# ============================================================================
# Stability
# Most scalar functions are CONSISTENT; bernoulli and random_int are VOLATILE;
# query_seed is CONSISTENT_WITHIN_QUERY. All three stability variants are
# emitted by a fixture so the wire enum stays covered (and other-language
# workers must specify it).
# ============================================================================

query T
SELECT function_name
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar' AND stability = 'VOLATILE'
ORDER BY function_name;
----
bernoulli
random_int

query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar' AND stability = 'CONSISTENT';
----
46

query T
SELECT function_name
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'scalar' AND stability = 'CONSISTENT_WITHIN_QUERY'
ORDER BY function_name;
----
query_seed

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
