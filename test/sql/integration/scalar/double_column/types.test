# name: test/sql/integration/scalar/double_column/types.test
# description: Type tests for VGI double_column scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Type-specific tests (verify type promotion)
# ----------------------------------------------------------------------------

# BIGINT -> INT64
query I
SELECT example.double_column(100::BIGINT);
----
200

# INTEGER -> INT64 (promoted to prevent overflow)
query I
SELECT example.double_column(50::INTEGER);
----
100

# SMALLINT -> INT32 (promoted)
query I
SELECT example.double_column(10::SMALLINT);
----
20

# DOUBLE -> DOUBLE (preserved)
query R
SELECT example.double_column(3.14::DOUBLE);
----
6.28

query R
SELECT example.double_column(2.5::DOUBLE);
----
5.0

# FLOAT -> FLOAT (preserved)
query R
SELECT example.double_column(1.5::FLOAT);
----
3.0

# ----------------------------------------------------------------------------
# NULL handling
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(NULL::INTEGER);
----
NULL

query I
SELECT example.double_column(col) FROM (VALUES (1), (NULL), (3)) t(col);
----
2
NULL
6

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(col) AS result
    FROM (VALUES (1), (NULL), (2), (NULL), (3)) t(col)
) WHERE result IS NOT NULL;
----
3

# ----------------------------------------------------------------------------
# Zero values
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(0::INTEGER);
----
0

query I
SELECT example.double_column(0::BIGINT);
----
0

query R
SELECT example.double_column(0.0::DOUBLE);
----
0.0

# Negative zero (should still be zero)
query R
SELECT example.double_column(-0.0::DOUBLE);
----
0.0

# ----------------------------------------------------------------------------
# Negative numbers
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(-1);
----
-2

query I
SELECT example.double_column(-100);
----
-200

query I
SELECT example.double_column(-1000000);
----
-2000000

query R
SELECT example.double_column(-3.14::DOUBLE);
----
-6.28

# ----------------------------------------------------------------------------
# Large integer values
# ----------------------------------------------------------------------------

# Large positive integer
query I
SELECT example.double_column(1000000000::BIGINT);
----
2000000000

# Billion range
query I
SELECT example.double_column(999999999::BIGINT);
----
1999999998

# Large negative integer
query I
SELECT example.double_column(-1000000000::BIGINT);
----
-2000000000

# ----------------------------------------------------------------------------
# Small decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.double_column(0.001::DOUBLE);
----
0.002

query R
SELECT example.double_column(0.0001::DOUBLE);
----
0.0002

query R
SELECT example.double_column(0.123456789::DOUBLE);
----
0.246913578

# Very small value
query R
SELECT example.double_column(0.000001::DOUBLE);
----
0.000002

# ----------------------------------------------------------------------------
# Large decimal values
# ----------------------------------------------------------------------------

query R
SELECT example.double_column(999999.99::DOUBLE);
----
1999999.98

query R
SELECT example.double_column(1234567.89::DOUBLE);
----
2469135.78

# ----------------------------------------------------------------------------
# Mixed signs in batch
# ----------------------------------------------------------------------------

query I
SELECT example.double_column(x) FROM (VALUES (-5), (0), (5), (-10), (10)) t(x);
----
-10
0
10
-20
20

# Note: VALUES with decimals creates DECIMAL type, need explicit cast to DOUBLE
query R
SELECT example.double_column(x::DOUBLE) FROM (VALUES (-1.5), (0.0), (1.5)) t(x);
----
-3.0
0.0
3.0

# ----------------------------------------------------------------------------
# Type coercion boundaries
# ----------------------------------------------------------------------------

# Values at TINYINT boundaries (using INTEGER to avoid overflow)
query I
SELECT example.double_column(127::INTEGER);
----
254

query I
SELECT example.double_column(-128::INTEGER);
----
-256

# Values at SMALLINT boundaries (using INTEGER to avoid overflow)
query I
SELECT example.double_column(32767::INTEGER);
----
65534

query I
SELECT example.double_column(-32768::INTEGER);
----
-65536

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
