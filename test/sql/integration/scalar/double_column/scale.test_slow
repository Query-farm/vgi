# name: test/sql/integration/scalar/double_column/scale.test_slow
# description: Scale tests for VGI double_column scalar function (5000+ rows)
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Large table tests (5000 rows) - tests parallelism
# ============================================================================

# Create a table with 5000 rows of integers
statement ok
CREATE TABLE large_numbers AS
SELECT i AS num_col, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Verify table size
query I
SELECT COUNT(*) FROM large_numbers;
----
5000

# Run double_column on all rows
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(num_col) AS result
    FROM large_numbers
);
----
5000

# Verify all results are correctly doubled
query I
SELECT COUNT(*) FROM (
    SELECT num_col, example.double_column(num_col) AS doubled
    FROM large_numbers
) WHERE doubled = num_col * 2;
----
5000

# Test with filtering
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(num_col) AS result
    FROM large_numbers
    WHERE id <= 2500
);
----
2500

# Test with aggregation
query I
SELECT SUM(example.double_column(num_col))
FROM large_numbers
WHERE id <= 100;
----
10100

# Create table with double precision values
statement ok
CREATE TABLE large_doubles AS
SELECT (i * 0.1)::DOUBLE AS dbl_col, i AS id
FROM (SELECT unnest(generate_series(1, 5000)) AS i);

# Run double_column on all double rows
query I
SELECT COUNT(*) FROM (
    SELECT example.double_column(dbl_col) AS result
    FROM large_doubles
);
----
5000

# Verify doubling with tolerance for floating point
query I
SELECT COUNT(*) FROM (
    SELECT dbl_col, example.double_column(dbl_col) AS doubled
    FROM large_doubles
) WHERE ABS(doubled - dbl_col * 2) < 0.0001;
----
5000

# Cleanup test tables
statement ok
DROP TABLE large_numbers;

statement ok
DROP TABLE large_doubles;

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
