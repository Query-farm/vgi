# name: test/sql/integration/scalar/double.test
# description: Tests for VGI double scalar function
# group: [vgi_integration_scalar]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# double function
# Doubles values in a numeric column
# Args: value (numeric)
# Returns: numeric (doubled value, promoted type)
# ============================================================================

# ============================================================================
# Basic integer tests
# ============================================================================

query IT
SELECT example.double(1), typeof(example.double(1));
----
2	BIGINT

query IT
SELECT example.double(21), typeof(example.double(21));
----
42	BIGINT

query IT
SELECT example.double(0), typeof(example.double(0));
----
0	BIGINT

query IT
SELECT example.double(-5), typeof(example.double(-5));
----
-10	BIGINT

# ============================================================================
# Multiple rows from table
# ============================================================================

query IT
SELECT example.double(x), typeof(example.double(x)) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
2	BIGINT
4	BIGINT
6	BIGINT
8	BIGINT
10	BIGINT

query IT
SELECT example.double(val), typeof(example.double(val)) FROM (VALUES (10), (20), (30)) t(val) ORDER BY val;
----
20	BIGINT
40	BIGINT
60	BIGINT

# ============================================================================
# Larger datasets
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.double(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.double(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# Verify values are correct
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.double(i::INTEGER) AS doubled
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE doubled = val * 2;
----
50

# ============================================================================
# Integration with other SQL operations
# ============================================================================

query IIT
SELECT val, example.double(val) AS doubled, typeof(example.double(val))
FROM (VALUES (5), (10), (15)) t(val)
ORDER BY val;
----
5	10	BIGINT
10	20	BIGINT
15	30	BIGINT

query I
SELECT SUM(example.double(x)) FROM (VALUES (1), (2), (3)) t(x);
----
12

# ============================================================================
# With expressions
# ============================================================================

query IT
SELECT example.double(10 + 5), typeof(example.double(10 + 5));
----
30	BIGINT

query IT
SELECT example.double(x * 2), typeof(example.double(x * 2)) FROM (VALUES (5)) t(x);
----
20	BIGINT

# ============================================================================
# Type-specific tests
# ============================================================================

# BIGINT
query IT
SELECT example.double(100::BIGINT), typeof(example.double(100::BIGINT));
----
200	BIGINT

# INTEGER
query IT
SELECT example.double(50::INTEGER), typeof(example.double(50::INTEGER));
----
100	BIGINT

# SMALLINT
query IT
SELECT example.double(10::SMALLINT), typeof(example.double(10::SMALLINT));
----
20	INTEGER

# DOUBLE
query RT
SELECT example.double(3.14::DOUBLE), typeof(example.double(3.14::DOUBLE));
----
6.28	DOUBLE

query RT
SELECT example.double(2.5::DOUBLE), typeof(example.double(2.5::DOUBLE));
----
5.0	DOUBLE

# FLOAT (promoted to DOUBLE for overflow safety)
query RT
SELECT example.double(1.5::FLOAT), typeof(example.double(1.5::FLOAT));
----
3.0	DOUBLE

# ============================================================================
# Return type validation (ANY type resolution via on_bind)
# The double function uses ArrowAny input/output types. The worker's on_bind
# promotes the output type to prevent overflow: int promotes up one size,
# float32 promotes to float64, float64 stays the same.
# ============================================================================

# INTEGER (int32) input -> BIGINT (int64) output
query I
SELECT typeof(example.double(1::INTEGER));
----
BIGINT

# BIGINT (int64) input -> BIGINT (int64) output (no further promotion)
query I
SELECT typeof(example.double(1::BIGINT));
----
BIGINT

# SMALLINT (int16) input -> INTEGER (int32) output
query I
SELECT typeof(example.double(1::SMALLINT));
----
INTEGER

# TINYINT (int8) input -> SMALLINT (int16) output
query I
SELECT typeof(example.double(1::TINYINT));
----
SMALLINT

# DOUBLE (float64) input -> DOUBLE (float64) output
query I
SELECT typeof(example.double(1.0::DOUBLE));
----
DOUBLE

# FLOAT (float32) input -> DOUBLE (float64) output (promoted for overflow safety)
query I
SELECT typeof(example.double(1.0::FLOAT));
----
DOUBLE

# Verify type is consistent across multiple rows
query I
SELECT CASE WHEN COUNT(DISTINCT typeof(result)) = 1 AND MIN(typeof(result)) = 'BIGINT' THEN 'OK' ELSE 'FAIL' END
FROM (SELECT example.double(x) AS result FROM (VALUES (1), (2), (3)) t(x));
----
OK

# Note: typeof(example.double(NULL::INTEGER)) returns "NULL" because DuckDB
# short-circuits scalar NULLs before the worker bind resolves the output type

# ============================================================================
# NULL handling
# ============================================================================

query I
SELECT example.double(NULL::INTEGER);
----
NULL

query I
SELECT example.double(col) FROM (VALUES (1), (NULL), (3)) t(col);
----
2
NULL
6

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.double(col) AS result
    FROM (VALUES (1), (NULL), (2), (NULL), (3)) t(col)
) WHERE result IS NOT NULL;
----
3

# ============================================================================
# Zero values
# ============================================================================

query IT
SELECT example.double(0::INTEGER), typeof(example.double(0::INTEGER));
----
0	BIGINT

query IT
SELECT example.double(0::BIGINT), typeof(example.double(0::BIGINT));
----
0	BIGINT

query RT
SELECT example.double(0.0::DOUBLE), typeof(example.double(0.0::DOUBLE));
----
0.0	DOUBLE

# ============================================================================
# Negative numbers
# ============================================================================

query IT
SELECT example.double(-1), typeof(example.double(-1));
----
-2	BIGINT

query IT
SELECT example.double(-100), typeof(example.double(-100));
----
-200	BIGINT

query IT
SELECT example.double(-1000000), typeof(example.double(-1000000));
----
-2000000	BIGINT

query RT
SELECT example.double(-3.14::DOUBLE), typeof(example.double(-3.14::DOUBLE));
----
-6.28	DOUBLE

# ============================================================================
# Large integer values
# ============================================================================

query IT
SELECT example.double(1000000000::BIGINT), typeof(example.double(1000000000::BIGINT));
----
2000000000	BIGINT

query IT
SELECT example.double(999999999::BIGINT), typeof(example.double(999999999::BIGINT));
----
1999999998	BIGINT

query IT
SELECT example.double(-1000000000::BIGINT), typeof(example.double(-1000000000::BIGINT));
----
-2000000000	BIGINT

# ============================================================================
# Small decimal values
# ============================================================================

query RT
SELECT example.double(0.001::DOUBLE), typeof(example.double(0.001::DOUBLE));
----
0.002	DOUBLE

query RT
SELECT example.double(0.0001::DOUBLE), typeof(example.double(0.0001::DOUBLE));
----
0.0002	DOUBLE

# ============================================================================
# Mixed signs in batch
# ============================================================================

query IT
SELECT example.double(x), typeof(example.double(x)) FROM (VALUES (-5), (0), (5), (-10), (10)) t(x);
----
-10	BIGINT
0	BIGINT
10	BIGINT
-20	BIGINT
20	BIGINT

# ============================================================================
# Regression: doubling a wide decimal (or HUGEINT, which crosses the wire as
# decimal128(38, 0)) must not blow precision. pyarrow's pc.multiply follows
# the SQL rule decimal(p1,s1)*decimal(p2,s2) -> decimal(p1+p2+1, s1+s2), so
# multiplying by the literal 2 (decimal128(19,0)) would have demanded
# precision 58 — past decimal128's 38-digit cap, raising
# "Decimal precision out of range [1, 38]: 58". The fixture now computes
# value+value (precision +1) and casts back, so small values double cleanly.
# ============================================================================

query I
SELECT example.double(100::HUGEINT);
----
200

query I
SELECT example.double(100::DECIMAL(38, 0));
----
200

query I
SELECT example.double(123.45::DECIMAL(20, 2));
----
246.90

# Doubling at the precision-38 cap when the actual value would overflow the
# capped output should raise a clear "does not fit in precision 38".
statement error
SELECT example.double(50000000000000000000000000000000000000::DECIMAL(38,0));
----
does not fit in precision 38

# ============================================================================
# Regression: temporal types (date/time/timestamp/interval) must be rejected
# at bind time with a clear SchemaValidationError. Previously the type_bound
# allowed them through and pc.multiply crashed inside compute() with an
# opaque ArrowNotImplementedError ("multiply has no kernel matching ...").
# ============================================================================

statement error
SELECT example.double(DATE '2024-01-01');
----
_is_multipliable_type

statement error
SELECT example.double(TIMESTAMP '2024-01-01 00:00:00');
----
_is_multipliable_type

statement error
SELECT example.double(INTERVAL '1' DAY);
----
_is_multipliable_type

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
