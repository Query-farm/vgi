# name: test/sql/integration/scalar/double.test
# description: Tests for VGI double scalar function
# group: [vgi]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# double function
# Doubles values in a numeric column
# Args: value (numeric)
# Returns: numeric (doubled value, promoted type)
# ============================================================================

# ============================================================================
# Basic integer tests
# ============================================================================

query I
SELECT example.double(1);
----
2

query I
SELECT example.double(21);
----
42

query I
SELECT example.double(0);
----
0

query I
SELECT example.double(-5);
----
-10

# ============================================================================
# Multiple rows from table
# ============================================================================

query I
SELECT example.double(x) FROM (VALUES (1), (2), (3), (4), (5)) t(x);
----
2
4
6
8
10

query I
SELECT example.double(val) FROM (VALUES (10), (20), (30)) t(val) ORDER BY val;
----
20
40
60

# ============================================================================
# Larger datasets
# ============================================================================

query I
SELECT COUNT(*) FROM (
    SELECT example.double(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 100)) AS i)
);
----
100

query I
SELECT COUNT(*) FROM (
    SELECT example.double(i::INTEGER) AS result
    FROM (SELECT unnest(generate_series(1, 500)) AS i)
);
----
500

# Verify values are correct
query I
SELECT COUNT(*) FROM (
    SELECT i::INTEGER AS val, example.double(i::INTEGER) AS doubled
    FROM (SELECT unnest(generate_series(1, 50)) AS i)
) WHERE doubled = val * 2;
----
50

# ============================================================================
# Integration with other SQL operations
# ============================================================================

query II
SELECT val, example.double(val) AS doubled
FROM (VALUES (5), (10), (15)) t(val)
ORDER BY val;
----
5	10
10	20
15	30

query I
SELECT SUM(example.double(x)) FROM (VALUES (1), (2), (3)) t(x);
----
12

# ============================================================================
# With expressions
# ============================================================================

query I
SELECT example.double(10 + 5);
----
30

query I
SELECT example.double(x * 2) FROM (VALUES (5)) t(x);
----
20

# ============================================================================
# Type-specific tests
# ============================================================================

# BIGINT
query I
SELECT example.double(100::BIGINT);
----
200

# INTEGER
query I
SELECT example.double(50::INTEGER);
----
100

# SMALLINT
query I
SELECT example.double(10::SMALLINT);
----
20

# DOUBLE
query R
SELECT example.double(3.14::DOUBLE);
----
6.28

query R
SELECT example.double(2.5::DOUBLE);
----
5.0

# FLOAT
query R
SELECT example.double(1.5::FLOAT);
----
3.0

# ============================================================================
# NULL handling
# ============================================================================

query I
SELECT example.double(NULL::INTEGER);
----
NULL

query I
SELECT example.double(col) FROM (VALUES (1), (NULL), (3)) t(col);
----
2
NULL
6

# Count non-null results
query I
SELECT COUNT(*) FROM (
    SELECT example.double(col) AS result
    FROM (VALUES (1), (NULL), (2), (NULL), (3)) t(col)
) WHERE result IS NOT NULL;
----
3

# ============================================================================
# Zero values
# ============================================================================

query I
SELECT example.double(0::INTEGER);
----
0

query I
SELECT example.double(0::BIGINT);
----
0

query R
SELECT example.double(0.0::DOUBLE);
----
0.0

# ============================================================================
# Negative numbers
# ============================================================================

query I
SELECT example.double(-1);
----
-2

query I
SELECT example.double(-100);
----
-200

query I
SELECT example.double(-1000000);
----
-2000000

query R
SELECT example.double(-3.14::DOUBLE);
----
-6.28

# ============================================================================
# Large integer values
# ============================================================================

query I
SELECT example.double(1000000000::BIGINT);
----
2000000000

query I
SELECT example.double(999999999::BIGINT);
----
1999999998

query I
SELECT example.double(-1000000000::BIGINT);
----
-2000000000

# ============================================================================
# Small decimal values
# ============================================================================

query R
SELECT example.double(0.001::DOUBLE);
----
0.002

query R
SELECT example.double(0.0001::DOUBLE);
----
0.0002

# ============================================================================
# Mixed signs in batch
# ============================================================================

query I
SELECT example.double(x) FROM (VALUES (-5), (0), (5), (-10), (10)) t(x);
----
-10
0
10
-20
20

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
