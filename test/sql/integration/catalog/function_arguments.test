# name: test/sql/integration/catalog/function_arguments.test
# description: vgi_function_arguments() surfaces per-argument metadata that
#   duckdb_functions() flattens away — named/positional/const/varargs/type.
#   Anchored on the example worker's `multiply` (value positional non-const +
#   factor positional const) and `double` (AnyArrow value). The per-argument
#   description (vgi_doc) plumbing is exercised by each SDK's unit round-trip
#   tests; it is intentionally NOT asserted here because the example workers do
#   not uniformly document their arguments, so the value would vary per worker.
# group: [vgi_integration]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# multiply: const fidelity duckdb_functions() can't show — factor is a const
# parameter (resolved at bind), value is a regular columnar parameter. Both
# positional. (Cast bools to text for stable sqllogictest column typing.)
query TTTT
SELECT arg_name, arg_type, is_positional::VARCHAR, is_const::VARCHAR
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'multiply'
ORDER BY arg_position;
----
value	BIGINT	true	false
factor	BIGINT	true	true

# double: AnyArrow argument surfaces as is_any_type with arg_type ANY.
query TTT
SELECT arg_name, arg_type, is_any_type::VARCHAR
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'double'
ORDER BY arg_position;
----
value	ANY	true

# A positional argument is never also named (mutually exclusive classification).
query I
SELECT count(*) FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND is_positional AND is_named;
----
0

# The arg_description column is queryable across every row regardless of
# whether the worker documents the argument (NULL when undocumented).
query I
SELECT (count(*) > 0)::INT FROM vgi_function_arguments()
WHERE catalog_name = 'example';
----
1

# Scoping by WHERE works and a non-existent catalog yields no rows.
query I
SELECT count(*) FROM vgi_function_arguments() WHERE catalog_name = 'does_not_exist';
----
0
