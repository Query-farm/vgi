# name: test/sql/integration/catalog/function_arguments_constraints.test
# description: vgi_function_arguments() surfaces per-argument constraint metadata for
#   agent discovery — arg_default (JSON scalar), arg_choices (JSON array), arg_range
#   (interval notation built from ge/le/gt/lt), and arg_pattern (regex). Anchored on
#   the fixture worker's `format_number` overloads, whose `precision` const parameter
#   declares a numeric range (ge=0, le=10) via the modern ConstParam API — and on
#   `multiply`, which declares no constraints (the absence contract). The `make_series`
#   table function proves the surface is function-kind-agnostic (its `count`/`step`
#   const args declare ranges through the same Arg(...) path) and that a table bind
#   enforces those ranges, not just surfaces them.
#
#   The arg_default/arg_choices/arg_range/arg_pattern columns are new to
#   vgi_function_arguments(), so this test needs a haybarn built from a source
#   tree that includes them. It is gated by `require-env VGI_TEST_ARG_CONSTRAINTS`
#   (set only by `make test_arg_constraints`, which runs the freshly-built local
#   binary) so it skips cleanly in the vgi-python integration suite, which drives
#   an older *pinned* published haybarn binary that lacks the columns. Drop the
#   gate once the pinned HAYBARN_RELEASE in vgi-python advances past this change.
# group: [vgi_integration]

require-env VGI_TEST_WORKER

require-env VGI_TEST_ARG_CONSTRAINTS

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# precision (a const param, shared across the format_number overloads) declares a
# numeric range → surfaces as interval notation in arg_range. DISTINCT collapses the
# identical rows the overloads contribute.
query TT
SELECT DISTINCT arg_name, arg_range
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'format_number' AND arg_name = 'precision';
----
precision	[0, 10]

# The unconstrained params of format_number carry no range (value across all
# overloads, prefix on the full overload).
query TT
SELECT DISTINCT arg_name, arg_range
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'format_number' AND arg_name <> 'precision'
ORDER BY arg_name;
----
prefix	NULL
value	NULL

# precision declares only a range — its choices / pattern / default stay NULL.
query TTTT
SELECT DISTINCT arg_name, arg_choices, arg_pattern, arg_default
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'format_number' AND arg_name = 'precision';
----
precision	NULL	NULL	NULL

# multiply declares no constraints — every constraint column is NULL (the absence
# contract: additive columns default to SQL NULL on functions that don't use them).
query TTTTT
SELECT arg_name, arg_default, arg_choices, arg_range, arg_pattern
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'multiply'
ORDER BY arg_position;
----
value	NULL	NULL	NULL	NULL
factor	NULL	NULL	NULL	NULL

# make_series is a *table* function: its `count` (ge=0) and `step` (ge=1) const args
# declare numeric ranges through the same Arg(...) path as scalar params, so the
# discovery surface is function-kind-agnostic. DISTINCT collapses the overloads (the
# unconstrained start/stop/values args and the float-overload `step` stay NULL and are
# excluded by the IS NOT NULL guard).
query TT
SELECT DISTINCT arg_name, arg_range
FROM vgi_function_arguments()
WHERE catalog_name = 'example' AND function_name = 'make_series' AND arg_range IS NOT NULL
ORDER BY arg_name;
----
count	[0, +inf)
step	[1, +inf)

# Surfacing isn't the whole contract: a table bind *enforces* the declared range too.
# count declares ge=0, so a negative constant is rejected before the scan runs, while
# an in-range constant binds cleanly.
statement error
SELECT * FROM example.make_series(-1);
----

statement ok
SELECT * FROM example.make_series(3);
