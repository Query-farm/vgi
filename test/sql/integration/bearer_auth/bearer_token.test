# name: test/sql/integration/bearer_auth/bearer_token.test
# description: Tests for bearer_token ATTACH option with HTTP transport
# group: [vgi_integration_bearer_auth]

require-env VGI_TEST_WORKER

require-env VGI_TEST_BEARER_TOKEN

require vgi

require httpfs

# ============================================================================
# ATTACH with bearer_token succeeds
# ============================================================================

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', bearer_token '${VGI_TEST_BEARER_TOKEN}');

# ============================================================================
# Basic scalar function works with bearer auth
# ============================================================================

query I
SELECT example.double(21);
----
42

# ============================================================================
# Table function works with bearer auth
# ============================================================================

query I
SELECT count(*) > 0 FROM example.main.projected_data(10);
----
true

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;

# ============================================================================
# ATTACH with wrong bearer_token fails
# ============================================================================

statement error
ATTACH 'example' AS example_bad (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', bearer_token 'wrong-token');
----
bearer token was rejected

# ============================================================================
# bearer_token and oauth_refresh_token are mutually exclusive
# ============================================================================

statement error
ATTACH 'example' AS example_both (TYPE vgi, LOCATION '${VGI_TEST_WORKER}', bearer_token 'token', oauth_refresh_token 'token');
----
Cannot specify both bearer_token and oauth_refresh_token
