# name: test/sql/integration/table_in_out/table_buffering_projection_filters.test
# description: Projection + filter pushdown for the buffered Sink+Source path.
#   Mirrors echo/projection_filters.test for the streaming TableFunctionGenerator
#   path, using the EchoBufferingFunction fixture (TableBufferingFunction
#   subclass with projection_pushdown + filter_pushdown + auto_apply_filters
#   all True). Verifies that pushdown plumbing reaches the worker's
#   finalize() output: framework narrows params.output_schema via
#   project_schema, and _FilteringOutputCollector applies pushdown filters
#   automatically.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Projection pushdown — single column from multi-column input
# ============================================================================

query I
SELECT a FROM example.echo_buffering((SELECT 1 AS a, 2 AS b, 3 AS c));
----
1

query I
SELECT b FROM example.echo_buffering((SELECT 1 AS a, 2 AS b, 3 AS c));
----
2

query I
SELECT c FROM example.echo_buffering((SELECT 1 AS a, 2 AS b, 3 AS c));
----
3

# Subset of columns — preserves SELECT order on the wire.
query II
SELECT a, c FROM example.echo_buffering((SELECT 1 AS a, 2 AS b, 3 AS c));
----
1	3

query II
SELECT b, a FROM example.echo_buffering((SELECT 1 AS a, 2 AS b, 3 AS c));
----
2	1

# Multi-row projection.
query I
SELECT x FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y)));
----
1
2
3

query I
SELECT y FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y)));
----
a
b
c

# Larger dataset — verify the aggregate matches.
query II
SELECT COUNT(*), SUM(n) FROM (
    SELECT n FROM example.echo_buffering(
        (SELECT unnest(generate_series(1, 100)) AS n, 'constant' AS label)
    )
);
----
100	5050

# ============================================================================
# Filter pushdown — constant comparisons
# ============================================================================

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x = 2;
----
2	b

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x > 1;
----
2	b
3	c

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x < 3;
----
1	a
2	b

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x >= 2;
----
2	b
3	c

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x <= 2;
----
1	a
2	b

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x != 2;
----
1	a
3	c

# ============================================================================
# Filter pushdown — string filters
# ============================================================================

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'apple'), (2, 'banana'), (3, 'cherry')) t(id, fruit))) WHERE fruit = 'banana';
----
2	banana

# ============================================================================
# Filter pushdown — range filters (AND)
# ============================================================================

query I
SELECT n FROM example.echo_buffering((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n >= 3 AND n <= 7;
----
3
4
5
6
7

query I
SELECT n FROM example.echo_buffering((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n > 4 AND n < 6;
----
5

# ============================================================================
# Filter pushdown — IN filter
# ============================================================================

query I
SELECT n FROM example.echo_buffering((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n IN (2, 4, 6, 8);
----
2
4
6
8

query II
SELECT * FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c'), (4, 'd')) t(id, letter))) WHERE letter IN ('a', 'c');
----
1	a
3	c

# ============================================================================
# Filter pushdown — IS NULL / IS NOT NULL
# ============================================================================

query I
SELECT n FROM example.echo_buffering((SELECT * FROM (VALUES (1), (NULL), (3), (NULL), (5)) t(n))) WHERE n IS NOT NULL;
----
1
3
5

query I
SELECT n FROM example.echo_buffering((SELECT * FROM (VALUES (1), (NULL), (3), (NULL), (5)) t(n))) WHERE n IS NULL;
----
NULL
NULL

# ============================================================================
# Combined projection + filter pushdown
# ============================================================================

query I
SELECT x FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x > 1;
----
2
3

# Filter column NOT in the projected output — exercises the
# column_ids-vs-projection_ids split: the worker still receives the
# filter column on the wire (column_ids includes x), but only emits the
# projected column (y).
query I
SELECT y FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x = 2;
----
b

query I
SELECT id FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'apple', 100), (2, 'banana', 200), (3, 'cherry', 300)) t(id, fruit, price))) WHERE price > 150;
----
2
3

query II
SELECT id, fruit FROM example.echo_buffering((SELECT * FROM (VALUES (1, 'apple', 100), (2, 'banana', 200), (3, 'cherry', 300)) t(id, fruit, price))) WHERE price >= 200;
----
2	banana
3	cherry

# ============================================================================
# Buffered-specific — multi-batch input with filter
# ============================================================================
# Stresses the cross-tick contract: process() buffers all input batches,
# combine() collapses to one finalize_state_id, finalize() drains one
# batch per tick. The framework's projection narrowing applies per-tick;
# auto-apply filters wrap the OutputCollector for every tick.

statement ok
CREATE TEMP TABLE wide AS SELECT v AS n, v*10 AS m, v*100 AS p FROM range(50) t(v);

query II
SELECT COUNT(*), SUM(n) FROM (
    SELECT n FROM example.echo_buffering((SELECT * FROM wide)) WHERE n >= 10 AND n < 20
);
----
10	145

# Filter on non-projected column across batches.
query II
SELECT COUNT(*), SUM(m) FROM (
    SELECT m FROM example.echo_buffering((SELECT * FROM wide)) WHERE p > 2500
);
----
24	9000

# ============================================================================
# ORDER BY + LIMIT — exercises the OPTIONAL_FILTER swallow path in
# VgiSerializeFilters (Top-N pushes a DynamicFilter that we can't
# serialize; the streaming reference handles this by skipping it, and the
# buffered path inherits the same behavior).
# ============================================================================

query I
SELECT n FROM example.echo_buffering((SELECT unnest(generate_series(1, 100)) AS n)) ORDER BY n LIMIT 5;
----
1
2
3
4
5

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
