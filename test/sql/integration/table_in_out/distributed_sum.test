# name: test/sql/integration/table_in_out/distributed_sum.test
# description: Integration tests for VGI distributed sum table-in-out functions
# group: [vgi_integration_table_in_out]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sum_all_columns_simple_distributed function
# Distributed column-wise sum aggregation (generator API)
# Args: data (TABLE) - input table with numeric columns
# ============================================================================

# ----------------------------------------------------------------------------
# Basic sum - single row
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns_simple_distributed((SELECT 1 AS a, 2 AS b));
----
1	2

# ----------------------------------------------------------------------------
# Multiple rows
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns_simple_distributed((SELECT * FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)));
----
9	12

# Verify: a = 1+3+5 = 9, b = 2+4+6 = 12

# ----------------------------------------------------------------------------
# Larger dataset
# ----------------------------------------------------------------------------

query I
SELECT n FROM example.sum_all_columns_simple_distributed((SELECT unnest(generate_series(1, 100)) AS n));
----
5050

# Verify: sum(1..100) = 5050

# ----------------------------------------------------------------------------
# Very large datasets (10,000+ rows to span multiple batches)
# ----------------------------------------------------------------------------

# 10,000 rows
query I
SELECT n FROM example.sum_all_columns_simple_distributed((SELECT unnest(generate_series(1, 10000)) AS n));
----
50005000

# 12,000 rows
query I
SELECT n FROM example.sum_all_columns_simple_distributed((SELECT unnest(generate_series(1, 12000)) AS n));
----
72006000

# Multiple columns with 10,000 rows
query II
SELECT * FROM example.sum_all_columns_simple_distributed((
    SELECT unnest(generate_series(1, 10000)) AS a,
           unnest(generate_series(10001, 20000)) AS b
));
----
50005000	150005000

# ============================================================================
# Edge cases
# ============================================================================

# All zeros
query I
SELECT n FROM example.sum_all_columns_simple_distributed((SELECT 0 AS n FROM (SELECT unnest(generate_series(1, 100)))));
----
0

# Negative numbers
query I
SELECT n FROM example.sum_all_columns_simple_distributed((SELECT * FROM (VALUES (-1), (-2), (-3), (6)) t(n)));
----
0

# Wide tables
query IIII
SELECT * FROM example.sum_all_columns_simple_distributed((
    SELECT * FROM (VALUES (1, 2, 3, 4), (10, 20, 30, 40), (100, 200, 300, 400)) t(c1, c2, c3, c4)
));
----
111	222	333	444

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
