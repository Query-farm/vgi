# name: test/sql/integration/table_in_out/tableinout_multibatch_repro.test
# description: Regression test for the table-in-out multi-source-pipeline input
#   desync (NOW FIXED), run against the CANONICAL Python worker (vgi-python
#   vgi-fixture-worker) so the result is decisive across SDKs. A relation built
#   from UNION ALL of literal SELECTs is fed to the streaming table-in-out
#   operator from one source sub-pipeline per branch; DuckDB's PipelineExecutors
#   for those branches can run CONCURRENTLY against the operator's single shared
#   worker connection (cf. DuckDB issue #18222). The original bug: their 1:1
#   write→read exchanges interleaved on the one schema-first IPC stream and
#   desynced ("Invalid flatbuffers message"; Rust's vgi-rpc-rust wire.rs
#   StreamReader::new words it "expected Schema, got RecordBatch").
#
#   THE FIX: VgiTableInOutGlobalState::exchange_mutex serializes each per-batch
#   write→read on the shared connection, so concurrent branch executors no longer
#   interleave. Streaming is preserved — input is NOT buffered.
#
#   HISTORY: the failure tracked the table-in-out KIND, not the worker language.
#   The STREAMING kind (`echo`) failed; the BUFFERING kind (`buffer_input`) was
#   always immune (it coalesces sub-pipelines in a Sink+Source operator). The
#   canonical Python worker reproduced it, proving the defect was shared client
#   framing, not Rust-only. See the Rust apples-to-apples in
#   tableinout_multibatch_repro_rust.test (eval_all).
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# CONTROL A — streaming echo, single-batch VALUES input. Must PASS.
# ----------------------------------------------------------------------------
query I
SELECT * FROM example.echo((
    SELECT * FROM (VALUES (1::BIGINT), (2::BIGINT), (3::BIGINT)) t(x)
)) ORDER BY 1;
----
1
2
3

# ----------------------------------------------------------------------------
# CONTROL B — streaming echo, MULTI-batch but SINGLE source operator
# (range(5000) >> the 2048-row batch size). This proves the trigger is the
# multi-SOURCE-pipeline shape, not row count / batch count: a single scan that
# emits many RecordBatches under one Schema stays in lockstep. Must PASS.
# ----------------------------------------------------------------------------
query II
SELECT count(*), sum(x) FROM example.echo((
    SELECT i::BIGINT AS x FROM range(5000) t(i)
)) t2(x);
----
5000	12497500

# ----------------------------------------------------------------------------
# REPRO — streaming echo, SAME logical rows as CONTROL A but built from
# UNION ALL of literal SELECTs (one source sub-pipeline / sub-stream per
# branch). FIXED: the per-batch write→read exchange on the operator's single
# shared connection is now serialized (VgiTableInOutGlobalState::exchange_mutex),
# so the concurrent branch PipelineExecutors no longer interleave IPC on the one
# stream. Must now PASS.
# ----------------------------------------------------------------------------
query I
SELECT * FROM example.echo((
    SELECT 1::BIGINT
    UNION ALL
    SELECT 2::BIGINT
    UNION ALL
    SELECT 3::BIGINT
)) ORDER BY 1;
----
1
2
3

# ----------------------------------------------------------------------------
# CONTRAST — the BUFFERING kind (buffer_input) is IMMUNE to the same input.
# Identical UNION-ALL relation, emitted in full. This localizes the defect to
# the STREAMING table-in-out exchange, and rules out "Rust vs Python": the same
# Python worker passes buffering and fails streaming.
# ----------------------------------------------------------------------------
query I
SELECT * FROM example.buffer_input((
    SELECT 1::BIGINT
    UNION ALL
    SELECT 2::BIGINT
    UNION ALL
    SELECT 3::BIGINT
)) ORDER BY 1;
----
1
2
3

# ----------------------------------------------------------------------------
# HARDENING — extra multi-source-pipeline shapes that all hit the same fixed
# concurrent-exchange path. All must PASS.
# ----------------------------------------------------------------------------

# 5-branch UNION ALL of literals.
query II
SELECT count(*), sum(x) FROM example.echo((
    SELECT 10::BIGINT UNION ALL SELECT 20 UNION ALL SELECT 30
    UNION ALL SELECT 40 UNION ALL SELECT 50
)) t(x);
----
5	150

# UNION ALL of two multi-batch range() scans (each branch is its own
# source sub-pipeline AND emits many RecordBatches).
query II
SELECT count(*), sum(x) FROM example.echo((
    SELECT i::BIGINT AS x FROM range(3000) t(i)
    UNION ALL
    SELECT i::BIGINT AS x FROM range(3000) t(i)
)) t2(x);
----
6000	8997000

# Streaming echo fed by a JOIN (multi-pipeline source), then re-streamed.
query I
SELECT count(*) FROM example.echo((
    SELECT a.x::BIGINT AS x
    FROM (VALUES (1),(2),(3)) a(x)
    JOIN (VALUES (1),(2),(3),(1)) b(x) USING (x)
)) t(x);
----
4

# Parallelism stress: many-branch UNION ALL under multiple threads — exercises
# the exchange_mutex across concurrent branch PipelineExecutors.
statement ok
SET threads = 8;

query II
SELECT count(*), sum(x) FROM example.echo((
    SELECT i::BIGINT AS x FROM range(2000) t(i)
    UNION ALL SELECT i::BIGINT FROM range(2000) t(i)
    UNION ALL SELECT i::BIGINT FROM range(2000) t(i)
    UNION ALL SELECT i::BIGINT FROM range(2000) t(i)
)) t2(x);
----
8000	7996000

statement ok
RESET threads;

statement ok
DETACH example;
