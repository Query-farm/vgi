# name: test/sql/integration/table_in_out/exceptions.test
# description: Integration tests for VGI exception-raising table-in-out functions
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# exception_finalize function
# Test function that raises exception during finalize phase
# Args: data (TABLE) - input table with numeric columns
# ============================================================================

# This should fail with "Intentional exception during finalize()"
statement error
SELECT * FROM example.exception_finalize((SELECT 1 AS a, 2 AS b));
----
Intentional exception during finalize()

# ============================================================================
# exception_process function
# Test function that raises exception on second batch during process phase
# Note: This function inherits from SumAllColumnsFunction but raises
# an exception on every second batch (batch_index % 2 == 0)
# ============================================================================

# 3000 rows exceeds the 2048-row batch size, so the worker receives 2 batches.
# batch_count reaches 2 → batch_count % 2 == 0 → raises exception
statement error
SELECT * FROM example.exception_process((
    SELECT unnest(generate_series(1, 3000)) AS a, unnest(generate_series(1, 3000)) AS b
));
----
Intentional exception on batch 2

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
