# name: test/sql/integration/table_in_out/buffered_worker_crash.test
# description: Worker SIGKILLs itself during table_buffering.process —
#   verify the C++ side surfaces a clean error and the pool recovers so
#   the next query against the same catalog succeeds on a fresh worker.
#
# Dedicated-worker only: crash_on_process calls os.kill(getpid(), SIGKILL)
# inside the worker. Under subprocess transport that kills only the per-
# DuckDB-process worker child, which is what this test asserts. Under any
# shared-worker transport (http://, https://, unix://, launch:) it would
# tear down the single process serving every concurrent test, cascading
# into "RPC response stream EOF" failures across the suite. The
# VGI_TEST_DEDICATED_WORKER env var is set by Makefile test_subprocess*
# targets and auto-detected by scripts/run_tests.py from a bare-path
# VGI_TEST_WORKER; shared-worker runs leave it unset so this test skips.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require-env VGI_TEST_DEDICATED_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Worker SIGKILL mid-process — the unary RPC's response stream ends without
# a schema; ReadUnaryResponse throws IOException. Sub-pipeline tears down
# and any peer/in-flight workers are cancel-dispatched.
# ----------------------------------------------------------------------------

statement error
SELECT * FROM example.crash_on_process((SELECT 1::BIGINT AS v));
----
RPC response stream EOF

# ----------------------------------------------------------------------------
# Recovery: pool entries should not be poisoned. A subsequent buffered query
# against the same catalog must succeed — this proves the operator's error
# path did not leak in-flight workers and that the pool's stale-conn retry
# (AcquireAndBindConnection) gets a fresh worker.
# ----------------------------------------------------------------------------

query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(100) AS t(v)));
----
100

query I
SELECT * FROM example.sum_all_columns((SELECT * FROM range(10) AS t(v)));
----
45

statement ok
DETACH example;
