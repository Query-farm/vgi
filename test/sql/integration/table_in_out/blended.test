# name: test/sql/integration/table_in_out/blended.test
# description: Phase B — blended ("UNNEST-style") table-in-out functions. A blended
#   function's POSITIONAL args ARE its per-row input columns (real typed args, no
#   synthetic TABLE placeholder), so ONE registration serves the literal call
#   (f(52,13) -> PhysicalTableScan single-row scan-mode), the column call (FROM t,
#   f(t.x,t.y) -> streaming), and LATERAL (f(t.x,t.y)). Covers the simple fixture
#   (geo_encode), an arity overload sharing the name (geo_encode3), and a VARARGS
#   fixture (row_sum). Inline named args in the FROM-clause forms are a separate
#   follow-up (a Haybarn binder patch); not exercised here.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require vgi

# HTTP transport ATTACH needs httpfs loaded (else a "VGI HTTP transport requires
# the httpfs extension" error — containing "HTTP" — makes the harness silently
# skip the whole file). Harmless on subprocess.
require httpfs

statement ok
ATTACH 'example' AS ex (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ---------------------------------------------------------------------------
# simple blended: geo_encode(latitude, longitude) -> geohash
# ---------------------------------------------------------------------------

# LITERAL form — the PhysicalTableScan single-row scan-mode risk: exactly one row,
# no infinite loop.
query I
SELECT geohash FROM ex.geo_encode(52.0, 13.0);
----
52.0:13.0

# integer literals cast to the DOUBLE signature (fixture normalizes to float)
query I
SELECT geohash FROM ex.geo_encode(52, 13);
----
52.0:13.0

# COLUMN form — streaming input, one output row per input row (order-checked)
query III
SELECT x, y, geohash FROM (VALUES (1.0, 2.0), (3.0, 4.0)) v(x, y), ex.geo_encode(v.x, v.y) ORDER BY x;
----
1.0	2.0	1.0:2.0
3.0	4.0	3.0:4.0

# LATERAL form — must NOT throw the FinalExecute/projected-input error (blended is
# no-finalize by design, so it participates in correlated lateral joins)
query III
SELECT x, y, geohash FROM (VALUES (10.0, 20.0), (30.0, 40.0)) v(x, y), LATERAL ex.geo_encode(v.x, v.y) ORDER BY x;
----
10.0	20.0	10.0:20.0
30.0	40.0	30.0:40.0

# 1 -> 0 (filter to no rows) is clean: no hang, no spurious rows
query I
SELECT count(*) FROM ex.geo_encode(1.0, 2.0) WHERE geohash IS NULL;
----
0

# catalog introspection: the args are REAL value types (DOUBLE), NOT a TABLE arg
# (DISTINCT because geo_encode has two arity overloads, both DOUBLE-typed).
query TT
SELECT DISTINCT arg_name, arg_type
FROM vgi_function_arguments()
WHERE catalog_name = 'ex' AND function_name = 'geo_encode' AND arg_name IN ('latitude', 'longitude')
ORDER BY arg_name;
----
latitude	DOUBLE
longitude	DOUBLE

# ---------------------------------------------------------------------------
# arity overload: geo_encode3 shares the name "geo_encode" with a 3rd column
# ---------------------------------------------------------------------------

# 3-arg literal resolves to the 3-positional overload
query I
SELECT geohash FROM ex.geo_encode(52.0, 13.0, 100.0);
----
52.0:13.0:100.0

# 3-arg column form
query I
SELECT geohash FROM (VALUES (1.0, 2.0, 3.0)) v(a, b, c), ex.geo_encode(v.a, v.b, v.c);
----
1.0:2.0:3.0

# ---------------------------------------------------------------------------
# VARARGS blended: row_sum(v1, v2, ...) sums the per-row input columns
# ---------------------------------------------------------------------------

# literal, 3 columns
query I
SELECT row_sum FROM ex.row_sum(1.0, 2.0, 3.0);
----
6.0

# literal, different arity (2 columns)
query I
SELECT row_sum FROM ex.row_sum(5.0, 5.0);
----
10.0

# column form, varargs
query IIII
SELECT a, b, c, row_sum FROM (VALUES (1.0, 2.0, 3.0), (10.0, 20.0, 30.0)) v(a, b, c), ex.row_sum(v.a, v.b, v.c) ORDER BY a;
----
1.0	2.0	3.0	6.0
10.0	20.0	30.0	60.0

# ---------------------------------------------------------------------------
# inline named args (opt := value) — the Haybarn binder patch extracts them
# BEFORE the input subquery sweep, so they work in the literal, column, AND
# LATERAL forms (not just the literal STANDARD path).
# ---------------------------------------------------------------------------

# literal + named
query I
SELECT row_sum FROM ex.row_sum(-1.0, -2.0, absolute := true);
----
3.0

# COLUMN form + named (row_sum(a, b) with absolute -> abs(a)+abs(b))
query I
SELECT row_sum FROM (VALUES (-1.0, -2.0), (3.0, -4.0)) v(a, b), ex.row_sum(v.a, v.b, absolute := true) ORDER BY 1;
----
3.0
7.0

# LATERAL form + named
query I
SELECT row_sum FROM (VALUES (-5.0, -5.0)) v(a, b), LATERAL ex.row_sum(v.a, v.b, absolute := true);
----
10.0

# a named value referencing an outer column is rejected (named args are constants)
statement error
SELECT row_sum FROM (VALUES (1.0, 2.0)) v(a, b), ex.row_sum(v.a, v.b, absolute := (v.a > 0));
----
does not support lateral join column parameters

# an unknown named param is rejected at bind
statement error
SELECT row_sum FROM (VALUES (1.0, 2.0)) v(a, b), ex.row_sum(v.a, v.b, nope := true);
----
Invalid named parameter

# a reserved SQL keyword works as a named param when quoted (literal form)
query I
SELECT geohash FROM ex.geo_encode(52.5, 13.4, "precision" := 1);
----
52.5:13.4

# ---------------------------------------------------------------------------
# edge cases (senior-review C1/M1)
# ---------------------------------------------------------------------------

# 1 -> 0 at the WORKER: a blended map whose whole output for the single input row
# is a 0-row batch. The literal scan-mode must skip the empty batch and finish
# cleanly at true EOS — NOT infinite-loop re-feeding the PhysicalTableScan input.
query I
SELECT count(*) FROM ex.blended_drop(1.0);
----
0

# zero-varargs childless call: row_sum() has no input columns -> the childless
# scan-mode path with an empty input schema (M1 all-names-empty signal). The point
# is it must COMPLETE (no infinite-loop hang), not a specific row count: over
# subprocess it yields one 0.0 row, but over HTTP a 0-column input batch loses its
# row count (an Arrow-IPC quirk) so the worker sees no rows and emits none. Assert
# only that it runs cleanly on both transports.
statement ok
SELECT row_sum FROM ex.row_sum();

# an AS alias in a table-function argument position is a parser error (so the
# named-vs-alias ambiguity for input columns never arises — you cannot write it).
statement error
SELECT * FROM (VALUES (1.0, 2.0)) v(a, b), ex.geo_encode(v.a AS foo, v.b);
----
syntax error

statement ok
DETACH ex;
