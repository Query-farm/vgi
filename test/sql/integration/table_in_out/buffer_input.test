# name: test/sql/integration/table_in_out/buffer_input.test
# description: Integration tests for VGI buffer_input table-in-out function
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# buffer_input function
# Buffers all input rows and emits them all during finalize.
# Tests that data is correctly accumulated and emitted in finalize phase.
# Args: data (TABLE) - input table to buffer
# ============================================================================

# ----------------------------------------------------------------------------
# Basic buffer - single row
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.buffer_input((SELECT 1 AS a, 2 AS b));
----
1	2

query I
SELECT * FROM example.buffer_input((SELECT 42 AS value));
----
42

# ----------------------------------------------------------------------------
# Multiple rows - all buffered and emitted in finalize
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.buffer_input((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y)));
----
1	a
2	b
3	c

query I
SELECT * FROM example.buffer_input((SELECT unnest([5, 4, 3, 2, 1]) AS n));
----
5
4
3
2
1

# ----------------------------------------------------------------------------
# Empty input
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.buffer_input((SELECT * FROM (VALUES (1, 'a')) t(x, y) WHERE false));
----

query I
SELECT COUNT(*) FROM example.buffer_input((SELECT * FROM (VALUES (1)) t(x) WHERE false));
----
0

# ----------------------------------------------------------------------------
# Larger dataset
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM example.buffer_input((SELECT unnest(generate_series(1, 500)) AS n));
----
500

query I
SELECT SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 100)) AS n));
----
5050

query II
SELECT MIN(n), MAX(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 200)) AS n));
----
1	200

# ----------------------------------------------------------------------------
# Very large datasets (10,000+ rows to span multiple batches)
# All data must be buffered and emitted in finalize
# ----------------------------------------------------------------------------

# 10,000 rows
query II
SELECT COUNT(*), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 10000)) AS n));
----
10000	50005000

# 12,000 rows - verify all data preserved across many batches
query IIII
SELECT COUNT(*), MIN(n), MAX(n), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 12000)) AS n));
----
12000	1	12000	72006000

# Multiple columns with 10,000 rows
query IIII
SELECT COUNT(*), SUM(a), SUM(b), SUM(a*b)
FROM example.buffer_input((
    SELECT unnest(generate_series(1, 10000)) AS a,
           unnest(generate_series(1, 10000)) AS b
));
----
10000	50005000	50005000	333383335000

# ----------------------------------------------------------------------------
# Verify data integrity after buffering
# The buffer_input should preserve all values exactly
# ----------------------------------------------------------------------------

query I
SELECT COUNT(*) FROM (
    SELECT n FROM example.buffer_input((SELECT unnest(generate_series(1, 100)) AS n))
    EXCEPT
    SELECT unnest(generate_series(1, 100)) AS n
);
----
0

# All values from buffer_input should be in original set
query I
SELECT COUNT(*) FROM (
    SELECT unnest(generate_series(1, 100)) AS n
    EXCEPT
    SELECT n FROM example.buffer_input((SELECT unnest(generate_series(1, 100)) AS n))
);
----
0

# Integrity check - 1000 rows (EXCEPT is expensive, so keep dataset small)
query I
SELECT COUNT(*) FROM (
    SELECT n FROM example.buffer_input((SELECT unnest(generate_series(1, 1000)) AS n))
    EXCEPT
    SELECT unnest(generate_series(1, 1000)) AS n
);
----
0

# ----------------------------------------------------------------------------
# Edge cases with NULL values
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.buffer_input((SELECT NULL::INTEGER AS n));
----
NULL

query II
SELECT * FROM example.buffer_input((SELECT * FROM (VALUES (1, NULL), (NULL, 2), (3, 3)) t(a, b)));
----
1	NULL
NULL	2
3	3

# NULLs with moderately large dataset
# NULL for every multiple of 3: i % 3 = 0 → NULL
# 1000 multiples of 3 in range 1-3000, so 2000 non-null values
# Sum(1..3000) = 4501500, Sum(multiples of 3) = 1501500
# Sum of non-nulls = 4501500 - 1501500 = 3000000
query III
SELECT COUNT(*), COUNT(n), SUM(n) FROM example.buffer_input((
    SELECT CASE WHEN i % 3 = 0 THEN NULL ELSE i END AS n
    FROM (SELECT unnest(generate_series(1, 3000)) AS i)
));
----
3000	2000	3000000

# ----------------------------------------------------------------------------
# Different data types
# ----------------------------------------------------------------------------

# Strings - 1000 rows
# Note: MAX(s) returns 'row_999' (length 7) because strings are compared lexicographically
query II
SELECT COUNT(*), LENGTH(MAX(s)) FROM example.buffer_input((
    SELECT 'row_' || i::VARCHAR AS s FROM (SELECT unnest(generate_series(1, 1000)) AS i)
));
----
1000	7

# Mixed types
query III
SELECT COUNT(*), SUM(int_col), COUNT(str_col)
FROM example.buffer_input((
    SELECT i AS int_col, 'str_' || i::VARCHAR AS str_col, i * 1.5 AS float_col
    FROM (SELECT unnest(generate_series(1, 1000)) AS i)
));
----
1000	500500	1000

# ----------------------------------------------------------------------------
# Very large datasets spanning many batches (20,000+ rows)
# DuckDB batch size is 2048, so 20,000 rows = ~10 batches
# ----------------------------------------------------------------------------

# 20,000 rows - verify all data buffered and emitted correctly
query IIII
SELECT COUNT(*), MIN(n), MAX(n), SUM(n)
FROM example.buffer_input((SELECT unnest(generate_series(1, 20000)) AS n));
----
20000	1	20000	200010000

# 25,000 rows with multiple columns
query IIII
SELECT COUNT(*), SUM(a), SUM(b), SUM(a*b)
FROM example.buffer_input((
    SELECT unnest(generate_series(1, 25000)) AS a,
           unnest(generate_series(25001, 50000)) AS b
));
----
25000	312512500	937512500	13021458337500

# ----------------------------------------------------------------------------
# Batch boundary edge cases
# Exactly 2048 rows (one full batch)
# ----------------------------------------------------------------------------

query II
SELECT COUNT(*), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 2048)) AS n));
----
2048	2098176

# 2049 rows (just over batch boundary)
query II
SELECT COUNT(*), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 2049)) AS n));
----
2049	2100225

# 4096 rows (exactly two batches)
query II
SELECT COUNT(*), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 4096)) AS n));
----
4096	8390656

# 4097 rows (just over two batches)
query II
SELECT COUNT(*), SUM(n) FROM example.buffer_input((SELECT unnest(generate_series(1, 4097)) AS n));
----
4097	8394753

# ----------------------------------------------------------------------------
# Stress test - very large dataset (50,000 rows)
# ----------------------------------------------------------------------------

query IIII
SELECT COUNT(*), MIN(n), MAX(n), SUM(n)
FROM example.buffer_input((SELECT unnest(generate_series(1, 50000)) AS n));
----
50000	1	50000	1250025000

# ----------------------------------------------------------------------------
# Data integrity - verify no data loss or corruption
# All input values should be in output, and vice versa
# ----------------------------------------------------------------------------

# 5000 rows - check distinct values preserved
query II
SELECT COUNT(*), COUNT(DISTINCT n)
FROM example.buffer_input((SELECT unnest(generate_series(1, 5000)) AS n));
----
5000	5000

# Verify exact row match using EXCEPT
query I
SELECT COUNT(*) FROM (
    SELECT n FROM example.buffer_input((SELECT unnest(generate_series(1, 5000)) AS n))
    EXCEPT
    SELECT unnest(generate_series(1, 5000)) AS n
);
----
0

# ----------------------------------------------------------------------------
# Wide table test (many columns)
# ----------------------------------------------------------------------------

query IIIIII
SELECT COUNT(*), SUM(c1), SUM(c2), SUM(c3), SUM(c4), SUM(c5)
FROM example.buffer_input((
    SELECT i AS c1, i*2 AS c2, i*3 AS c3, i*4 AS c4, i*5 AS c5
    FROM (SELECT unnest(generate_series(1, 5000)) AS i)
));
----
5000	12502500	25005000	37507500	50010000	62512500

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
