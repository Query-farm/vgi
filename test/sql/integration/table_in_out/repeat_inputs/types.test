# name: test/sql/integration/table_in_out/repeat_inputs/types.test
# description: Data type tests for VGI repeat_inputs table-in-out function
# group: [vgi_integration_table_in_out_repeat_inputs]

require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ----------------------------------------------------------------------------
# Output type validation (table-in-out passthrough)
# repeat_inputs passes input types through unchanged. These tests verify
# that the output column types match the input column types exactly.
# ----------------------------------------------------------------------------

# Integer types preserved
query IIII
SELECT typeof(a), typeof(b), typeof(c), typeof(d)
FROM example.repeat_inputs(1, (
    SELECT 1::INTEGER AS a, 2::BIGINT AS b, 3::SMALLINT AS c, 4::TINYINT AS d
));
----
INTEGER	BIGINT	SMALLINT	TINYINT

# Float types preserved
query II
SELECT typeof(a), typeof(b)
FROM example.repeat_inputs(1, (
    SELECT 1.0::DOUBLE AS a, 2.0::FLOAT AS b
));
----
DOUBLE	FLOAT

# String type preserved
query I
SELECT typeof(a)
FROM example.repeat_inputs(1, (
    SELECT 'hello'::VARCHAR AS a
));
----
VARCHAR

# Boolean type preserved
query I
SELECT typeof(a) FROM example.repeat_inputs(1, (SELECT true AS a));
----
BOOLEAN

# ----------------------------------------------------------------------------
# Different data types
# ----------------------------------------------------------------------------

# String data repeated
# MAX(s) is lexicographic: 'str_99' > 'str_500' because '9' > '5'
# So MAX(s) = 'str_99' with length 6
query II
SELECT COUNT(*), LENGTH(MAX(s)) FROM example.repeat_inputs(2, (
    SELECT 'str_' || i::VARCHAR AS s FROM (SELECT unnest(generate_series(1, 500)) AS i)
));
----
1000	6

# Mixed types
query III
SELECT COUNT(*), SUM(int_col), COUNT(str_col)
FROM example.repeat_inputs(2, (
    SELECT i AS int_col, 'val_' || i::VARCHAR AS str_col
    FROM (SELECT unnest(generate_series(1, 1000)) AS i)
));
----
2000	1001000	2000

# ----------------------------------------------------------------------------
# NULL handling
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.repeat_inputs(2, (SELECT * FROM (VALUES (1, NULL), (NULL, 2)) t(a, b)));
----
1	NULL
NULL	2
1	NULL
NULL	2

# ----------------------------------------------------------------------------
# Multiple columns with large data
# ----------------------------------------------------------------------------

query IIII
SELECT COUNT(*), SUM(a), SUM(b), MIN(a)
FROM example.repeat_inputs(2, (
    SELECT unnest(generate_series(1, 5000)) AS a,
           unnest(generate_series(5001, 10000)) AS b
));
----
10000	25005000	75005000	1

query IIII
SELECT COUNT(*), SUM(a), SUM(b), SUM(a+b)
FROM example.repeat_inputs(3, (
    SELECT unnest(generate_series(1, 5000)) AS a,
           unnest(generate_series(5001, 10000)) AS b
));
----
15000	37507500	112507500	150015000

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
