# name: test/sql/integration/table_in_out/logging.test
# description: Integration tests for VGI table-in-out functions with logging
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# sum_all_columns function
# Sums all columns and emits log messages during processing
# Args: data (TABLE) - input table with numeric columns
# ============================================================================

# ----------------------------------------------------------------------------
# Basic sum - single row (emits log messages)
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns((SELECT 1 AS a, 2 AS b));
----
1	2

# ----------------------------------------------------------------------------
# Multiple rows with sum aggregation
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns((SELECT * FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)));
----
9	12

# Verify: a = 1+3+5 = 9, b = 2+4+6 = 12

# ----------------------------------------------------------------------------
# Larger dataset
# ----------------------------------------------------------------------------

query I
SELECT n FROM example.sum_all_columns((SELECT unnest(generate_series(1, 100)) AS n));
----
5050

# Verify: sum(1..100) = 5050

# ----------------------------------------------------------------------------
# Very large datasets (10,000+ rows to span multiple batches)
# Log messages emitted for each batch, testing protocol handling
# ----------------------------------------------------------------------------

# 10,000 rows - multiple batches, each emits a log message
query I
SELECT n FROM example.sum_all_columns((SELECT unnest(generate_series(1, 10000)) AS n));
----
50005000

# 15,000 rows - more batches with log messages
query I
SELECT n FROM example.sum_all_columns((SELECT unnest(generate_series(1, 15000)) AS n));
----
112507500

# Multiple columns with 10,000 rows
query II
SELECT * FROM example.sum_all_columns((
    SELECT unnest(generate_series(1, 10000)) AS a,
           unnest(generate_series(10001, 20000)) AS b
));
----
50005000	150005000

# Four columns with 10,000 rows
query IIII
SELECT * FROM example.sum_all_columns((
    SELECT i AS c1, i*2 AS c2, i*3 AS c3, i*4 AS c4
    FROM (SELECT unnest(generate_series(1, 10000)) AS i)
));
----
50005000	100010000	150015000	200020000

# ----------------------------------------------------------------------------
# Single column
# ----------------------------------------------------------------------------

query I
SELECT x FROM example.sum_all_columns((SELECT 42 AS x));
----
42

# ----------------------------------------------------------------------------
# Three columns
# ----------------------------------------------------------------------------

query III
SELECT * FROM example.sum_all_columns((SELECT * FROM (VALUES (1, 10, 100), (2, 20, 200)) t(a, b, c)));
----
3	30	300

# ----------------------------------------------------------------------------
# Edge cases
# ----------------------------------------------------------------------------

# All zeros
query I
SELECT n FROM example.sum_all_columns((SELECT 0 AS n FROM (SELECT unnest(generate_series(1, 100)))));
----
0

# Negative numbers
query I
SELECT n FROM example.sum_all_columns((SELECT * FROM (VALUES (-1), (-2), (-3), (6)) t(n)));
----
0

# Mixed positive and negative with many batches
query I
SELECT n FROM example.sum_all_columns((
    SELECT CASE WHEN i % 2 = 0 THEN i ELSE -i END AS n
    FROM (SELECT unnest(generate_series(1, 10000)) AS i)
));
----
5000

# Large values
query I
SELECT n FROM example.sum_all_columns((SELECT * FROM (VALUES (1000000000), (2000000000), (3000000000)) t(n)));
----
6000000000

# Wide tables
query IIIIII
SELECT * FROM example.sum_all_columns((
    SELECT * FROM (VALUES (1, 2, 3, 4, 5, 6), (10, 20, 30, 40, 50, 60)) t(c1, c2, c3, c4, c5, c6)
));
----
11	22	33	44	55	66

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
