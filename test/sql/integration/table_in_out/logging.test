# name: test/sql/integration/table_in_out/logging.test
# description: Integration tests for VGI table-in-out functions with logging
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

require json

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Enable logging to capture worker log messages
statement ok
CALL enable_logging(level := 'debug');

statement ok
CALL truncate_duckdb_logs();

# ============================================================================
# sum_all_columns function with logging := true
# Sums all columns and emits log messages during processing
# Args: data (TABLE) - input table with numeric columns, logging (BOOL)
# ============================================================================

# ----------------------------------------------------------------------------
# Basic correctness with logging enabled
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns((SELECT 1 AS a, 2 AS b), logging := true);
----
1	2

query II
SELECT * FROM example.sum_all_columns((SELECT * FROM (VALUES (1, 2), (3, 4), (5, 6)) t(a, b)), logging := true);
----
9	12

# ----------------------------------------------------------------------------
# Large dataset - multiple batches, each emits a log message
# ----------------------------------------------------------------------------

statement ok
CALL truncate_duckdb_logs();

query I
SELECT n FROM example.sum_all_columns((SELECT unnest(generate_series(1, 10000)) AS n), logging := true);
----
50005000

# Verify worker log messages were captured via in-band logging
# The worker emits "Processing batch with N rows" for each batch when logging=true
query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%Processing batch with%';
----
true

# Multiple batches should produce multiple log messages (10000 rows > 2048 batch size)
query I
SELECT COUNT(*) >= 2 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%Processing batch with%';
----
true

# Verify log messages include standard context fields
query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%Processing batch with%' AND message LIKE '%level=INFO%';
----
true

query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%Processing batch with%' AND message LIKE '%worker_pid=%';
----
true

# ----------------------------------------------------------------------------
# Multi-column with logging
# ----------------------------------------------------------------------------

query II
SELECT * FROM example.sum_all_columns((
    SELECT unnest(generate_series(1, 10000)) AS a,
           unnest(generate_series(10001, 20000)) AS b
), logging := true);
----
50005000	150005000

# ----------------------------------------------------------------------------
# Edge cases with logging enabled
# ----------------------------------------------------------------------------

# All zeros
query I
SELECT n FROM example.sum_all_columns((SELECT 0 AS n FROM (SELECT unnest(generate_series(1, 100)))), logging := true);
----
0

# Negative numbers
query I
SELECT n FROM example.sum_all_columns((SELECT * FROM (VALUES (-1), (-2), (-3), (6)) t(n)), logging := true);
----
0

# Wide tables
query IIIIII
SELECT * FROM example.sum_all_columns((
    SELECT * FROM (VALUES (1, 2, 3, 4, 5, 6), (10, 20, 30, 40, 50, 60)) t(c1, c2, c3, c4, c5, c6)
), logging := true);
----
11	22	33	44	55	66

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
