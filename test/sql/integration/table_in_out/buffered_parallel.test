# name: test/sql/integration/table_in_out/buffered_parallel.test
# description: Buffered table functions with multiple DuckDB threads — exercises
#   per-thread Sink workers, combine merging, and pool release after the query.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET threads=8;

# ----------------------------------------------------------------------------
# buffer_input — wide input, parallel sink, correct row count
# ----------------------------------------------------------------------------

query I
SELECT count(*) FROM example.buffer_input((SELECT i::BIGINT FROM range(100000) t(i)));
----
100000

query I
SELECT sum(i) FROM example.buffer_input((SELECT i::BIGINT AS i FROM range(100000) t(i)));
----
4999950000

# ----------------------------------------------------------------------------
# sum_all_columns — parallel combine must converge to one row
# ----------------------------------------------------------------------------

query I
SELECT * FROM example.sum_all_columns((SELECT i::BIGINT FROM range(100000) t(i)));
----
4999950000

# ----------------------------------------------------------------------------
# Pool diagnostics — should be empty before, populated during, drained after.
# ----------------------------------------------------------------------------

statement ok
SELECT vgi_worker_pool_flush();

query I
SELECT count(*) FROM example.buffer_input((SELECT i::BIGINT FROM range(50000) t(i)));
----
50000

# Pool count is bounded by `threads` (one secondary worker per DuckDB sink
# thread) plus one for the coordinator, with no leaks from prior queries.
# Asserting `<= 16` catches a regression where pool entries grow unboundedly
# across queries. Over HTTP transport this is trivially true (the pool is
# always empty per CLAUDE.md's "Pool diagnostics are subprocess-only" note);
# the meaningful coverage is on subprocess.
query I
SELECT count(*) <= 16 FROM vgi_worker_pool();
----
true

# ============================================================================
# Multi-worker engagement assertions — verify parallelism actually engaged.
# The operator emits VGI_LOG events ("buffered_table.process",
# "buffered_table.finalize") with a `conn=` field per worker connection.
# Counting distinct conn= ids in those events proves N>1 workers ran.
# Same pattern as filter_echo_partitioned.test:142-149 for the streaming path.
# ============================================================================

statement ok
CALL enable_logging(level := 'debug');

statement ok
SET threads=4;

# We need an input that DuckDB actually parallelizes. `range()` is a single-
# thread TABLE_SCAN, so SELECT FROM range(N) would feed only one Sink thread.
# A TEMP TABLE scan IS parallel (morsel-driven), which gives the Sink side
# multiple input threads to spawn workers on.
statement ok
CREATE TEMP TABLE parallel_input AS SELECT v FROM range(200000) AS t(v);

# ----------------------------------------------------------------------------
# Parallel SINK — process events should come from ≥2 distinct conn= ids
# when threads=4 and the input is parallel-scannable.
# ----------------------------------------------------------------------------

statement ok
CALL truncate_duckdb_logs();

statement ok
SELECT count(*) FROM example.buffer_input((SELECT * FROM parallel_input));

query I
SELECT COUNT(DISTINCT regexp_extract(message, 'conn=([0-9a-f]+)', 1)) >= 2
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%buffered_table.process%';
----
true

# ----------------------------------------------------------------------------
# Parallel SOURCE — buffer_input.combine() returns state_ids unchanged, so
# finalize_queue ends up with N entries (one per sink thread). N source
# threads each pop a different finalize_state_id and run it on their own
# worker. Assert ≥2 distinct conn= ids in finalize events.
# ----------------------------------------------------------------------------

query I
SELECT COUNT(DISTINCT regexp_extract(message, 'conn=([0-9a-f]+)', 1)) >= 2
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%buffered_table.finalize%'
  AND message NOT LIKE '%combine%';
----
true

# ----------------------------------------------------------------------------
# A second query with the same shape — verifies repeatability and that the
# pool returned workers cleanly between queries.
# ----------------------------------------------------------------------------

statement ok
CALL truncate_duckdb_logs();

query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM parallel_input));
----
200000

query I
SELECT COUNT(DISTINCT regexp_extract(message, 'conn=([0-9a-f]+)', 1)) >= 2
FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%buffered_table.process%';
----
true

statement ok
RESET threads;

statement ok
DETACH example;
