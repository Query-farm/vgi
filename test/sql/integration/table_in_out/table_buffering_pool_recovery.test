# name: test/sql/integration/table_in_out/buffered_pool_recovery.test
# description: After a SIGKILL'd worker is "returned" to the pool (in spirit —
#   really it just exits), the next ATTACH+query gets a fresh worker. Exercises
#   AcquireAndBindConnection's stale-conn EPIPE retry on the buffered path,
#   and proves the pool doesn't retain dead PIDs.
#
# Dedicated-worker only — see buffered_worker_crash.test header for the
# explanation of why crash_on_process (which SIGKILLs its own process) is
# not safe under shared-worker transports.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require-env VGI_TEST_DEDICATED_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Warm the pool with one clean query so subsequent crashes are measured
# against a steady baseline (otherwise the misses counter is polluted by
# the cold-start cost of the very first acquire).
statement ok
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(5) AS t(v)));

# Snapshot the misses counter BEFORE we crash anything. We assert against
# the delta below — the post-crash absolute count tells us nothing without
# a baseline (the counter is process-cumulative and the first acquire of
# every worker_path is itself a miss).
statement ok
CREATE TEMP TABLE misses_baseline AS
SELECT COALESCE(SUM(misses), 0)::BIGINT AS m FROM vgi_worker_pool_stats();

# Crash once.
statement error
SELECT * FROM example.crash_on_process((SELECT 1::BIGINT AS v));
----
RPC response stream EOF

# Crash again — different worker (the previous crashed worker exited; we
# either get a fresh spawn or, if pooling reused a peer, the peer survives).
statement error
SELECT * FROM example.crash_on_process((SELECT 1::BIGINT AS v));
----
RPC response stream EOF

# Clean query after two crashes: pool entries must have drained / refreshed.
query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(20) AS t(v)));
----
20

# Pool diagnostics: any pooled worker still around must be a fresh one (not
# the killed PIDs). Bounded-count check proves we're not leaking entries.
query I
SELECT count(*) <= 32 FROM vgi_worker_subprocess_pool();
----
true

# Positive freshness check: every pooled PID must be valid (>0). A stale
# entry referring to a dead worker would have its PID set to whatever the
# subprocess wrapper had at acquire time — still >0 — so this is a sanity
# check, not a freshness proof. The real freshness signal is the misses
# delta below.
query I
SELECT count(*) = 0 FROM vgi_worker_subprocess_pool() WHERE pid <= 0;
----
true

# Misses DELTA — every crash forces the next ATTACH+Sink to fail its pool
# acquire (stale EPIPE) and spawn a fresh worker. We expect AT LEAST 2
# additional misses since the baseline (one per crash + recovery). Each
# crashed worker that the pool subsequently tries to hand out gets EPIPE
# on the next request, the pool drops it, and increments misses.
query I
SELECT
  (SELECT COALESCE(SUM(misses), 0)::BIGINT FROM vgi_worker_pool_stats())
  - (SELECT m FROM misses_baseline) >= 2;
----
true

# A few more queries to confirm pool churn behaves.
query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(5) AS t(v)));
----
5

query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(5) AS t(v)));
----
5

statement ok
DETACH example;
