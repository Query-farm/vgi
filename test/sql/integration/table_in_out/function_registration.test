# name: test/sql/integration/table_in_out/function_registration.test
# description: Validates table-in-out function registration metadata matches the VGI example worker specification
# group: [vgi_integration_table_in_out]

# Table-in-out functions registered by the example worker must expose consistent
# metadata through duckdb_functions() so that all VGI worker implementations
# (Python, Go, etc.) can be validated against the same expectations.
#
# Table-in-out functions appear as function_type='table' in duckdb_functions()
# and are distinguished by having a TABLE parameter type in their signature.

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Function Inventory — canonical specification fixtures.
#
# The example worker ships two categories of table-in-out functions:
#
#   * Canonical "specification" fixtures (listed below) — the documented
#     surface that cross-language workers (Python, Go, ...) must mirror.
#     This test pins their names, parameter shapes, descriptions, and
#     categories.
#
#   * Fault-injection / behavioural fixtures (``crash_on_*``, ``hang_*``,
#     ``exception_*``, ``ordered_buffer_input``, ``batch_index_buffer_input``,
#     ``large_state``) — exercise specific edge cases in the SQL test
#     suite; not part of the contract surface, may come and go. Excluded
#     from the inventory checks so adding a new fault-injection fixture
#     doesn't churn this file.
# ============================================================================

query T
SELECT function_name
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table'
AND function_name IN (
    'buffer_input', 'echo', 'exception_finalize', 'exception_process',
    'filter_by_setting', 'repeat_inputs', 'slow_cancellable_inout',
    'sum_all_columns', 'sum_all_columns_simple_distributed', 'unnest_tensor_rows'
)
ORDER BY function_name;
----
buffer_input
echo
exception_finalize
exception_process
filter_by_setting
repeat_inputs
slow_cancellable_inout
sum_all_columns
sum_all_columns_simple_distributed
unnest_tensor_rows

# Every canonical table-in-out fixture takes a TABLE-typed parameter — the
# whole point of the shape. Scoped to the named list (above) on purpose:
# the alternative — counting every table-in-out registration — bit-rotted
# silently every time a fault-injection fixture was added. Pin the assertion
# to the contract surface; expand the IN-list explicitly when a fixture
# graduates from "test plumbing" to "canonical specification".
query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table'
AND function_name IN (
    'buffer_input', 'echo', 'exception_finalize', 'exception_process',
    'filter_by_setting', 'repeat_inputs', 'slow_cancellable_inout',
    'sum_all_columns', 'sum_all_columns_simple_distributed', 'unnest_tensor_rows'
)
AND list_contains(parameter_types, 'TABLE');
----
10

# ============================================================================
# Per-function Registration
# Each query checks: name, parameters, parameter_types, description
# ============================================================================

# ----------------------------------------------------------------------------
# buffer_input — Collects all input, emits during finalization
# Parameters: data (TABLE)
# Single-table passthrough with buffering semantics
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'buffer_input';
----
buffer_input	[data]	[TABLE]	Collects all input batches and emits during finalization

# ----------------------------------------------------------------------------
# echo — Passthrough function (identity transform)
# Parameters: data (TABLE)
# Supports projection and filter pushdown
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'echo';
----
echo	[data]	[TABLE]	Passthrough function that emits each input batch unchanged

# ----------------------------------------------------------------------------
# filter_by_setting — Filters rows by threshold setting
# Parameters: data (TABLE)
# Uses the threshold DuckDB setting to filter rows
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'filter_by_setting';
----
filter_by_setting	[data]	[TABLE]	Filter rows where value column >= threshold setting

# ----------------------------------------------------------------------------
# exception_finalize — Raises exception during finalize phase (test function)
# Parameters: data (TABLE), logging (BOOLEAN named)
# Inherits parameter signature from sum_all_columns
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'exception_finalize';
----
exception_finalize	[data, logging]	[TABLE, BOOLEAN]	Test function that raises exception during finalize

# ----------------------------------------------------------------------------
# exception_process — Raises exception during process phase (test function)
# Parameters: data (TABLE), logging (BOOLEAN named)
# Inherits parameter signature from sum_all_columns
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'exception_process';
----
exception_process	[data, logging]	[TABLE, BOOLEAN]	Test function that raises exception during process

# ----------------------------------------------------------------------------
# repeat_inputs — Duplicates each input batch N times
# Parameters: repeat_count (BIGINT), data (TABLE)
# Note: repeat_count is positional (before the TABLE input)
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'repeat_inputs';
----
repeat_inputs	[repeat_count, data]	[BIGINT, TABLE]	Duplicates each input batch N times

# ----------------------------------------------------------------------------
# sum_all_columns — Column-wise aggregation of numeric columns
# Parameters: data (TABLE), logging (BOOLEAN named)
# Accumulates in process(), emits single row in finalize()
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sum_all_columns';
----
sum_all_columns	[data, logging]	[TABLE, BOOLEAN]	Computes column-wise sums across all batches

# ----------------------------------------------------------------------------
# sum_all_columns_simple_distributed — Distributed aggregation via callback API
# Parameters: data (TABLE)
# Uses ArrowSerializableDataclass for distributed state management
# ----------------------------------------------------------------------------

query TTTT
SELECT function_name, parameters, parameter_types, description
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sum_all_columns_simple_distributed';
----
sum_all_columns_simple_distributed	[data]	[TABLE]	Distributed sum using the buffered (Sink+Combine+Source) model

# ============================================================================
# Categories
# Functions declare categories for discoverability
# ============================================================================

query TT
SELECT function_name, categories
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'echo';
----
echo	[utility, debug]

query TT
SELECT function_name, categories
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'sum_all_columns';
----
sum_all_columns	[aggregation, numeric]

# ============================================================================
# Tags
# Worker-supplied Meta.tags must surface through duckdb_functions().tags.
# DuckDB's FunctionEntry ctor does not copy comment/tags from the CreateInfo
# (unlike schema/table/view/macro entries), so the VGI function-set builders
# set them on the constructed entry directly — without that these are empty.
# ============================================================================

query TT
SELECT map_extract(tags, 'category')[1], map_extract(tags, 'type')[1]
FROM duckdb_functions()
WHERE database_name = 'example' AND function_name = 'echo';
----
debug	passthrough

# ============================================================================
# No varargs
# None of the table-in-out functions use varargs
# ============================================================================

query I
SELECT COUNT(*)
FROM duckdb_functions()
WHERE database_name = 'example' AND function_type = 'table'
AND function_name IN (
    'buffer_input', 'echo', 'exception_finalize', 'exception_process',
    'filter_by_setting', 'repeat_inputs', 'sum_all_columns',
    'sum_all_columns_simple_distributed'
)
AND varargs IS NOT NULL;
----
0

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
