# name: test/sql/integration/table_in_out/echo/projection_filters.test
# description: Projection and filter pushdown tests for VGI echo table-in-out function
# group: [vgi_integration_table_in_out_echo]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# ============================================================================
# Projection pushdown tests
# ============================================================================

# Select single column from multi-column input
query I
SELECT a FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
1

query I
SELECT b FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
2

query I
SELECT c FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
3

# Select subset of columns
query II
SELECT a, c FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
1	3

query II
SELECT b, a FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
2	1

# Projection with multiple rows
query I
SELECT x FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y)));
----
1
2
3

query I
SELECT y FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y)));
----
a
b
c

# Projection on larger dataset - verify count and sum
query II
SELECT COUNT(*), SUM(n) FROM (SELECT n FROM example.echo((SELECT unnest(generate_series(1, 100)) AS n, 'constant' AS label)));
----
100	5050

# ============================================================================
# Filter pushdown tests - constant comparisons
# ============================================================================

# Equality filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x = 2;
----
2	b

# Greater than filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x > 1;
----
2	b
3	c

# Less than filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x < 3;
----
1	a
2	b

# Greater than or equal filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x >= 2;
----
2	b
3	c

# Less than or equal filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x <= 2;
----
1	a
2	b

# Not equal filter
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x != 2;
----
1	a
3	c

# ============================================================================
# Filter pushdown tests - string filters
# ============================================================================

# String equality
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'apple'), (2, 'banana'), (3, 'cherry')) t(id, fruit))) WHERE fruit = 'banana';
----
2	banana

# ============================================================================
# Filter pushdown tests - range filters (AND)
# ============================================================================

# Range filter
query I
SELECT n FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n >= 3 AND n <= 7;
----
3
4
5
6
7

# Tight range
query I
SELECT n FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n > 4 AND n < 6;
----
5

# ============================================================================
# Filter pushdown tests - IN filter
# ============================================================================

# IN filter with integers
query I
SELECT n FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n IN (2, 4, 6, 8);
----
2
4
6
8

# IN filter with strings
query II
SELECT * FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c'), (4, 'd')) t(id, letter))) WHERE letter IN ('a', 'c');
----
1	a
3	c

# ============================================================================
# Filter pushdown tests - IS NULL / IS NOT NULL
# ============================================================================

# IS NOT NULL filter
query I
SELECT n FROM example.echo((SELECT * FROM (VALUES (1), (NULL), (3), (NULL), (5)) t(n))) WHERE n IS NOT NULL;
----
1
3
5

# IS NULL filter
query I
SELECT n FROM example.echo((SELECT * FROM (VALUES (1), (NULL), (3), (NULL), (5)) t(n))) WHERE n IS NULL;
----
NULL
NULL

# ============================================================================
# Combined projection and filter pushdown
# ============================================================================

# Project single column with filter
query I
SELECT x FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x > 1;
----
2
3

# Project different column than filtered
query I
SELECT y FROM example.echo((SELECT * FROM (VALUES (1, 'a'), (2, 'b'), (3, 'c')) t(x, y))) WHERE x = 2;
----
b

# Filter on non-projected column
query I
SELECT id FROM example.echo((SELECT * FROM (VALUES (1, 'apple', 100), (2, 'banana', 200), (3, 'cherry', 300)) t(id, fruit, price))) WHERE price > 150;
----
2
3

# Multiple projected columns with filter
query II
SELECT id, fruit FROM example.echo((SELECT * FROM (VALUES (1, 'apple', 100), (2, 'banana', 200), (3, 'cherry', 300)) t(id, fruit, price))) WHERE price >= 200;
----
2	banana
3	cherry

# ============================================================================
# Larger dataset tests
# ============================================================================

# Filter on large dataset
query I
SELECT COUNT(*) FROM example.echo((SELECT unnest(generate_series(1, 10000)) AS n)) WHERE n > 9990;
----
10

# Projection on large dataset with filter
query I
SELECT SUM(n) FROM example.echo((SELECT unnest(generate_series(1, 1000)) AS n, 'x' AS label)) WHERE n <= 10;
----
55

# IN filter on large dataset
query I
SELECT COUNT(*) FROM example.echo((SELECT unnest(generate_series(1, 10000)) AS n)) WHERE n IN (100, 500, 1000, 5000, 9999);
----
5

# Range filter on large dataset
query I
SELECT COUNT(*) FROM example.echo((SELECT unnest(generate_series(1, 10000)) AS n)) WHERE n >= 5000 AND n < 5100;
----
100

# ============================================================================
# Aggregations with filters
# ============================================================================

# Count with filter
query I
SELECT COUNT(*) FROM example.echo((SELECT unnest(generate_series(1, 100)) AS n)) WHERE n > 50;
----
50

# Sum with filter
query I
SELECT SUM(n) FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n <= 5;
----
15

# Avg with filter
query R
SELECT AVG(n) FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n >= 6;
----
8.0

# Min/Max with filter
query II
SELECT MIN(n), MAX(n) FROM example.echo((SELECT unnest(generate_series(1, 100)) AS n)) WHERE n >= 25 AND n <= 75;
----
25	75

# ============================================================================
# Edge cases
# ============================================================================

# Filter that matches no rows
query I
SELECT * FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n > 100;
----

# Filter that matches all rows
query I
SELECT COUNT(*) FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n)) WHERE n > 0;
----
10

# Projection with empty result after filter
query I
SELECT n FROM example.echo((SELECT unnest(generate_series(1, 10)) AS n, 'label' AS s)) WHERE n > 100;
----

# ============================================================================
# Plan-shape assertions — projection pushdown is actually happening
# ============================================================================
# When projection pushes into the operator, the worker emits a narrow Arrow
# batch directly and DuckDB does NOT insert a PROJECTION node above
# INOUT_FUNCTION to narrow the output. If the capability advertisement gets
# dropped from vgi_table_function_set.cpp (or InitGlobal stops capturing
# column_ids), DuckDB falls back to inserting a narrowing PROJECTION above
# the operator — the negative regex below catches that.
#
# DOTALL (?s) is required so .* spans newlines. The input subquery's
# PROJECTION (a/b/c projection over the inner SELECT) always sits BELOW
# INOUT_FUNCTION in the rendered tree — and the rendered text shows the
# root first, so any PROJECTION ABOVE the operator appears BEFORE the
# INOUT_FUNCTION substring in the text.
#
# Verification that the regex has teeth: under
# `PRAGMA disabled_optimizers='unused_columns'` the assertion fails
# (DuckDB inserts a narrowing PROJECTION above INOUT_FUNCTION instead of
# pushing). Don't enable that pragma here — these queries run with the
# default optimizer set.

# Single-column projection from a 3-column subquery
query II
EXPLAIN SELECT b FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
physical_plan	<!REGEX>:(?s).*PROJECTION.*INOUT_FUNCTION.*

# Two-column subset (verifies projection_ids handling, not just single-col)
query II
EXPLAIN SELECT a, c FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c));
----
physical_plan	<!REGEX>:(?s).*PROJECTION.*INOUT_FUNCTION.*

# Projection + filter — confirms FILTER sits above the operator (correct,
# since DuckDB's planner doesn't push filters into InOut) while PROJECTION
# does NOT sit above (projection pushes in).
query II
EXPLAIN SELECT b FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c)) WHERE b > 0;
----
physical_plan	<!REGEX>:(?s).*PROJECTION.*INOUT_FUNCTION.*

# Same query — assert the FILTER node IS present above (positive match,
# pins the current "filter runs above operator" planner behavior).
query II
EXPLAIN SELECT b FROM example.echo((SELECT 1 AS a, 2 AS b, 3 AS c)) WHERE b > 0;
----
physical_plan	<REGEX>:(?s).*FILTER.*INOUT_FUNCTION.*

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DETACH example;
