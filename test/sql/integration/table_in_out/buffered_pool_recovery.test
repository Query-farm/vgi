# name: test/sql/integration/table_in_out/buffered_pool_recovery.test
# description: After a SIGKILL'd worker is "returned" to the pool (in spirit —
#   really it just exits), the next ATTACH+query gets a fresh worker. Exercises
#   AcquireAndBindConnection's stale-conn EPIPE retry on the buffered path,
#   and proves the pool doesn't retain dead PIDs.
# group: [vgi_integration_table_in_out]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'example' AS example (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Crash once.
statement error
SELECT * FROM example.crash_on_process((SELECT 1::BIGINT AS v));
----
RPC response stream EOF

# Crash again — different worker (the previous crashed worker exited; we
# either get a fresh spawn or, if pooling reused a peer, the peer survives).
statement error
SELECT * FROM example.crash_on_process((SELECT 1::BIGINT AS v));
----
RPC response stream EOF

# Clean query after two crashes: pool entries must have drained / refreshed.
query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(20) AS t(v)));
----
20

# Pool diagnostics: any pooled worker still around must be a fresh one (not
# the killed PIDs). We can't reliably enumerate them across HTTP, so just
# check count is bounded — proves we're not leaking entries unbounded.
query I
SELECT count(*) <= 32 FROM vgi_worker_pool();
----
true

# A few more queries to confirm pool churn behaves.
query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(5) AS t(v)));
----
5

query I
SELECT count(*) FROM example.buffer_input((SELECT * FROM range(5) AS t(v)));
----
5

statement ok
DETACH example;
