# name: test/sql/integration/writable/products.test
# description: Tests for INSERT with defaults, constraints, and RETURNING on writable_products
# group: [vgi_integration_writable]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'writable' AS writable (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CREATE TABLE writable.main.writable_products (product_id BIGINT NOT NULL UNIQUE, name VARCHAR NOT NULL, price DOUBLE NOT NULL DEFAULT 0.0 CHECK(price >= 0), status VARCHAR NOT NULL DEFAULT 'draft', created_at VARCHAR NOT NULL DEFAULT 'server-assigned');

# ============================================================================
# Default resolution — column-subset INSERT (price, status, created_at have defaults)
# ============================================================================

# product_id + name only: price=0.0, status='draft', created_at='server-assigned'
statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (1, 'Widget');

query IRT
SELECT name, price, status FROM writable.main.writable_products WHERE name = 'Widget';
----
Widget	0.0	draft

# product_id + name + price: status defaults to 'draft'
statement ok
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (2, 'Gadget', 19.99);

query IRT
SELECT name, price, status FROM writable.main.writable_products WHERE name = 'Gadget';
----
Gadget	19.99	draft

# All columns explicit (no defaults needed)
statement ok
INSERT INTO writable.main.writable_products(product_id, name, price, status, created_at) VALUES (100, 'Explicit', 5.0, 'active', '2026-01-01');

query IIRT
SELECT product_id, name, price, status FROM writable.main.writable_products WHERE name = 'Explicit';
----
100	Explicit	5.0	active

# ============================================================================
# Defaults visible in RETURNING
# ============================================================================

# RETURNING shows default price and status
query RT
INSERT INTO writable.main.writable_products(product_id, name) VALUES (3, 'RetDefault') RETURNING price, status;
----
0.0	draft

# RETURNING with name + price: status is default
query IRT
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (4, 'RetPrice', 9.99) RETURNING name, price, status;
----
RetPrice	9.99	draft

# NOTE: NOT NULL and CHECK constraint tests are deferred — errors from the
# transactor's DuckDB propagate as IO Errors which may break subsequent
# transactor connections in the same test session.

# ============================================================================
# Multi-row INSERT with defaults
# ============================================================================

statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (10, 'Alpha'), (11, 'Beta'), (12, 'Gamma');

query I
SELECT COUNT(*) FROM writable.main.writable_products WHERE status = 'draft' AND price = 0.0 AND name IN ('Alpha', 'Beta', 'Gamma');
----
3

# ============================================================================
# Multi-row INSERT with defaults + RETURNING
# ============================================================================

query IT
INSERT INTO writable.main.writable_products(product_id, name) VALUES (20, 'Ret1'), (21, 'Ret2'), (22, 'Ret3') RETURNING product_id, name;
----
20	Ret1
21	Ret2
22	Ret3

# ============================================================================
# INSERT with mixed defaults and explicit values
# ============================================================================

query IRT
INSERT INTO writable.main.writable_products(product_id, name, status) VALUES (30, 'Custom', 'published') RETURNING name, price, status;
----
Custom	0.0	published

# ============================================================================
# RETURNING with expression
# ============================================================================

query R
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (40, 'ExprTest', 25.0) RETURNING price * 2;
----
50.0

# ============================================================================
# RETURNING column subset
# ============================================================================

query I
INSERT INTO writable.main.writable_products(product_id, name) VALUES (50, 'SubsetRet') RETURNING name;
----
SubsetRet

# ============================================================================
# Cleanup before default value tests
# ============================================================================

statement ok
DELETE FROM writable.main.writable_products;

query I
SELECT COUNT(*) FROM writable.main.writable_products;
----
0

# ============================================================================
# Default values — INSERT with only required columns
# ============================================================================

statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (100, 'DefaultsTest');

query ITRTT
SELECT product_id, name, price, status, created_at FROM writable.main.writable_products WHERE product_id = 100;
----
100	DefaultsTest	0.0	draft	server-assigned

statement ok
DELETE FROM writable.main.writable_products WHERE product_id = 100;

# ============================================================================
# Default values — INSERT overriding all defaults
# ============================================================================

statement ok
INSERT INTO writable.main.writable_products(product_id, name, price, status, created_at) VALUES (101, 'OverrideTest', 49.99, 'active', '2026-01-01');

query ITRTT
SELECT product_id, name, price, status, created_at FROM writable.main.writable_products WHERE product_id = 101;
----
101	OverrideTest	49.99	active	2026-01-01

statement ok
DELETE FROM writable.main.writable_products WHERE product_id = 101;

# ============================================================================
# Default values — RETURNING shows defaults
# ============================================================================

query ITRTT
INSERT INTO writable.main.writable_products(product_id, name) VALUES (102, 'RetDefaults') RETURNING *;
----
102	RetDefaults	0.0	draft	server-assigned

statement ok
DELETE FROM writable.main.writable_products WHERE product_id = 102;

# ============================================================================
# CHECK constraint — price >= 0 violation
# ============================================================================

statement error
INSERT INTO writable.main.writable_products(product_id, name, price) VALUES (103, 'NegPrice', -1.0);
----
Constraint Error

# ============================================================================
# UNIQUE constraint — duplicate product_id
# ============================================================================

statement ok
INSERT INTO writable.main.writable_products(product_id, name) VALUES (200, 'First');

statement error
INSERT INTO writable.main.writable_products(product_id, name) VALUES (200, 'Duplicate');
----
Constraint Error

statement ok
DELETE FROM writable.main.writable_products WHERE product_id = 200;

# ============================================================================
# NOT NULL constraint — missing required name
# ============================================================================

statement error
INSERT INTO writable.main.writable_products(product_id, name) VALUES (201, NULL);
----
Constraint Error

statement ok
DROP TABLE writable.main.writable_products;
