# name: test/sql/vgi_integration.test
# description: test vgi extension with a real VGI worker
# group: [vgi]

# This test requires a VGI worker to be available
# Set VGI_TEST_WORKER environment variable to the path of a VGI worker executable
require-env VGI_TEST_WORKER

require vgi

# ============================================================================
# Test vgi_catalogs function
# ============================================================================

# Test vgi_catalogs returns at least 0 rows (the worker exists and responds)
query I
SELECT count(*) >= 0 FROM vgi_catalogs('${VGI_TEST_WORKER}');
----
true

# Verify the result is a table with a catalog column of VARCHAR type
query I
SELECT typeof(catalog) FROM vgi_catalogs('${VGI_TEST_WORKER}') LIMIT 1;
----
VARCHAR

# Test EXPLAIN with vgi_catalogs shows Worker in output
query II
EXPLAIN SELECT * FROM vgi_catalogs('${VGI_TEST_WORKER}');
----
physical_plan	<REGEX>:.*VGI_CATALOGS.*Worker:.*

# ============================================================================
# Test ATTACH with VGI catalog
# ============================================================================

# Test ATTACH with VGI catalog
statement ok
ATTACH 'example' AS vgi_test (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

# Test schema discovery - verify we can see the schemas
query II rowsort
SELECT catalog_name, schema_name FROM information_schema.schemata WHERE catalog_name = 'vgi_test';
----
vgi_test	data
vgi_test	main

# DETACH the catalog
statement ok
DETACH vgi_test;

# Test ATTACH with non-existent catalog returns proper error
statement error
ATTACH 'nonexistent_catalog' AS vgi_bad (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');
----
No worker handles catalog 'nonexistent_catalog'

# ============================================================================
# Test vgi_table_function with multi-worker execution and logging
# ============================================================================

require json

# Enable VGI logging
statement ok
CALL enable_logging(level := 'debug');

statement ok
CALL truncate_duckdb_logs();

# Test partitioned_sequence function with 1 million values
# This exercises multi-worker execution via work queue pattern
query IIII
SELECT COUNT(*) as total, COUNT(DISTINCT n) as distinct_count, MIN(n) as min_val, MAX(n) as max_val
FROM vgi_table_function('${VGI_TEST_WORKER}', 'partitioned_sequence', [1000000]);
----
1000000	1000000	0	999999

# Verify logging captured table function operations
query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%table_function.bind%';
----
true

# Verify batch_received events contain worker_pid
query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%batch_received%worker_pid=%';
----
true

# Verify multi-worker execution was attempted (at least one secondary worker spawned).
# Asserting on init_local rather than batch_received avoids a timing race where the
# primary can drain a small work queue before a freshly-spawned secondary picks up
# any chunks — the secondary still exists, it just didn't win any work items.
query I
SELECT COUNT(*) > 0 FROM duckdb_logs()
WHERE type = 'VGI' AND message LIKE '%table_function.init_local%worker_type=secondary%';
----
true

# Verify scan completed for at least one worker
query I
SELECT COUNT(*) > 0 FROM duckdb_logs() WHERE type = 'VGI' AND message LIKE '%scan_complete%';
----
true

# ============================================================================
# Test EXPLAIN with vgi_table_function
# ============================================================================

# EXPLAIN should work without hanging and show Worker/Function in output
query II
EXPLAIN SELECT * FROM vgi_table_function('${VGI_TEST_WORKER}', 'sequence', [10]);
----
physical_plan	<REGEX>:.*VGI_TABLE_FUNCTION.*Function: sequence.*
