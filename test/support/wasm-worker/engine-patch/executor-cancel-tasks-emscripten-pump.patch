--- a/src/parallel/executor.cpp
+++ b/src/parallel/executor.cpp
@@ -22,6 +22,11 @@
 #include <algorithm>
 #include <chrono>
 
+#if defined(__EMSCRIPTEN__)
+#include <emscripten/threading.h>
