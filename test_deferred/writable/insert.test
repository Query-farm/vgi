# name: test/sql/integration/writable/insert.test
# description: INSERT operations on VGI writable tables
# group: [vgi_integration_writable]

require-env VGI_TEST_WORKER

require vgi

require httpfs

statement ok
ATTACH 'writable' AS writable (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
CREATE TABLE writable.main.writable_data (id BIGINT NOT NULL, name VARCHAR NOT NULL);

statement ok
DELETE FROM writable.main.writable_data;

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
0

# ============================================================================
# INSERT VALUES — single row
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (1, 'hello');

query II
SELECT id, name FROM writable.main.writable_data;
----
1	hello

# ============================================================================
# INSERT VALUES — multiple rows in one statement
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (2, 'world'), (3, 'test');

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
3

query II
SELECT id, name FROM writable.main.writable_data ORDER BY id;
----
1	hello
2	world
3	test

# ============================================================================
# INSERT ... SELECT — from a DuckDB-local query
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'row_' || i::VARCHAR FROM range(4, 7) t(i);

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
6

query II
SELECT id, name FROM writable.main.writable_data WHERE id >= 4 ORDER BY id;
----
4	row_4
5	row_5
6	row_6

# ============================================================================
# INSERT ... SELECT — large batch (thousands of rows, multiple vector batches)
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'bulk_' || i::VARCHAR FROM range(1000, 6000) t(i);

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id >= 1000;
----
5000

# Verify first and last rows of the bulk insert
query II
SELECT id, name FROM writable.main.writable_data WHERE id = 1000;
----
1000	bulk_1000

query II
SELECT id, name FROM writable.main.writable_data WHERE id = 5999;
----
5999	bulk_5999

# ============================================================================
# INSERT — empty (zero rows)
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'nope' FROM range(0) t(i);

# ============================================================================
# INSERT — type edge cases
# ============================================================================

# Negative numbers
statement ok
INSERT INTO writable.main.writable_data VALUES (-1, 'negative');

# Empty string
statement ok
INSERT INTO writable.main.writable_data VALUES (-2, '');

# Long string
statement ok
INSERT INTO writable.main.writable_data VALUES (-3, repeat('x', 10000));

query II
SELECT id, name FROM writable.main.writable_data WHERE id = -1;
----
-1	negative

query II
SELECT id, name FROM writable.main.writable_data WHERE id = -2;
----
-2	(empty)

query I
SELECT length(name) FROM writable.main.writable_data WHERE id = -3;
----
10000

# ============================================================================
# INSERT — duplicate values (no unique constraint on id, should succeed)
# ============================================================================

statement ok
INSERT INTO writable.main.writable_data VALUES (1, 'duplicate_of_hello');

query I
SELECT COUNT(*) FROM writable.main.writable_data WHERE id = 1;
----
2

# ============================================================================
# INSERT ... RETURNING — single row
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9001, 'returning_test') RETURNING id, name;
----
9001	returning_test

# Verify it was actually inserted
query II
SELECT id, name FROM writable.main.writable_data WHERE id = 9001;
----
9001	returning_test

# ============================================================================
# INSERT ... RETURNING — multiple rows
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9002, 'ret_a'), (9003, 'ret_b') RETURNING id, name;
----
9002	ret_a
9003	ret_b

# ============================================================================
# INSERT ... RETURNING — with INSERT ... SELECT
# ============================================================================

query II
INSERT INTO writable.main.writable_data SELECT i, 'ret_sel_' || i::VARCHAR FROM range(9010, 9013) t(i) RETURNING id, name;
----
9010	ret_sel_9010
9011	ret_sel_9011
9012	ret_sel_9012

# ============================================================================
# INSERT ... RETURNING * — all columns
# ============================================================================

query II
INSERT INTO writable.main.writable_data VALUES (9999, 'star_test') RETURNING *;
----
9999	star_test

# ============================================================================
# INSERT ... RETURNING — column subset (only id)
# ============================================================================

query I
INSERT INTO writable.main.writable_data VALUES (9050, 'partial_ret') RETURNING id;
----
9050

# ============================================================================
# INSERT ... RETURNING — with expression
# ============================================================================

query I
INSERT INTO writable.main.writable_data VALUES (9060, 'expr_test') RETURNING id * 2;
----
18120

# ============================================================================
# Large INSERT ... RETURNING (multi-batch, >2048 rows)
# ============================================================================

statement ok
DELETE FROM writable.main.writable_data;

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
0

statement ok
INSERT INTO writable.main.writable_data SELECT i, 'ret_' || i::VARCHAR FROM range(0, 5000) t(i);

query I
SELECT COUNT(*) FROM writable.main.writable_data;
----
5000

statement ok
DROP TABLE writable.main.writable_data;
