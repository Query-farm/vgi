{
        "dependencies": [
                "openssl",
                "curl",
                {
                        "name": "arrow",
                        "default-features": false,
                        "features": [
                                { "name": "mimalloc", "platform": "(linux | (osx & arm64)) & !emscripten" }
                        ]
                }
        ],
        "vcpkg-configuration": {
                "overlay-ports": [
                        "./vcpkg_ports",
                        "./extension-ci-tools/vcpkg_ports"
                ],
                "overlay-triplets": [
                        "./extension-ci-tools/toolchains"
                ]
        }
}